# Public Supabase values for Astro browser submit.
# Copy this file to .env and replace placeholders locally.
# Do not commit real values.

PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Never put these in Astro PUBLIC_* env vars:
# SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL=
