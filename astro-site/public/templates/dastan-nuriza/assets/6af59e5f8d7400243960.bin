          border-radius: 2px;
          margin-left: 1px;
          margin-right: 1px;
        }

        .otelloReactSlider .reactSlider__thumb {
          width: 24px;
          height: 24px;
          background: var(--theme-color-button-opaque-default);
          border-radius: 100px;
          transform: translateY(-10px); /* 50% от высоты и 2px от высоты reactSlider-track*/
          border: none;
          outline: none;
          box-shadow: var(--theme-shadow-stroke-tertiary);
        }
        .otelloReactSlider .reactSlider__thumb:hover {
          background: var(--theme-color-button-opaque-hover);
        }
        .otelloReactSlider .reactSlider__thumb:active {
          background: var(--theme-color-button-opaque-pressed);
        }

        .otelloReactSlider .reactSlider__track-0,
        .otelloReactSlider .reactSlider__track-2 {
          height: 2px;
          margin-top: 1px;
          background: var(--theme-color-basic-tertiary);
        }

        .otelloReactSlider .reactSlider {
          width: 100%;
          height: 14px;
        }

        .otelloReactSlider .reactSlider__track._sliderTo-0 {
          background: var(--theme-color-surface-inverse);
        }

        .otelloReactSlider .reactSlider__track._sliderTo-1 {
          height: 2px;
          margin-top: 1px;
          background: var(--theme-color-basic-tertiary);
        }

