---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout title="Owner login" description="Безопасный MVP-вход владельца для просмотра заявок.">
  <main class="admin-page owner-login-page">
    <a class="back-link" href={`${base}admin/requests/`}>← К заявкам</a>

    <section class="section compact admin-hero owner-login-hero">
      <p class="eyebrow">Owner access</p>
      <h1>Вход владельца</h1>
      <p class="lead">Введите owner token один раз на своём устройстве. После сохранения админка сможет загружать заявки через защищённую Supabase Edge Function.</p>
    </section>

    <section class="section compact admin-panel owner-login-panel">
      <form class="owner-token-form owner-login-form" id="owner-login-form">
        <label for="owner-token">Owner API token</label>
        <input id="owner-token" name="owner-token" type="password" autocomplete="current-password" placeholder="Вставьте owner token" required />
        <div class="owner-login-actions">
          <button class="button" type="submit">Сохранить и открыть заявки</button>
          <button class="button ghost" id="clear-owner-token" type="button">Выйти / очистить token</button>
        </div>
        <p class="form-note" id="owner-login-status">Token хранится только в localStorage этого браузера. Service-role key сюда не вставляется.</p>
      </form>

      <div class="admin-warning">
        <strong>Безопасно:</strong> в браузер вводится только <code>OWNER_API_TOKEN</code>. <code>SUPABASE_SERVICE_ROLE_KEY</code> остаётся только в Supabase Edge Function.
      </div>
    </section>

    <script>
      const ownerTokenStorageKey = 'invitation_owner_api_token';
      const form = document.getElementById('owner-login-form') as HTMLFormElement | null;
      const input = document.getElementById('owner-token') as HTMLInputElement | null;
      const clearButton = document.getElementById('clear-owner-token') as HTMLButtonElement | null;
      const status = document.getElementById('owner-login-status');
      const requestsUrl = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/admin/requests/`;

      if (input) input.value = window.localStorage.getItem(ownerTokenStorageKey) || '';
      if (status && input?.value) status.textContent = 'Token уже сохранён на этом устройстве. Можно открыть заявки или заменить token.';

      form?.addEventListener('submit', (event) => {
        event.preventDefault();
        const token = input?.value.trim();
        if (!token) {
          if (status) status.textContent = 'Вставьте owner token.';
          return;
        }
        window.localStorage.setItem(ownerTokenStorageKey, token);
        if (status) status.textContent = 'Token сохранён. Открываю заявки...';
        window.location.href = requestsUrl;
      });

      clearButton?.addEventListener('click', () => {
        window.localStorage.removeItem(ownerTokenStorageKey);
        if (input) input.value = '';
        if (status) status.textContent = 'Token удалён из этого браузера.';
      });
    </script>
  </main>
</BaseLayout>
