---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout title="Бриф на сайт-приглашение">
  <main class="brief-page">
    <a class="back-link" href={base}>← Назад в каталог</a>
    <section class="section compact">
      <p class="eyebrow">Заказ</p>
      <h1>Бриф на сайт-приглашение</h1>
      <p class="lead">Эта страница пока как заготовка. Сюда позже добавим форму заказа или ссылку на WhatsApp/Instagram.</p>
      <div class="faq-grid">
        <article class="faq-card"><h3>1. Событие</h3><p>Свадьба, никах, кыз узатуу, день рождения или другое.</p></article>
        <article class="faq-card"><h3>2. Данные</h3><p>Имена, дата, место, программа, фото, пожелания.</p></article>
        <article class="faq-card"><h3>3. Дизайн</h3><p>Выбранный шаблон или индивидуальный стиль.</p></article>
      </div>
    </section>
  </main>
</BaseLayout>
