---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<BaseLayout title="Client preview" description="Первый черновик клиентского сайта, собранный из заявки.">
  <main class="client-preview-page">
    <a class="back-link" href={`${base}admin/requests/`}>← Назад в заявки</a>

    <section class="client-preview-shell" id="client-preview-shell" data-state="loading">
      <div class="preview-empty" id="preview-empty">
        <p class="eyebrow">Client preview</p>
        <h1>Черновик не найден</h1>
        <p class="lead" id="preview-empty-note">Откройте админку, выберите заявку и нажмите “Собрать черновик сайта”.</p>
        <a class="button" href={`${base}admin/requests/`}>Открыть заявки</a>
      </div>

      <article class="generated-invite" id="generated-invite" hidden>
        <header class="generated-hero">
          <p class="eyebrow" id="preview-source">Loading</p>
          <p class="eyebrow" id="preview-event-type">Событие</p>
          <h1 id="preview-names">Имена</h1>
          <p id="preview-intro">Текст приглашения</p>
          <div class="generated-facts">
            <span><b>Дата</b><em id="preview-date">—</em></span>
            <span><b>Время</b><em id="preview-time">—</em></span>
            <span><b>Место</b><em id="preview-venue">—</em></span>
          </div>
        </header>

        <section class="generated-section-list" id="preview-sections"></section>

        <section class="generated-owner-notes">
          <div>
            <p class="eyebrow">Owner next steps</p>
            <h2>Что доделать перед отправкой клиенту</h2>
          </div>
          <ul id="preview-next-steps"></ul>
        </section>
      </article>
    </section>

    <script>
      type GeneratedClientSite = {
        id: string;
        request_id: string;
        generated_at: string;
        template_slug: string;
        package_preference: string;
        title: string;
        names: string;
        client_name: string;
        event_type: string;
        event_date: string;
        event_time: string;
        venue: string;
        language: string;
        invitation_text: string;
        rsvp_needed: string;
        sections: Array<{ title: string; body: string }>;
        next_steps: string[];
      };

      type OwnerApiGeneratedSiteResponse = {
        ok?: boolean;
        error?: string;
        generated_site?: {
          request_number: string;
          site_slug: string;
          status: string;
          draft_payload: GeneratedClientSite;
        };
      };

      const params = new URLSearchParams(window.location.search);
      const requestId = params.get('id') || window.localStorage.getItem('generated_invitation_last_id') || '';
      const shell = document.getElementById('client-preview-shell');
      const empty = document.getElementById('preview-empty');
      const emptyNote = document.getElementById('preview-empty-note');
      const invite = document.getElementById('generated-invite');
      const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
      const ownerTokenStorageKey = 'invitation_owner_api_token';

      function readLocalDraft(id: string): GeneratedClientSite | null {
        if (!id) return null;
        try {
          const raw = window.localStorage.getItem(`generated_invitation_site_${id}`);
          return raw ? JSON.parse(raw) as GeneratedClientSite : null;
        } catch {
          return null;
        }
      }

      async function readOwnerApiDraft(id: string): Promise<{ draft: GeneratedClientSite | null; note?: string }> {
        if (!id) return { draft: null, note: 'id не указан' };
        if (!supabaseUrl) return { draft: null, note: 'PUBLIC_SUPABASE_URL не настроен' };
        const ownerToken = window.localStorage.getItem(ownerTokenStorageKey)?.trim();
        if (!ownerToken) return { draft: null, note: 'Owner API token не сохранён' };

        const endpoint = `${String(supabaseUrl).replace(/\/$/, '')}/functions/v1/owner-requests?generated_site=${encodeURIComponent(id)}`;
        try {
          const response = await fetch(endpoint, { headers: { 'x-owner-token': ownerToken } });
          const body = await response.json() as OwnerApiGeneratedSiteResponse;
          if (!response.ok || !body.ok || !body.generated_site?.draft_payload) {
            return { draft: null, note: body.error || `Owner API вернул ${response.status}` };
          }
          const draft = body.generated_site.draft_payload;
          window.localStorage.setItem(`generated_invitation_site_${draft.request_id || id}`, JSON.stringify(draft));
          window.localStorage.setItem('generated_invitation_last_id', draft.request_id || id);
          return { draft, note: `Supabase generated_sites · ${body.generated_site.status}` };
        } catch (error) {
          return { draft: null, note: error instanceof Error ? error.message : 'Owner API network error' };
        }
      }

      function setText(selector: string, value: string) {
        const node = document.querySelector(selector);
        if (node) node.textContent = value;
      }

      function renderDraft(draft: GeneratedClientSite, sourceNote: string) {
        document.title = `${draft.title} — preview`;
        shell?.setAttribute('data-state', 'ready');
        if (empty) empty.hidden = true;
        if (invite) invite.hidden = false;
        setText('#preview-source', sourceNote);
        setText('#preview-event-type', `${draft.event_type} · ${draft.template_slug} · ${draft.package_preference}`);
        setText('#preview-names', draft.names);
        setText('#preview-intro', draft.invitation_text);
        setText('#preview-date', draft.event_date);
        setText('#preview-time', draft.event_time);
        setText('#preview-venue', draft.venue);

        const sectionsEl = document.getElementById('preview-sections');
        if (sectionsEl) {
          sectionsEl.innerHTML = '';
          draft.sections.forEach((section, index) => {
            const article = document.createElement('article');
            article.className = 'generated-section-card';
            article.innerHTML = `<span>${String(index + 1).padStart(2, '0')}</span><h2></h2><p></p>`;
            const title = article.querySelector('h2');
            const body = article.querySelector('p');
            if (title) title.textContent = section.title;
            if (body) body.textContent = section.body;
            sectionsEl.appendChild(article);
          });
        }

        const nextStepsEl = document.getElementById('preview-next-steps');
        if (nextStepsEl) {
          nextStepsEl.innerHTML = '';
          draft.next_steps.forEach((step) => {
            const item = document.createElement('li');
            item.textContent = step;
            nextStepsEl.appendChild(item);
          });
        }
      }

      async function bootPreview() {
        const ownerApiResult = await readOwnerApiDraft(requestId);
        if (ownerApiResult.draft) {
          renderDraft(ownerApiResult.draft, ownerApiResult.note || 'Supabase generated_sites');
          return;
        }

        const localDraft = readLocalDraft(requestId);
        if (localDraft) {
          renderDraft(localDraft, `localStorage fallback${ownerApiResult.note ? ` · ${ownerApiResult.note}` : ''}`);
          return;
        }

        shell?.setAttribute('data-state', 'missing');
        if (emptyNote) {
          emptyNote.textContent = ownerApiResult.note
            ? `Черновик не найден. Backend note: ${ownerApiResult.note}`
            : 'Откройте админку, выберите заявку и нажмите “Собрать черновик сайта”.';
        }
      }

      bootPreview();
    </script>
  </main>
</BaseLayout>
