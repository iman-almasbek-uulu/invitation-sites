---
const title = 'Dastan / Nuriza — recovery archive';
---
<!doctype html>
<html lang="ky">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title}</title>
  </head>
  <body>
    <main class="recovery-page" data-recovery-page aria-label="Dastan and Nuriza recovery invitation">
      <picture aria-hidden="true">
        <source media="(max-width: 600px)" srcset={`${import.meta.env.BASE_URL}/recovery-assets/dastan-nuriza/mobile-full.png`} />
        <img class="recovery-canvas" src={`${import.meta.env.BASE_URL}/recovery-assets/dastan-nuriza/desktop-full.png`} alt="" />
      </picture>

      <button class="hotspot audio" type="button" data-audio-toggle aria-label="Музыканы күйгүзүү" aria-pressed="false"></button>
      <a class="hotspot map" data-map-link aria-label="Картадан ачуу" href="https://2gis.kg/bishkek/geo/70000001027946380" target="_blank" rel="noreferrer"></a>

      <form class="rsvp-hotspot" data-rsvp-form aria-label="Катышууну ырастоо">
        <label><span class="sr-only">Сиздин аты-жөнүңүз</span><input name="guestName" autocomplete="name" required /></label>
        <label><span class="sr-only">Тойго катыша аласызбы?</span><select name="attendance"><option>Албетте, барам</option><option>Тилекке каршы, бара албайм</option></select></label>
        <button type="submit" aria-label="Жөнөтүү"></button>
      </form>
      <p class="toast" data-rsvp-status aria-live="polite" hidden></p>
    </main>

    <script>
      const audioToggle = document.querySelector('[data-audio-toggle]');
      const rsvpForm = document.querySelector('[data-rsvp-form]');
      const rsvpStatus = document.querySelector('[data-rsvp-status]');
      let enabled = false;

      audioToggle?.addEventListener('click', () => {
        enabled = !enabled;
        audioToggle.setAttribute('aria-pressed', String(enabled));
        audioToggle.setAttribute('aria-label', enabled ? 'Музыка күйгүзүлдү' : 'Музыканы күйгүзүү');
      });

      rsvpForm?.addEventListener('submit', (event) => {
        event.preventDefault();
        const name = new FormData(rsvpForm).get('guestName')?.toString().trim();
        rsvpStatus.textContent = name ? `${name}, жообуңуз сакталды.` : 'Жообуңуз сакталды.';
        rsvpStatus.hidden = false;
        window.setTimeout(() => { rsvpStatus.hidden = true; }, 4000);
      });
    </script>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(html), :global(body) { margin: 0; min-height: 100%; background: #f7ead7; }
  /* The Astro development toolbar is not part of the recovery artifact. */
  :global(astro-dev-toolbar) { display: none !important; }
  .recovery-page { position: relative; width: 100%; max-width: 1280px; margin: 0 auto; line-height: 0; overflow: hidden; }
  .recovery-canvas { display: block; width: 100%; height: auto; user-select: none; }
  .hotspot, .rsvp-hotspot { position: absolute; border: 0; padding: 0; margin: 0; background: transparent; outline-offset: 4px; line-height: normal; }
  .hotspot:focus-visible, .rsvp-hotspot :focus-visible { outline: 3px solid #4a2c1f; }
  .audio { top: 21.7%; left: 10.75%; width: 15.625%; height: 6.9%; cursor: pointer; }
  .map { top: 61.35%; left: 37.65%; width: 17.2%; height: 9.25%; }
  .rsvp-hotspot { top: 73.79%; left: 52.9%; width: 36%; height: 9.3%; display: grid; grid-template-rows: 1fr 1fr; grid-template-columns: 1fr; gap: 0; }
  .rsvp-hotspot label, .rsvp-hotspot input, .rsvp-hotspot select, .rsvp-hotspot button { width: 100%; height: 100%; min-width: 0; opacity: 0; cursor: text; }
  .rsvp-hotspot button { grid-column: 1; cursor: pointer; }
  .toast { position: fixed; z-index: 2; bottom: 20px; left: 50%; transform: translateX(-50%); max-width: min(90vw, 450px); padding: 13px 18px; border-radius: 999px; background: #302118; color: #fff; font: 600 16px/1.25 system-ui, sans-serif; text-align: center; box-shadow: 0 8px 30px #0004; }
  .sr-only { position: absolute; overflow: hidden; width: 1px; height: 1px; clip: rect(0,0,0,0); white-space: nowrap; }
  @media (max-width: 600px) {
    .recovery-page { max-width: 390px; }
    .audio { top: 3.08%; left: 12.56%; width: 8.47%; height: 1.45%; }
    .map { top: 64.05%; left: 28%; width: 25%; height: 4.0%; }
    .rsvp-hotspot { top: 81.96%; left: 9.75%; width: 80.5%; height: 9.35%; }
  }
</style>
