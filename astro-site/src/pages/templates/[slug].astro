---
import BaseLayout from '../../layouts/BaseLayout.astro';
import templates from '../../data/templates.json';

export function getStaticPaths() {
  return templates.map((template) => ({ params: { slug: template.slug }, props: { template } }));
}

const { template } = Astro.props;
const palette: Record<string, string[]> = {
  luxury: ['#fffaf4', '#5b3428', '#2d1a13'],
  minimal: ['#f4f1ec', '#7c8a78', '#232621'],
  elegant: ['#eef4ef', '#7fa081', '#1d2b22'],
  party: ['#fff0d8', '#f28d35', '#321c13'],
  soft: ['#eef6ff', '#8bb6d8', '#203040'],
};
const colors = palette[template.style] ?? palette.luxury;
const isLuxuryWedding = template.slug === 'wedding-luxury-01';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const event = {
  bride: 'Амина',
  groom: 'Ислам',
  couple: 'Амина & Ислам',
  date: '24 августа 2026',
  day: '24',
  month: 'Август',
  year: '2026',
  weekday: 'Понедельник',
  time: '18:00',
  venue: 'Ресторан “Алтын Сарай”',
  address: 'Бишкек · ул. Токтогула 125',
};

const program = [
  ['17:30', 'Сбор гостей'],
  ['18:00', 'Начало торжества'],
  ['19:00', 'Праздничный ужин'],
  ['20:30', 'Танцы и поздравления'],
];
---
<BaseLayout title={`${template.name} — демо приглашения`} description={template.description}>
  <main class:list={['invite-demo', { 'luxury-invite': isLuxuryWedding }]} style={`--paper:${colors[0]};--accent:${colors[1]};--ink:${colors[2]}`}>
    <a class="back-link" href={base}>← Назад в каталог</a>

    {isLuxuryWedding ? (
      <>
        <section class="toi-page" id="top">
          <button class="toi-music" type="button" aria-label="Включить музыку">
            <span>♪</span> Музыка
          </button>

          <section class="toi-cover">
            <div class="toi-names-side">
              <span>{event.bride}</span>
              <span>{event.groom}</span>
            </div>
            <div class="toi-frame top" aria-hidden="true"><i></i><b>♡</b><i></i></div>
            <div class="toi-envelope" aria-hidden="true">
              <div class="toi-seal">БАСЫҢЫЗ</div>
            </div>
            <div class="toi-cover-title">
              <p>Үйлөнүү үлпөт тойго чакыруу</p>
              <h1>{event.bride}<br /><em>&</em><br />{event.groom}</h1>
            </div>
            <a class="toi-heart-date" href="#invite"><strong>{event.day}</strong></a>
            <div class="toi-line" aria-hidden="true"></div>
          </section>

          <section class="toi-invite-card" id="invite">
            <div class="toi-frame" aria-hidden="true"><i></i><b>♡</b><i></i></div>
            <p class="toi-script">Урматтуу коноктор</p>
            <h2>Сиздерди кубанычыбызга күбө болууга чакырабыз</h2>
            <p>
              Бул күн биз үчүн өзгөчө. Жакындарыбыздын батасы, жылуу сөзү жана катышуусу
              майрамыбызды дагы да маңыздуу кылат.
            </p>
          </section>

          <section class="toi-date-section">
            <p class="toi-script">Save the date</p>
            <div class="toi-month">{event.month}</div>
            <div class="toi-calendar">
              <span>ПН</span><span>ВТ</span><span>СР</span><span>ЧТ</span><span>ПТ</span><span>СБ</span><span>ВС</span>
              <em></em><em></em><em></em><em></em><em></em><b>1</b><b>2</b>
              <b>3</b><b>4</b><b>5</b><b>6</b><b>7</b><b>8</b><b>9</b>
              <b>10</b><b>11</b><b>12</b><b>13</b><b>14</b><b>15</b><b>16</b>
              <b>17</b><b>18</b><b>19</b><b>20</b><b>21</b><b>22</b><b>23</b>
              <strong>{event.day}</strong><b>25</b><b>26</b><b>27</b><b>28</b><b>29</b><b>30</b>
              <b>31</b>
            </div>
            <p class="toi-time">{event.weekday} · {event.time}</p>
          </section>

          <section class="toi-venue">
            <p>Ресторан</p>
            <h2>{event.venue}</h2>
            <span>{event.address}</span>
            <a href="https://2gis.kg/bishkek" target="_blank" rel="noreferrer">Картага өтүү</a>
          </section>

          <section class="toi-timeline">
            <p class="toi-script">Программа</p>
            {program.map(([time, title]) => (
              <article>
                <time>{time}</time>
                <span>{title}</span>
              </article>
            ))}
          </section>

          <section class="toi-countdown" data-countdown="2026-08-24T18:00:00+06:00">
            <p class="toi-script">Тойго чейин калды</p>
            <div>
              <article><strong data-days>00</strong><span>Күн</span></article>
              <article><strong data-hours>00</strong><span>Саат</span></article>
              <article><strong data-minutes>00</strong><span>Мүнөт</span></article>
              <article><strong data-seconds>00</strong><span>Секунд</span></article>
            </div>
          </section>

          <section class="toi-rsvp">
            <div class="toi-frame" aria-hidden="true"><i></i><b>♡</b><i></i></div>
            <h2>Тойго катыша аласызбы?</h2>
            <form>
              <label><input type="radio" name="rsvp" /> Ооба, барам</label>
              <label><input type="radio" name="rsvp" /> Тилекке каршы, бара албайм</label>
              <input type="text" placeholder="Сиздин атыңыз?" />
              <button type="button">Жиберүү</button>
            </form>
          </section>

          <section class="toi-final">
            <p>Сүйүү жана урмат менен</p>
            <h2>{event.couple}</h2>
            <div class="hero-actions center">
              <a class="button" href={`${base}brief/`}>Заказать такой сайт</a>
              <a class="button secondary" href={base}>Другие шаблоны</a>
            </div>
          </section>
        </section>

        <script>
          const countdown = document.querySelector('[data-countdown]');
          const musicButton = document.querySelector('.toi-music');
          let musicOn = false;
          musicButton?.addEventListener('click', () => {
            musicOn = !musicOn;
            musicButton.classList.toggle('is-playing', musicOn);
            musicButton.innerHTML = musicOn ? '<span>♪</span> Музыка включена' : '<span>♪</span> Музыка';
          });
          function updateCountdown() {
            if (!countdown) return;
            const rawTarget = countdown.getAttribute('data-countdown');
            if (!rawTarget) return;
            const target = new Date(rawTarget).getTime();
            const diff = Math.max(target - Date.now(), 0);
            const days = Math.floor(diff / 86400000);
            const hours = Math.floor((diff % 86400000) / 3600000);
            const minutes = Math.floor((diff % 3600000) / 60000);
            const seconds = Math.floor((diff % 60000) / 1000);
            const setText = (selector: string, value: number) => {
              const node = countdown.querySelector(selector);
              if (node) node.textContent = String(value).padStart(2, '0');
            };
            setText('[data-days]', days);
            setText('[data-hours]', hours);
            setText('[data-minutes]', minutes);
            setText('[data-seconds]', seconds);
          }
          updateCountdown();
          setInterval(updateCountdown, 1000);
        </script>
      </>
    ) : (
      <section class="invite-card">
        <p class="eyebrow">{template.label}</p>
        <h1>{template.name}</h1>
        <p class="invite-lead">{template.description}</p>
        <div class="names">Амина & Ислам</div>
        <p class="date">24 августа 2026 · 18:00</p>
        <div class="invite-details">
          <article><span>📍</span><h2>Локация</h2><p>Ресторан “Алтын Сарай”, Бишкек</p></article>
          <article><span>🗓️</span><h2>Программа</h2><p>Встреча гостей, церемония, ужин, фото и поздравления.</p></article>
          <article><span>💌</span><h2>RSVP</h2><p>Подтвердите участие до 10 августа.</p></article>
        </div>
        <div class="hero-actions center">
          <a class="button" href={`${base}brief/`}>Заказать такой сайт</a>
          <a class="button secondary" href={base}>Другие шаблоны</a>
        </div>
      </section>
    )}
  </main>
</BaseLayout>
