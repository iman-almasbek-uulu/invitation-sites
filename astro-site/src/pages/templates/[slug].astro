---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { templates, type InvitationTemplate } from '../../data/templates';

export function getStaticPaths() {
  return templates.map((template) => ({ params: { slug: template.slug }, props: { template } }));
}

const { template } = Astro.props as { template: InvitationTemplate };
const palette: Record<string, string[]> = {
  luxury: ['#fffaf4', '#5b3428', '#2d1a13'],
  minimal: ['#f4f1ec', '#7c8a78', '#232621'],
  elegant: ['#eef4ef', '#7fa081', '#1d2b22'],
  party: ['#fff0d8', '#f28d35', '#321c13'],
  soft: ['#eef6ff', '#8bb6d8', '#203040'],
};
const colors = palette[template.style] ?? palette.luxury;
const isLuxuryWedding = template.slug === 'wedding-luxury-01';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const firstSectionAsset = (file: string) => `${base}assets/wedding-first-section/${file}`;
---
<BaseLayout title={`${template.name} — демо приглашения`} description={template.description}>
  <main class:list={['invite-demo', { 'luxury-invite': isLuxuryWedding }]} style={`--paper:${colors[0]};--accent:${colors[1]};--ink:${colors[2]}`}>
    {!isLuxuryWedding && <a class="back-link" href={base}>← Назад в каталог</a>}

    {isLuxuryWedding ? (
      <section
        class="wedding-first-hero"
        data-wedding-first-hero
        style={`--gold-divider:url(${firstSectionAsset('gold-divider.svg')});`}
      >
        <div class="wedding-layered-stage" aria-hidden="true">
          <img class="wedding-stage-background" src={firstSectionAsset('background.png')} alt="" loading="eager" />
          <img class="wedding-stage-flower wedding-stage-flower--top" src={firstSectionAsset('flowers-top-right.png')} alt="" loading="eager" />
          <img class="wedding-stage-flower wedding-stage-flower--bottom" src={firstSectionAsset('flowers-bottom-left.png')} alt="" loading="eager" />
        </div>
        <div class="wedding-first-shell">
          <header class="wedding-first-title">
            <p>Wedding Invitation</p>
            <h1>Ayan & Amina</h1>
            <img src={firstSectionAsset('gold-divider.svg')} alt="" />
            <time datetime="2026-09-12">12 September 2026</time>
          </header>

          <div class="wedding-envelope-scene">
            <img class="env-layer env-back" src={firstSectionAsset('envelope-back.png')} alt="" />
            <div class="layer-card">
              <img class="layer-card-shadow" src={firstSectionAsset('card-shadow.png')} alt="" />
              <img class="layer-card-art" src={firstSectionAsset('invitation-card.png')} alt="" />
              <article class="layer-card-copy" aria-live="polite">
                <p>Together with our families</p>
                <strong>Ayan & Amina</strong>
                <span>invite you to celebrate our wedding</span>
                <time datetime="2026-09-12">12 September 2026</time>
              </article>
            </div>
            <img class="env-layer env-side env-side--left" src={firstSectionAsset('envelope-left-flap.png')} alt="" />
            <img class="env-layer env-side env-side--right" src={firstSectionAsset('envelope-right-flap.png')} alt="" />
            <img class="env-layer env-front-pocket" src={firstSectionAsset('envelope-bottom-flap.png')} alt="" />
            <div class="env-top-flap">
              <img class="env-top-face env-top-face--outside" src={firstSectionAsset('envelope-top-flap.png')} alt="" />
              <img class="env-top-face env-top-face--inside" src={firstSectionAsset('envelope-top-flap.png')} alt="" />
            </div>
            <button class="wax-seal-button" type="button" data-open-first-envelope aria-label="Open wedding invitation envelope" aria-expanded="false">
              <img class="wax-seal-intact" src={firstSectionAsset('wax-seal.png')} alt="" />
              <img class="wax-seal-half wax-seal-half--left" src={firstSectionAsset('wax-seal-left.png')} alt="" />
              <img class="wax-seal-half wax-seal-half--right" src={firstSectionAsset('wax-seal-right.png')} alt="" />
              <span class="sr-only">Open envelope</span>
            </button>
          </div>

          <div class="wedding-first-actions">
            <button class="open-invitation-button" type="button" data-open-first-envelope aria-expanded="false">Open Invitation</button>
            <button class="replay-invitation-button" type="button" data-replay-first-envelope>Replay opening</button>
            <a class="view-invitation-button" href={`${base}brief/?template=${template.slug}`} data-view-invitation>View Invitation</a>
          </div>
        </div>

        <script>
          const hero = document.querySelector('[data-wedding-first-hero]');
          const openButtons = document.querySelectorAll('[data-open-first-envelope]');
          const replayButton = document.querySelector('[data-replay-first-envelope]');
          let openingStarted = false;
          let timeline: number[] = [];
          const openInvitation = () => {
            if (!hero || openingStarted) return;
            openingStarted = true;
            hero.classList.add('is-unsealing');
            openButtons.forEach((button) => {
              button.setAttribute('aria-expanded', 'true');
              if (button instanceof HTMLButtonElement) button.disabled = true;
            });
            timeline = [
              window.setTimeout(() => hero.classList.add('is-opening'), 280),
              window.setTimeout(() => hero.classList.add('is-revealing'), 860),
              window.setTimeout(() => hero.classList.add('is-opened'), 1850),
            ];
          };
          const replayInvitation = () => {
            if (!hero || prefersReducedMotion) return;
            timeline.forEach((id) => window.clearTimeout(id));
            timeline = [];
            openingStarted = false;
            hero.classList.remove('is-unsealing', 'is-opening', 'is-revealing', 'is-opened');
            openButtons.forEach((button) => {
              button.setAttribute('aria-expanded', 'false');
              if (button instanceof HTMLButtonElement) button.disabled = false;
            });
            window.requestAnimationFrame(() => window.requestAnimationFrame(openInvitation));
          };
          const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (prefersReducedMotion) {
            hero?.classList.add('is-unsealing', 'is-opening', 'is-revealing', 'is-opened', 'is-reduced-motion');
            openButtons.forEach((button) => button.setAttribute('aria-expanded', 'true'));
          } else {
            openButtons.forEach((button) => button.addEventListener('click', openInvitation));
            replayButton?.addEventListener('click', replayInvitation);
          }
        </script>
      </section>
    ) : (
      <section class="invite-card">
        <p class="eyebrow">{template.label}</p>
        <h1>{template.name}</h1>
        <p class="invite-lead">{template.description}</p>
        <div class="names">Амина & Ислам</div>
        <p class="date">24 августа 2026 · 18:00</p>
        <div class="invite-details">
          <article><span>📍</span><h2>Локация</h2><p>Ресторан “Алтын Сарай”, Бишкек</p></article>
          <article><span>🗓️</span><h2>Программа</h2><p>Встреча гостей, церемония, ужин, фото и поздравления.</p></article>
          <article><span>💌</span><h2>RSVP</h2><p>Подтвердите участие до 10 августа.</p></article>
        </div>
        <div class="hero-actions center">
          <a class="button" href={`${base}brief/`}>Заказать такой сайт</a>
          <a class="button secondary" href={base}>Другие шаблоны</a>
        </div>
      </section>
    )}
  </main>
</BaseLayout>
