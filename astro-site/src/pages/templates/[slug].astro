---
import BaseLayout from '../../layouts/BaseLayout.astro';
import templates from '../../data/templates.json';

export function getStaticPaths() {
  return templates.map((template) => ({ params: { slug: template.slug }, props: { template } }));
}

const { template } = Astro.props;
const palette: Record<string, string[]> = {
  luxury: ['#fbf4ea', '#b68b45', '#2a2118'],
  minimal: ['#f4f1ec', '#7c8a78', '#232621'],
  elegant: ['#eef4ef', '#7fa081', '#1d2b22'],
  party: ['#fff0d8', '#f28d35', '#321c13'],
  soft: ['#eef6ff', '#8bb6d8', '#203040'],
};
const colors = palette[template.style] ?? palette.luxury;
const isLuxuryWedding = template.slug === 'wedding-luxury-01';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const event = {
  couple: 'Амина & Ислам',
  bride: 'Амина',
  groom: 'Ислам',
  date: '24 августа 2026',
  day: '24',
  month: 'Август',
  year: '2026',
  weekday: 'Понедельник',
  time: '18:00',
  venue: 'Алтын Сарай',
  address: 'Бишкек · ул. Токтогула 125',
  deadline: 'до 10 августа',
};

const program = [
  ['17:30', 'Welcome', 'Сбор гостей, welcome drinks и первые фотографии'],
  ['18:00', 'Ceremony', 'Красивое открытие вечера и поздравления'],
  ['19:00', 'Dinner', 'Праздничный ужин, тосты и семейные моменты'],
  ['20:30', 'Party', 'Музыка, танцы и незабываемая атмосфера'],
];
---
<BaseLayout title={`${template.name} — демо приглашения`} description={template.description}>
  <main class:list={['invite-demo', { 'luxury-invite': isLuxuryWedding }]} style={`--paper:${colors[0]};--accent:${colors[1]};--ink:${colors[2]}`}>
    <a class="back-link" href={base}>← Назад в каталог</a>

    {isLuxuryWedding ? (
      <>
        <div class="lux-noise" aria-hidden="true"></div>
        <div class="romance-effects" aria-hidden="true">
          <span class="bokeh bokeh-one"></span>
          <span class="bokeh bokeh-two"></span>
          <span class="bokeh bokeh-three"></span>
          <span class="petal petal-1">✦</span>
          <span class="petal petal-2">❦</span>
          <span class="petal petal-3">✧</span>
          <span class="petal petal-4">❦</span>
          <span class="petal petal-5">✦</span>
          <span class="petal petal-6">✧</span>
          <span class="petal petal-7">❦</span>
          <span class="petal petal-8">✦</span>
        </div>

        <section class="lux-cover" id="top">
          <button class="music-pill" type="button" aria-label="Включить музыку">
            <span class="music-icon">♪</span>
            <span>Включить музыку</span>
          </button>
          <div class="cover-photo" aria-hidden="true">
            <span class="photo-bloom bloom-a"></span>
            <span class="photo-bloom bloom-b"></span>
            <span class="photo-arch"></span>
            <span class="photo-couple">A · I</span>
          </div>
          <div class="cover-copy">
            <p class="luxury-kicker">Wedding invitation</p>
            <p class="save-date">Save the date</p>
            <h1>{event.couple}</h1>
            <div class="cover-date">
              <span>{event.weekday}</span>
              <strong>{event.day}</strong>
              <span>{event.month} · {event.year}</span>
            </div>
            <p class="hero-note">Приглашаем вас разделить с нами вечер любви, семьи и красивых воспоминаний.</p>
            <a class="scroll-cue" href="#invite">Открыть приглашение ↓</a>
          </div>
        </section>

        <section class="invite-section statement-section reveal-card" id="invite">
          <p class="script-label">Дорогие гости</p>
          <h2>Мы хотим видеть вас рядом в самый важный день</h2>
          <p>
            Этот вечер мы собираем для самых близких людей. Ваше присутствие, улыбки и тёплые слова
            сделают нашу свадьбу по-настоящему особенной.
          </p>
        </section>

        <section class="invite-section names-section reveal-card">
          <div class="name-card left">
            <span>Невеста</span>
            <h2>{event.bride}</h2>
          </div>
          <div class="name-divider">&</div>
          <div class="name-card right">
            <span>Жених</span>
            <h2>{event.groom}</h2>
          </div>
        </section>

        <section class="invite-section calendar-section reveal-card">
          <div class="section-title-small">Дата торжества</div>
          <div class="premium-date-card">
            <span>{event.month}</span>
            <strong>{event.day}</strong>
            <em>{event.year}</em>
            <p>{event.weekday} · {event.time}</p>
          </div>
          <div class="calendar-card" aria-label={`${event.date}`}>
            <div class="calendar-grid">
              <span>ПН</span><span>ВТ</span><span>СР</span><span>ЧТ</span><span>ПТ</span><span>СБ</span><span>ВС</span>
              <em></em><em></em><em></em><em></em><em></em><b>1</b><b>2</b>
              <b>3</b><b>4</b><b>5</b><b>6</b><b>7</b><b>8</b><b>9</b>
              <b>10</b><b>11</b><b>12</b><b>13</b><b>14</b><b>15</b><b>16</b>
              <b>17</b><b>18</b><b>19</b><b>20</b><b>21</b><b>22</b><b>23</b>
              <strong>24</strong><b>25</b><b>26</b><b>27</b><b>28</b><b>29</b><b>30</b>
              <b>31</b>
            </div>
          </div>
        </section>

        <section class="invite-section timeline-section reveal-card">
          <div class="section-title-small">Программа вечера</div>
          <h2>Как пройдёт праздник</h2>
          <div class="timeline-list premium-timeline">
            {program.map(([time, title, text]) => (
              <article>
                <time>{time}</time>
                <div><h3>{title}</h3><p>{text}</p></div>
              </article>
            ))}
          </div>
        </section>

        <section class="invite-section venue-section reveal-card">
          <div class="venue-card premium-venue">
            <p class="script-label">Локация</p>
            <h2>{event.venue}</h2>
            <p>{event.address}</p>
            <div class="map-preview" aria-hidden="true">
              <span></span><i></i><b></b>
            </div>
            <div class="map-buttons">
              <a href="https://2gis.kg/bishkek" target="_blank" rel="noreferrer">Открыть в 2GIS</a>
              <a href="https://maps.google.com" target="_blank" rel="noreferrer">Google Maps</a>
            </div>
          </div>
        </section>

        <section class="invite-section dress-section reveal-card">
          <div class="section-title-small">Dress code</div>
          <h2>Палитра вечера</h2>
          <p>Будем рады, если вы поддержите мягкие оттенки champagne, ivory, mocha и gold.</p>
          <div class="dress-palette" aria-label="Палитра дресс-кода">
            <span style="--swatch:#fff7ea"></span>
            <span style="--swatch:#ead8bf"></span>
            <span style="--swatch:#c9a56a"></span>
            <span style="--swatch:#806448"></span>
            <span style="--swatch:#24170f"></span>
          </div>
        </section>

        <section class="invite-section countdown-section reveal-card">
          <p class="script-label">До свадьбы осталось</p>
          <div class="countdown" data-countdown="2026-08-24T18:00:00+06:00">
            <div><strong data-days>00</strong><span>дней</span></div>
            <div><strong data-hours>00</strong><span>часов</span></div>
            <div><strong data-minutes>00</strong><span>минут</span></div>
            <div><strong data-seconds>00</strong><span>секунд</span></div>
          </div>
        </section>

        <section class="invite-section rsvp-section reveal-card">
          <p class="script-label">RSVP</p>
          <h2>Подтвердите присутствие {event.deadline}</h2>
          <form class="rsvp-form">
            <label>Ваше имя<input type="text" placeholder="Например: Айжан" /></label>
            <label>Сможете прийти?<select><option>Да, с радостью приду</option><option>Отвечу позже</option><option>К сожалению, не смогу</option></select></label>
            <label>Количество гостей<select><option>1 гость</option><option>2 гостя</option><option>3 гостя</option><option>4 гостя</option></select></label>
            <button type="button">Отправить ответ</button>
          </form>
          <a class="whatsapp-cta" href="https://wa.me/?text=Здравствуйте,%20я%20подтверждаю%20участие%20на%20свадьбе" target="_blank" rel="noreferrer">Ответить через WhatsApp</a>
        </section>

        <section class="invite-section final-section reveal-card">
          <p>С любовью и уважением,</p>
          <h2>{event.couple}</h2>
          <div class="hero-actions center">
            <a class="button" href={`${base}brief/`}>Заказать такой сайт</a>
            <a class="button secondary" href={base}>Другие шаблоны</a>
          </div>
        </section>

        <script>
          const countdown = document.querySelector('[data-countdown]');
          const musicButton = document.querySelector('.music-pill');
          let musicOn = false;

          musicButton?.addEventListener('click', () => {
            musicOn = !musicOn;
            musicButton.classList.toggle('is-playing', musicOn);
            const musicLabel = musicButton.querySelector('span:last-child');
            if (musicLabel) musicLabel.textContent = musicOn ? 'Музыка включена' : 'Включить музыку';
          });

          function updateCountdown() {
            if (!countdown) return;
            const rawTarget = countdown.getAttribute('data-countdown');
            if (!rawTarget) return;
            const target = new Date(rawTarget).getTime();
            const diff = Math.max(target - Date.now(), 0);
            const days = Math.floor(diff / 86400000);
            const hours = Math.floor((diff % 86400000) / 3600000);
            const minutes = Math.floor((diff % 3600000) / 60000);
            const seconds = Math.floor((diff % 60000) / 1000);
            countdown.querySelector('[data-days]')!.textContent = String(days).padStart(2, '0');
            countdown.querySelector('[data-hours]')!.textContent = String(hours).padStart(2, '0');
            countdown.querySelector('[data-minutes]')!.textContent = String(minutes).padStart(2, '0');
            countdown.querySelector('[data-seconds]')!.textContent = String(seconds).padStart(2, '0');
          }
          updateCountdown();
          setInterval(updateCountdown, 1000);

          const cards = document.querySelectorAll('.reveal-card');
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.16 });
          cards.forEach((card) => observer.observe(card));
        </script>
      </>
    ) : (
      <section class="invite-card">
        <p class="eyebrow">{template.label}</p>
        <h1>{template.name}</h1>
        <p class="invite-lead">{template.description}</p>
        <div class="names">Амина & Ислам</div>
        <p class="date">24 августа 2026 · 18:00</p>
        <div class="invite-details">
          <article><span>📍</span><h2>Локация</h2><p>Ресторан “Алтын Сарай”, Бишкек</p></article>
          <article><span>🗓️</span><h2>Программа</h2><p>Встреча гостей, церемония, ужин, фото и поздравления.</p></article>
          <article><span>💌</span><h2>RSVP</h2><p>Подтвердите участие до 10 августа.</p></article>
        </div>
        <div class="hero-actions center">
          <a class="button" href={`${base}brief/`}>Заказать такой сайт</a>
          <a class="button secondary" href={base}>Другие шаблоны</a>
        </div>
      </section>
    )}
  </main>
</BaseLayout>
