---
import BaseLayout from '../../layouts/BaseLayout.astro';
import templates from '../../data/templates.json';

export function getStaticPaths() {
  return templates.map((template) => ({ params: { slug: template.slug }, props: { template } }));
}

const { template } = Astro.props;
const palette: Record<string, string[]> = {
  luxury: ['#fffaf4', '#5b3428', '#2d1a13'],
  minimal: ['#f4f1ec', '#7c8a78', '#232621'],
  elegant: ['#eef4ef', '#7fa081', '#1d2b22'],
  party: ['#fff0d8', '#f28d35', '#321c13'],
  soft: ['#eef6ff', '#8bb6d8', '#203040'],
};
const colors = palette[template.style] ?? palette.luxury;
const isLuxuryWedding = template.slug === 'wedding-luxury-01';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const event = {
  bride: 'Айсулуу',
  groom: 'Нурсултан',
  monogram: 'A & N',
  date: '15 июля 2026',
  day: '15',
  month: 'Июль',
  year: '2026',
  weekday: 'Среда',
  time: '17:00',
  venue: 'Ресторан “Ак-Кеме”',
  address: 'г. Бишкек, ул. Токтогула 2/2',
  phone: '+996 700 123 456',
};

const rail = [
  ['01','WELCOME','Главный экран\nЗакрытый конверт'],
  ['02','ОТКРЫТИЕ','Конверт открывается'],
  ['03','ПРИГЛАШЕНИЕ','Основная информация\nо свадьбе'],
  ['04','LOVE STORY','История любви пары'],
  ['05','ТАЙМЕР','До нашей свадьбы'],
  ['06','ПРОГРАММА ДНЯ','План мероприятия'],
  ['07','ЛОКАЦИЯ','Место проведения'],
  ['08','DRESS CODE','Дресс-код для гостей'],
  ['09','ГАЛЕРЕЯ','Фотографии пары'],
  ['10','ПОДТВЕРЖДЕНИЕ RSVP','Подтвердите участие'],
  ['11','ПОЖЕЛАНИЯ','Пожелания и информация'],
  ['12','ФИНАЛЬНЫЙ ЭКРАН','Спасибо!\nДо встречи на свадьбе'],
];

const program = [
  ['16:30', 'Сбор гостей'],
  ['17:00', 'Церемония'],
  ['18:00', 'Фотосессия'],
  ['19:00', 'Банкет'],
  ['22:00', 'Торт'],
  ['23:00', 'Завершение вечера'],
];

const gallery = [
  'https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=420&q=85',
  'https://images.unsplash.com/photo-1520854221256-17451cc331bf?auto=format&fit=crop&w=420&q=85',
  'https://images.unsplash.com/photo-1511285560929-80b456fea0bc?auto=format&fit=crop&w=420&q=85',
  'https://images.unsplash.com/photo-1529636798458-92182e662485?auto=format&fit=crop&w=420&q=85',
  'https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&w=420&q=85',
  'https://images.unsplash.com/photo-1469371670807-013ccf25f16a?auto=format&fit=crop&w=420&q=85',
];

const phonePreviews = ['01','02','03','04','05','06','07','08','09','10','11','12'];
---
<BaseLayout title={`${template.name} — демо приглашения`} description={template.description}>
  <main class:list={['invite-demo', { 'luxury-invite': isLuxuryWedding }]} style={`--paper:${colors[0]};--accent:${colors[1]};--ink:${colors[2]}`}>
    <a class="back-link" href={base}>← Назад в каталог</a>

    {isLuxuryWedding ? (
      <section class="royal-page" data-royal-page>
        <button class="royal-music" type="button" aria-label="Включить музыку"><span>♪</span> Музыка</button>
        <div class="royal-ambience" aria-hidden="true">
          {Array.from({ length: 16 }).map((_, i) => <i class={`royal-petal p${i + 1}`}>❦</i>)}
          {Array.from({ length: 18 }).map((_, i) => <b class={`royal-spark s${i + 1}`}></b>)}
        </div>

        <aside class="royal-left-rail" aria-label="Навигация по приглашению">
          {rail.map(([num, title, text]) => (
            <a href={`#section-${num}`}>
              <strong>{num}</strong>
              <span>{title}</span>
              <small>{text}</small>
            </a>
          ))}
        </aside>

        <aside class="royal-phone-rail" aria-hidden="true">
          {phonePreviews.map((n) => (
            <a class={`royal-phone-shot shot-${n}`} href={`#section-${n}`}>
              <em>{n}</em>
              <span></span>
              <i></i>
            </a>
          ))}
        </aside>

        <section class="royal-stage">
          <section class="royal-panel royal-cover" id="section-01">
            <div class="royal-corners"></div>
            <div class="royal-envelope closed">
              <div class="royal-envelope-text">Үйлөнүү тойго<br />Чакыруу</div>
              <div class="royal-wax">бас</div>
              <div class="royal-flower left"></div>
              <div class="royal-flower right"></div>
            </div>
            <p class="royal-scroll">Нажмите на печать</p>
          </section>

          <section class="royal-panel royal-open" id="section-02">
            <div class="royal-paper">
              <span>{event.monogram}</span>
            </div>
            <div class="royal-envelope open"><div class="royal-wax">ачуу</div></div>
          </section>

          <section class="royal-panel royal-main-info" id="section-03">
            <div class="royal-photo-card"></div>
            <div class="royal-info-text">
              <p>Биздин эң маанилүү күнгө<br />сизди чакырабыз!</p>
              <h1>{event.groom} & {event.bride}</h1>
              <div class="royal-facts">
                <span><b>Дата</b>{event.date}</span>
                <span><b>Убактысы</b>{event.time}</span>
                <span><b>Өтүү жери</b>{event.venue}</span>
              </div>
            </div>
          </section>

          <section class="royal-panel royal-story" id="section-04">
            <p class="royal-script">Наша история любви</p>
            <h2>{event.groom} & {event.bride}</h2>
            <div class="royal-couple-live"></div>
          </section>

          <section class="royal-panel royal-timer" id="section-05" data-countdown="2026-07-15T17:00:00+06:00">
            <p class="royal-script">До нашей свадьбы осталось</p>
            <div class="royal-counts">
              <article><strong data-days>00</strong><span>Дней</span></article>
              <article><strong data-hours>00</strong><span>Часов</span></article>
              <article><strong data-minutes>00</strong><span>Минут</span></article>
              <article><strong data-seconds>00</strong><span>Секунд</span></article>
            </div>
          </section>

          <section class="royal-panel royal-program" id="section-06">
            <p class="royal-script">Программа дня</p>
            <div class="royal-program-list">
              {program.map(([time, title]) => <article><time>{time}</time><span>{title}</span></article>)}
            </div>
          </section>

          <section class="royal-panel royal-location" id="section-07">
            <div class="royal-map"></div>
            <div>
              <p class="royal-script">Место проведения</p>
              <h2>{event.venue}</h2>
              <p>{event.address}<br />{event.phone}</p>
              <a href="https://maps.google.com" target="_blank" rel="noreferrer">Открыть в Google Maps</a>
            </div>
          </section>

          <section class="royal-panel royal-dress" id="section-08">
            <p class="royal-script">Дресс-код</p>
            <p>Мы будем рады, если вы поддержите цветовую гамму</p>
            <div class="royal-dress-cards"><article>Для мужчин<br /><b>Классика</b></article><article>Для женщин<br /><b>Вечернее платье</b></article></div>
            <div class="royal-palette"><span></span><span></span><span></span><span></span><span></span><span></span></div>
          </section>

          <section class="royal-panel royal-gallery" id="section-09">
            <p class="royal-script">Наша галерея</p>
            <div class="royal-gallery-strip" aria-label="Живая галерея свадебных фото">
              {gallery.map((src) => <div class="royal-gallery-photo" style={`background-image:url('${src}')`} role="img" aria-label="Свадебное фото"></div>)}
            </div>
          </section>

          <section class="royal-panel royal-rsvp" id="section-10">
            <p class="royal-script">Подтвердите ваше участие</p>
            <form>
              <input placeholder="Ваше имя" />
              <input placeholder="Телефон" />
              <label><span>Будете присутствовать?</span><select><option>Да</option><option>Нет</option></select></label>
              <label><span>Количество гостей</span><select><option>1</option><option>2</option><option>3+</option></select></label>
              <button type="button">Подтвердить участие ♡</button>
            </form>
          </section>

          <section class="royal-panel royal-wishes" id="section-11">
            <div class="royal-gift"></div>
            <div>
              <p class="royal-script">Пожелания</p>
              <p>Самым главным подарком для нас станет ваше присутствие в этот день. Если вы планируете сделать подарок — мы будем благодарны вашему вниманию.</p>
            </div>
          </section>

          <section class="royal-panel royal-final" id="section-12">
            <div class="royal-final-logo">{event.monogram}</div>
            <h2>Спасибо!</h2>
            <p>До встречи на нашей свадьбе!</p>
            <div class="hero-actions center">
              <a class="button" href={`${base}brief/`}>Заказать такой сайт</a>
              <a class="button secondary" href={base}>Другие шаблоны</a>
            </div>
          </section>
        </section>

        <script>
          const countdown = document.querySelector('[data-countdown]');
          const musicButton = document.querySelector('.royal-music');
          let musicOn = false;
          musicButton?.addEventListener('click', () => {
            musicOn = !musicOn;
            musicButton.classList.toggle('is-playing', musicOn);
            musicButton.innerHTML = musicOn ? '<span>♪</span> Музыка включена' : '<span>♪</span> Музыка';
          });
          function updateCountdown() {
            if (!countdown) return;
            const rawTarget = countdown.getAttribute('data-countdown');
            if (!rawTarget) return;
            const target = new Date(rawTarget).getTime();
            const diff = Math.max(target - Date.now(), 0);
            const days = Math.floor(diff / 86400000);
            const hours = Math.floor((diff % 86400000) / 3600000);
            const minutes = Math.floor((diff % 3600000) / 60000);
            const seconds = Math.floor((diff % 60000) / 1000);
            const setText = (selector: string, value: number) => {
              const node = countdown.querySelector(selector);
              if (node) node.textContent = String(value).padStart(2, '0');
            };
            setText('[data-days]', days); setText('[data-hours]', hours); setText('[data-minutes]', minutes); setText('[data-seconds]', seconds);
          }
          updateCountdown(); setInterval(updateCountdown, 1000);
        </script>
      </section>
    ) : (
      <section class="invite-card">
        <p class="eyebrow">{template.label}</p>
        <h1>{template.name}</h1>
        <p class="invite-lead">{template.description}</p>
        <div class="names">Амина & Ислам</div>
        <p class="date">24 августа 2026 · 18:00</p>
        <div class="invite-details">
          <article><span>📍</span><h2>Локация</h2><p>Ресторан “Алтын Сарай”, Бишкек</p></article>
          <article><span>🗓️</span><h2>Программа</h2><p>Встреча гостей, церемония, ужин, фото и поздравления.</p></article>
          <article><span>💌</span><h2>RSVP</h2><p>Подтвердите участие до 10 августа.</p></article>
        </div>
        <div class="hero-actions center">
          <a class="button" href={`${base}brief/`}>Заказать такой сайт</a>
          <a class="button secondary" href={base}>Другие шаблоны</a>
        </div>
      </section>
    )}
  </main>
</BaseLayout>
