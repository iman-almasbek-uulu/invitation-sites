---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { midnightOrbitInvitation as invitation } from '../../data/templates/midnight-orbit';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const heroBackground = `${base}assets/templates/midnight-orbit/hero-background.png`;
---

<BaseLayout title="Midnight Orbit — свадебное приглашение" description="Первый экран свадебного invitation template Midnight Orbit.">
  <main class="midnight-orbit">
    <section class="hero" aria-labelledby="midnight-orbit-title">
      <img class="hero-art" src={heroBackground} alt="" aria-hidden="true" loading="eager" />
      <div class="hero-vignette" aria-hidden="true"></div>

      <div class="hero-copy">
        <p class="eyebrow">{invitation.eventLabel}</p>
        <h1 id="midnight-orbit-title">
          <span>{invitation.brideName}</span>
          <span class="couple-line"><i aria-hidden="true">&amp;</i> {invitation.groomName}</span>
        </h1>
        <span class="divider" aria-hidden="true"></span>
        <p class="date"><time datetime="2026-09-20">{invitation.dateLabel}</time><span aria-hidden="true"> · </span>{invitation.cityLabel}</p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  :global(html), :global(body) { min-height: 100%; margin: 0; background: #030914; }
  .midnight-orbit { min-height: 100svh; max-width: 430px; margin: 0 auto; overflow: hidden; background: #030914; box-shadow: 0 0 56px rgba(0, 0, 0, .58); }
  .hero { position: relative; width: 100%; min-height: 100svh; aspect-ratio: 9 / 16; overflow: hidden; isolation: isolate; color: #f6f3ee; background: #050b16; }
  .hero-art { position: absolute; z-index: -2; inset: 0; width: 100%; height: 100%; object-fit: fill; user-select: none; pointer-events: none; }
  .hero-vignette { position: absolute; z-index: -1; inset: 0; pointer-events: none; background: linear-gradient(180deg, rgba(2, 7, 15, .13), transparent 24%, transparent 74%, rgba(2, 7, 15, .26)); }
  .hero-copy { position: absolute; z-index: 1; top: 28.7%; left: 7%; right: 7%; display: grid; justify-items: center; text-align: center; text-shadow: 0 2px 14px rgba(3, 8, 18, .66); }
  .eyebrow { margin: 0 0 clamp(12px, 3.8vw, 17px); color: rgba(245, 244, 241, .9); font-family: Inter, sans-serif; font-size: clamp(8px, 2.05vw, 10px); font-weight: 500; letter-spacing: .22em; line-height: 1.2; text-transform: uppercase; }
  h1 { display: grid; gap: clamp(0px, .55vw, 3px); margin: 0; color: #f8f6f0; font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(44px, 13.6vw, 60px); font-weight: 400; letter-spacing: -.048em; line-height: .82; }
  .couple-line { white-space: nowrap; }
  h1 i { display: inline-block; margin-right: .025em; color: #c5a85e; font-size: .86em; font-style: normal; font-weight: 400; }
  .divider { width: clamp(76px, 23vw, 102px); height: 1px; margin: clamp(22px, 6vw, 27px) 0 clamp(14px, 3.5vw, 17px); background: linear-gradient(90deg, transparent, #ddc37b 12%, #d5b56a 88%, transparent); box-shadow: 0 0 10px rgba(222, 190, 111, .28); }
  .date { margin: 0; color: rgba(245, 243, 235, .92); font-family: Inter, sans-serif; font-size: clamp(7px, 1.8vw, 9px); font-weight: 500; letter-spacing: .18em; line-height: 1.45; text-transform: uppercase; }
  @media (max-width: 319px) { .hero-copy { top: 27.5%; left: 4%; right: 4%; } h1 { font-size: clamp(38px, 13.2vw, 44px); } .date { letter-spacing: .13em; } }
  @media (min-width: 431px) { .midnight-orbit { min-height: 100vh; } .hero { min-height: 764px; max-height: 100svh; } }
  @media (prefers-reduced-motion: reduce) { *, *::before, *::after { scroll-behavior: auto !important; } }
</style>
