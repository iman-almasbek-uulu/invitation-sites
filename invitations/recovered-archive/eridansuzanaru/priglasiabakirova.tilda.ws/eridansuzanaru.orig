<!-- Countdown Timer --> <link href="https://fonts.googleapis.com/css2?family=Forum&display=swap" rel="stylesheet"> <div id="countdown" style="
display: flex;
gap: 14px;
justify-content: center;
align-items: center;
font-family: 'PF Monumenta Pro', serif;
color: #5F0000;
background: transparent;
font-size: 18px;
font-weight: 400;
text-align: center;
"> <div style="display: flex; flex-direction: column; align-items: center;"> <span id="days" style="
font-size: 26px;
font-weight: 400;
width: 60px;
height: 60px;
border: 1px solid #5F0000;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
">00</span>Дней
</div> <div style="display: flex; flex-direction: column; align-items: center;"> <span id="hours" style="
font-size: 26px;
font-weight: 400;
width: 60px;
height: 60px;
border: 1px solid #5F0000;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
">00</span>Часов
</div> <div style="display: flex; flex-direction: column; align-items: center;"> <span id="minutes" style="
font-size: 26px;
font-weight: 400;
width: 60px;
height: 60px;
border: 1px solid #5F0000;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
">00</span>Минут
</div> <div style="display: flex; flex-direction: column; align-items: center;"> <span id="seconds" style="
font-size: 26px;
font-weight: 400;
width: 60px;
height: 60px;
border: 1px solid #5F0000;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
">00</span>Секунд
</div> </div> <script>(function(){const targetDate=new Date("June 6, 2026 00:00:00").getTime();function updateCountdown() {const now=new Date().getTime();const diff=targetDate - now;if(diff<0) return;const days=Math.floor(diff/(1000*60*60*24));const hours=Math.floor((diff%(1000*60*60*24))/(1000*60*60));const minutes=Math.floor((diff%(1000*60*60))/(1000*60));const seconds=Math.floor((diff%(1000*60))/1000);document.getElementById("days").textContent=days;document.getElementById("hours").textContent=hours;document.getElementById("minutes").textContent=minutes;document.getElementById("seconds").textContent=seconds;}
updateCountdown();setInterval(updateCountdown,1000);})();</script> </div> </div> <div class='t396__elem tn-elem tn-elem__21341601831771276458191 t-animate' data-elem-id='1771276458191' data-elem-type='image' data-field-top-value="20" data-field-left-value="172" data-field-height-value="267" data-field-width-value="200" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="px" data-field-widthunits-value="px" data-animate-style="fadeinup" data-animate-duration="1" data-animate-distance="100" data-animate-mobile="y" data-field-filewidth-value="360" data-field-fileheight-value="480" data-field-heightmode-value="hug" data-field-top-res-320-value="860" data-field-left-res-320-value="220" data-field-height-res-320-value="75" data-field-width-res-320-value="56" data-animate-duration-res-320="6" data-animate-delay-res-320="0.2" data-animate-distance-res-320="300" data-field-height-res-480-value="267" data-field-height-res-640-value="267"> <a class='tn-atom' href="https://2gis.kg/bishkek/geo/70030076682612211/72.212630,42.522665"> <img class='tn-atom__img t-img' data-original='https://static.tildacdn.one/tild3533-6263-4032-b630-303166323837/___22.svg'
