:3},{"url":"https://law.2gis.kg/agents-giveaway-rules/","text":"Правила проведения Акции в социальных сетях","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/giveaway-rules/","text":"Правила проведения Акции по добавлению Контента","subnav":[{"url":"https://law.2gis.kg/giveaway-rules/red01122020/","text":"Правила проведения Акции по добавлению Контента (утратили силу 04.10.2021г.)","subnav":[],"mods":{},"level":4}],"mods":{},"level":3},{"url":"https://law.2gis.kg/counting-clicks/","text":"Правила учета Рекламных показов","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/privacy-partner/","text":"Политика конфиденциальности Партнёра 2ГИС","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/partner-agreement/","text":"Соглашение с партнёром 2ГИС","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/partners-list/","text":"Перечень Партнёров 2ГИС","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/microsite/","text":"Соглашение об использовании Микросайта и требования к контенту для Микросайта ","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/copyright/","text":"Информация о Правообладателях","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/promo-add-friends/","text":"Правила проведения Акций по добавлению друзей ","subnav":[],"mods":{},"level":3}],"mods":{"active":false,"expand":true,"expanded":true},"level":2}]}}],"initedModules":[{"elements":{"link":{},"subnavLink":{}},"slot":{"templates":{},"modules":{},"utils":{},"config":{"mainModule":"page","projectName":"infoportal","city.cookieName":"project","mapsApi.libURL":"https://maps.api.2gis.ru/2.0/loader.js?pkg=full","static.prefix":"https://hstatic.2gis.com/","schema":"https","crmEndpoint":"https://info.2gis.ru/moscow/advtilda","infoApi.host":"ayahuasca.2gis.com","monitor.url":"/novosibirsk/monitor","server.listenArgs":[3000],"server.instanceCount":1,"server.useCluster":true,"WebApi.catalogUrl":"https://catalog.api.2gis.ru/2.0/","WebApi.key":"rudxfw6016","suggestUrl":"https://catalog.api.2gis.ru/suggest","logger.app":{"filename":"./logs/app.log","json":false,"timestamp":true},"logger.leaks":{"file":{"filename":"./logs/leaks.log","json":false,"timestamp":true}},"logger.graylog":{"graylogHost":"logserver.test","graylogPort":12201,"level":"warn"},"logger.crash":{"emails":[{"email":"al.kolpakov@2gis.ru"},{"email":"d.donov@2gis.ru"}]},"addFirmHref":"https://reklama.2gis.ru/%1/add-info/?utm_source=partner_network&utm_medium=add_info&utm_campaign=%2","feedbackApi.url":"https://feedback.api.2gis.ru/","feedback.rulesUrl":"https://law.2gis.ru/rules/","feedback.editPhotoUrl":"https://2gis.ru/$photoId","feedback.advertismentHref":"https://reklama.2gis.ru/%2/partner_network/feedback?calculate_for=%1&utm_source=partner_network&utm_medium=ad_link&utm_campaign=feedback","log_channels":["debug","warn"],"projectListTTL":600000,"storeLink.android":"https://play.google.com/store/apps/details?id=ru.dublgis.dgismobile&utm_source=2gisru&utm_medium=link&utm_campaign=android","storeLink.ios":"http://itunes.apple.com/ru/app/2gis/id481627348?mt=8","storeLink.windowsphone":"http://www.windowsphone.com/ru-ru/store/app/2gis/4c2d3b4e-c1f1-439b-bf16-f8b0d829fe87","storeLink.blackberry":"http://appworld.blackberry.com/webstore/content/39967127/","debug":true,"debugRequests":false,"cityselectorJsPath":"/vendor/cityselector.js","photorJsPath":"/vendor/photor.min.js","barrelJsPath":"/vendor/jqbarrel.js","scrollToJsPath":"/vendor/jquery.scrollTo.min.js","colorBoxJsPath":"/vendor/jquery.colorbox.min.js","analyticsJsPath":"/vendor/downloadPc.js","baronJsPath":"/vendor/baron.min.js","placeholderJsPath":"/vendor/placeholder.min.js","momentJsPath":"/vendor/moment.js","momentRuJsPath":"/vendor/moment_ru.js","momentCzJsPath":"/vendor/moment_cz.js","jqueryMask":"/vendor/jquery-masked.min.js","jqueryAppear":"/vendor/jquery-appear.js","suggest.defaultCountCities":2,"suggest.defaultCountFirms":6,"suggest.defaultCountGeo":2,"suggest.defaultCountRoutes":1,"suggest.defaultCountStation":1,"suggest.countForSearchCity":3,"flags.cookieName":"flags","flags.cookieDomain":".2gis.ru","flags.list.rateUsAlreadyShow":"rateUsAlreadyShow"},"isInited":true,"isEnableShowTrack":true,"isServer":true,"isClient":false,"isGrym":false},"type":"nav"}]},{"type":["main"],"modules":[{"type":"usercontent","data":{"mods":{"rel":"law"},"title":"Политика конфиденциальности","content":"<p><a href=\"https://law.2gis.kg/privacy/cookie\">Политика использования файлов cookie ООО &ldquo;ДубльГИС&rdquo;</a></p>\r\n<p>Настоящая Политика конфиденциальности определяет порядок обработки и&nbsp;защиты информации о&nbsp;Пользователях, включая персональные данные Пользователей, которую Общество с&nbsp;ограниченной ответственностью &ldquo;ДубльГИС&rdquo; может получить во&nbsp;время регистрации&nbsp;/ авторизации и/или использования Пользователями любого из&nbsp;программных продуктов и/или Cервисов Администрации (далее совместно именуются &ldquo;<strong>Сервисы 2ГИС</strong>&rdquo;).</p>\r\n<p>Перед использованием Сервисов 2ГИС, Вам необходимо обязательно ознакомиться с&nbsp;условиями настоящей Политики.</p>\r\n<p>1. Общие положения</p>\r\n<p>1.1. В&nbsp;настоящей Политике используются следующие термины и&nbsp;определения:</p>\r\n<p><strong>Администрация или 2ГИС</strong>&nbsp;&mdash; Общество с&nbsp;ограниченной ответственностью &ldquo;ДубльГИС&rdquo;, ОГРН 1045401929847, место нахождения: 630048, Российская Федерация, г. Новосибирск, пл. имени Карла Маркса, д.7, 13&nbsp;этаж.</p>\r\n<p><strong>Закон №&nbsp;152-ФЗ</strong>&nbsp;&mdash; Федеральный закон Российской Федерации от&nbsp;27.07.2006&nbsp;N 152-ФЗ &ldquo;О&nbsp;персональных данных&rdquo;.</p>\r\n<p><strong>Закон №&nbsp;149-ФЗ</strong>&nbsp;&mdash; Федеральный закон Российской Федерации от&nbsp;27.07.2006&nbsp;N 149-ФЗ &ldquo;Об&nbsp;информации, информационных технологиях и&nbsp;о&nbsp;защите информации&rdquo;.</p>\r\n<p><strong>Информация</strong>&nbsp;&mdash; информация о&nbsp;Пользователях, включая персональные данные Пользователей.</p>\r\n<p><strong>Персональные данные</strong>&nbsp;&mdash; любая информация, относящаяся к&nbsp;прямо или косвенно определенному (конкретному) Пользователю (субъекту персональных данных).</p>\r\n<p><strong>Пользователь</strong>&nbsp;&mdash; физическое лицо, действующее в своем или чужом интересе (от имени и в интересах представляемого им Клиента). \r\nС 14 лет Пользователь вправе самостоятельно осуществлять регистрацию в Сервисах 2ГИС, если это требуется для использования ряда функций, и пользоваться последними в пределах правоспособности, установленной законодательством.</p>\r\n<p><strong>Клиент</strong>&nbsp;&mdash; юридическое лицо и/или индивидуальный предприниматель, информация о&nbsp;котором размещена в&nbsp;Справочнике организаций 2ГИС.</p>\r\n<p><strong>Сервисы 2ГИС</strong>&nbsp;&mdash; Программные продукты 2ГИС и&nbsp;Онлайн-сервисы 2ГИC, как они определены в&nbsp;Лицензионных соглашениях, размещенных в&nbsp;сети Интернет по&nbsp;адресам <a href=\"https://law.2gis.ru/licensing-agreement/\">https://law.2gis.ru/licensing-agreement/</a>, <a href=\"https://law.2gis.kz/licensing-agreement/\">https://law.2gis.kz/licensing-agreement/</a>, <a href=\"https://law.2gis.kg/licensing-agreement/\">https://law.2gis.kg/licensing-agreement/</a>, <a href=\"https://law.2gis.uz/licensing-agreement/\">https://law.2gis.uz/licensing-agreement/</a>, <a href=\"https://law.2gis.az/licensing-agreement/\">https://law.2gis.az/licensing-agreement/</a>.</p>\r\n<p><strong>Cookies&nbsp;&mdash; </strong>данные из&nbsp;файлов &ldquo;cookie&rdquo;, как они определены в&nbsp;Политике использования файлов cookie 2ГИС.<strong> </strong></p>\r\n<p><strong>Нотификаторы</strong>&nbsp;&mdash; информационные и/или рекламные электронные сообщения, push-уведомления.</p>\r\n<p><strong>Политика</strong>&nbsp;&mdash; настоящая Политика конфиденциальности.</p>\r\n<p>В&nbsp;Политике могут быть использованы термины и&nbsp;определения, не&nbsp;указанные в&nbsp;настоящем пункте. В&nbsp;этом случае толкование такого термина производится в&nbsp;соответствии с&nbsp;текстом Политики. В&nbsp;случае отсутствия однозначного толкования термина или определения в&nbsp;тексте Политики, следует руководствоваться его толкованием, определенным в&nbsp;Лицензионном соглашении, доступном в&nbsp;сети Интернет по&nbsp;адресам, указанным выше.</p>\r\n<p>1.2. Пользуясь Сервисами 2ГИС, Вы&nbsp;соглашаетесь с&nbsp;тем, что:</p>\r\n<ul>\r\n<li>Вы&nbsp;ознакомились с&nbsp;условиями настоящей Политики в&nbsp;полном объеме до&nbsp;начала использования Сервисов 2ГИС.</li>\r\n<li>Обработка Информации необходима для выполнения договорных обязательств Администрации перед Вами в&nbsp;рамках Лицензионных соглашений (<a href=\"https://law.2gis.kg/licensing-agreement/\">https://law.2gis.kg/licensing-agreement/</a>, <a href=\"https://law.2gis.ru/licensing-agreement/\">https://law.2gis.ru/licensing-agreement/</a>, <a href=\"https://law.2gis.kz/licensing-agreement/\">https://law.2gis.kz/licensing-agreement/</a>, <a href=\"https://law.2gis.uz/licensing-agreement/\">https://law.2gis.uz/licensing-agreement/</a>, <a href=\"https://law.2gis.az/licensing-agreement/\">https://law.2gis.az/licensing-agreement/</a>), включая обеспечение работы Сервисов 2ГИС. Начало использования Вами Сервисов 2ГИС в&nbsp;любой форме означает, что&nbsp;Вы принимаете все условия настоящей Политики в&nbsp;полном объеме без каких-либо изъятий и&nbsp;ограничений с&nbsp;Вашей стороны.</li>\r\n<li>Политика (в&nbsp;том числе любая из&nbsp;ее&nbsp;частей) может быть изменена Администрацией без специального уведомления Вас об&nbsp;этом и&nbsp;без выплаты какой-либо компенсации в&nbsp;связи с&nbsp;этим. Новая редакция Политики вступает в&nbsp;силу с&nbsp;момента ее&nbsp;размещения на&nbsp;сайте Администрации, размещенном в&nbsp;домене по&nbsp;адресу 2gis.kg, если иное не&nbsp;предусмотрено новой редакцией Политики.</li>\r\n</ul>\r\n<p>1.3. Если Вы&nbsp;не&nbsp;согласны с&nbsp;условиями настоящей Политики, не&nbsp;начинайте или незамедлительно прекратите любое использование Сервисов 2ГИС.</p>\r\n<p>1.4. Принимая условия настоящей Политики, Вы&nbsp;выражаете свое согласие на&nbsp;обработку Администрацией Информации в&nbsp;целях, предусмотренных настоящей Политикой, а&nbsp;также на&nbsp;передачу Информации третьим лицам в&nbsp;случаях, перечисленных в&nbsp;настоящей Политике.</p>\r\n<p>1.5. Используя Сервисы 2ГИС с&nbsp;помощью веб-браузера, который принимает данные из&nbsp;cookies, Вы&nbsp;соглашаетесь со&nbsp;сбором и&nbsp;обработкой данных из&nbsp;cookies Администрацией в&nbsp;целях, предусмотренных настоящей Политикой, и&nbsp;передачу Администрацией данные из&nbsp;cookies третьим лицам в&nbsp;случаях, перечисленных в&nbsp;Политике использования файлов cookie 2ГИС.</p>\r\n<p>1.6. Отключение и/или блокировка Вами опции веб-браузера по&nbsp;приему данных из&nbsp;cookies означает запрет на&nbsp;сбор и&nbsp;обработку Администрацией данных из&nbsp;cookies.</p>\r\n<p>1.7. При обработке Информации Администрация руководствуется Законом №&nbsp;152-ФЗ, Законом №&nbsp;149-ФЗ и&nbsp;иным применимым законодательством.</p>\r\n<p>2. Состав Информации, которую собирает и&nbsp;обрабатывает Администрация</p>\r\n<p>2.1. Администрация собирает и&nbsp;обрабатывает следующие виды Информации:</p>\r\n<p>2.1.1. Персональные данные, размещаемые Пользователями о&nbsp;себе самостоятельно при регистрации&nbsp;/ использовании Сервисов 2ГИС, в&nbsp;т.ч. при оформлении заявки в&nbsp;карточке Клиента на&nbsp;оказание услуг&nbsp;/ выполнение работ&nbsp;/ приобретение товара. К&nbsp;персональным данным могут относиться, в&nbsp;частности, имя, отчество, фамилия, дата рождения, изображение, паспортные данные, номер телефона и/или адрес электронной почты Пользователя.</p>\r\n<p>2.1.2. Персональные данные, размещаемые Пользователями о&nbsp;себе самостоятельно при регистрации в&nbsp;Личном кабинете. К&nbsp;персональным данным могут относиться, в&nbsp;частности, имя, фамилия, отчество, номер телефона и/или адрес электронной почты Пользователя.</p>\r\n<p>2.1.3. Персональные данные, размещаемые Пользователями в&nbsp;процессе использования Сервисов 2ГИС, в&nbsp;том числе Личного кабинета (к&nbsp;примеру, имя, фамилия, отчество, дата рождения, паспортные данные, адрес регистрации, номер телефона, адрес электронной почты, платежные данные Пользователя).</p>\r\n<p>2.1.4. Персональные данные, размещаемые Пользователями в&nbsp;формах обратной связи, в&nbsp;том числе название Клиента, должность.</p>\r\n<p>2.1.5. Иные персональные данные, доступ к&nbsp;которым Пользователь предоставляет Администрации через веб-сайты или сервисы третьих лиц, в&nbsp;том числе при авторизации Пользователя в&nbsp;Сервисах 2ГИС.</p>\r\n<p>2.1.6. Данные, не&nbsp;являющиеся персональными данными, необходимые для функционирования Сервисов 2ГИС.</p>\r\n<p>К&nbsp;ним относятся данные, автоматически передаваемые Сервисам 2ГИС в&nbsp;процессе их&nbsp;использования с&nbsp;помощью установленного на&nbsp;устройстве Пользователя программного обеспечения, в&nbsp;т.ч. IP-адрес, индивидуальный сетевой номер устройства (MAC-адрес, ID&nbsp;устройства), электронный серийный номер (IMEI, MEID), рекламные идентификаторы (GAID, IDFA, OAID и&nbsp;иные, соотносящиеся с&nbsp;операционной системой Пользователя), данные из&nbsp;cookies, информация о&nbsp;браузере, операционной системе, времени доступа, поисковых запросах, сведения о&nbsp;местоположении и&nbsp;перемещении устройства Пользователя.</p>\r\n<p>Если на&nbsp;основании этих данных Администрация может идентифицировать субъекта, данные относятся к&nbsp;персональным данным.</p>\r\n<p>2.1.7. Данные, дополнительно предоставляемые Пользователями по&nbsp;запросу Администрации для выполнения обязательств Администрации перед Пользователями в&nbsp;отношении использования Сервисов 2ГИС.</p>\r\n<p>2.1.8. Иная информация о&nbsp;Пользователях, сбор и/или обработка которой установлены соглашениями об&nbsp;использовании отдельных Сервисов 2ГИС и/или правилами оказания услуг с&nbsp;использованием отдельных Сервисов 2ГИС.</p>\r\n<p>2.2. Обязательная для использования программных продуктов и/или предоставления Сервисов 2ГИС или отдельных их&nbsp;функциональных возможностей информация помечена специальным образом. Иная информация предоставляется Пользователем на&nbsp;его усмотрение.</p>\r\n<p>2.3. Запрещается предоставление Пользователем персональных данных третьих лиц без полученного от&nbsp;третьих лиц разрешения на&nbsp;такую передачу, за&nbsp;исключением персональных данных третьих лиц, которые были получены Пользователем из&nbsp;общедоступных источников информации.</p>\r\n<p>2.4. По&nbsp;общему правилу Администрация не&nbsp;проверяет достоверность предоставляемых Пользователями персональных данных. В&nbsp;случаях, предусмотренных соглашениями об&nbsp;использовании отдельных Сервисов 2ГИС, Пользователь обязан предоставить подтверждение достоверности предоставленных им&nbsp;своих персональных данных.</p>\r\n<p>2.5. Администрация не&nbsp;обрабатывает персональные данные Пользователей, не&nbsp;прошедших регистрацию, авторизацию и/или не&nbsp;разместивших персональные данные в&nbsp;процессе использования Сервисов 2ГИС, в&nbsp;т.ч.&nbsp;в&nbsp;формах обратной связи.</p>\r\n<p>2.6. Администрация не&nbsp;контролирует и&nbsp;не&nbsp;несет ответственность за&nbsp;обработку Информации сайтами третьих лиц, на&nbsp;которые Пользователь может перейти по&nbsp;ссылкам, доступным в&nbsp;Сервисах 2ГИС.</p>\r\n<p>3. Цели сбора и&nbsp;обработки Информации</p>\r\n<p>3.1. Администрация осуществляет сбор и&nbsp;обработку только той Информации, которая необходима для выполнения обязательств Администрации по&nbsp;предоставлению Сервисов 2ГИС.</p>\r\n<p>3.2. Администрация может использовать Информацию для:</p>\r\n<p>3.2.1. идентификации стороны договора между Пользователем и&nbsp;Администрацией;</p>\r\n<p>3.2.2. аутентификации Пользователя при регистрации в&nbsp;Личном кабинете путем совершения звонка на&nbsp;номер телефона Пользователя с&nbsp;целью сообщения проверочного кода;</p>\r\n<p>3.2.3. предоставления Пользователям услуг с&nbsp;использованием Сервисов 2ГИС и&nbsp;дальнейшего совершенствования Сервисов 2ГИС, разработки новых сервисов и&nbsp;услуг;</p>\r\n<p>3.2.4. реагирования на&nbsp;запросы Пользователей в&nbsp;службу поддержки, информирования Пользователей о&nbsp;возможностях Сервисов 2ГИС, направления запросов, касающихся использования Сервисов 2ГИС;</p>\r\n<p>3.2.5. маркетинга;</p>\r\n<p>3.2.6. выполнения статистических и&nbsp;иных исследований, на&nbsp;основе обезличенных данных;</p>\r\n<p>3.2.7. предоставления данных из&nbsp;cookies третьим лицам, с&nbsp;которыми у&nbsp;Администрации заключены договоры, для демонстрации третьими лицами Пользователям таргетированных рекламных и&nbsp;информационных материалов в&nbsp;сети Интернет и/или для целей оказания третьими лицами иных услуг Пользователям в&nbsp;установленном законом порядке;</p>\r\n<p>3.2.8. формирования профиля Пользователя на&nbsp;основании полученной Информации и&nbsp;предоставления соответствующей Информации партнерам 2ГИС (владельцы сайтов и&nbsp;приложений, рекламные сети, компании в&nbsp;сфере интернет-бизнеса и/или финансов) для создания рекламных продуктов для отдельных групп пользователей и/или отображения рекламы на&nbsp;сайтах, в&nbsp;программах, продуктах или сервисах партнеров;</p>\r\n<p>3.2.9. коммуникации с&nbsp;Пользователем в&nbsp;целях налаживания партнерских отношений, ведения переговоров по&nbsp;согласованию условий договоров с&nbsp;Пользователем и/или Клиентом, в&nbsp;чьих интересах он&nbsp;действует, заключения и&nbsp;исполнения таких договоров;</p>\r\n<p>3.2.10. добавления и/или актуализации информации в&nbsp;Справочнике организаций 2ГИС в&nbsp;отношении Клиента, в&nbsp;интересах которого действует Пользователь, устранения неточностей Сервисов 2ГИС, включая коммуникации с&nbsp;Пользователем в&nbsp;указанных целях.</p>\r\n<p>3.3. Вы&nbsp;соглашаетесь получать от&nbsp;Администрации:</p>\r\n<p>3.3.1. на&nbsp;указанный в&nbsp;Вашем аккаунте электронный адрес и&nbsp;на&nbsp;мобильное устройство, на&nbsp;котором осуществляется просмотр Сервисов 2ГИС, нотификаторы, о&nbsp;важных событиях, происходящих в&nbsp;рамках Сервисов 2ГИС или в&nbsp;связи с&nbsp;ними, а&nbsp;также в&nbsp;случае отдельной подписки&nbsp;&mdash; получать на&nbsp;указанный при подписке адрес электронной почты информационные и/или рекламные сообщения о&nbsp;новостях 2ГИС, анонсы мероприятий для разработчиков и&nbsp;материалы с&nbsp;таких мероприятий, рассылка о&nbsp;вышедших статьях (нерекламные интервью) о&nbsp;компаниях разных сфер бизнеса;</p>\r\n<p>3.3.2. на&nbsp;указанный в&nbsp;Вашем Личном кабинете номер телефона, в&nbsp;том числе в&nbsp;мессенджерах, и/или по&nbsp;адресу электронной почты, нотификаторы, в&nbsp;том числе уведомления об&nbsp;изменениях в&nbsp;функционале Личного кабинета 2ГИС, информирование о&nbsp;новинках Сервисов 2ГИС и&nbsp;услуг Администрации (уведомления могут сопровождаться рекламными сообщениями от&nbsp;третьих лиц);</p>\r\n<p>3.4. Пользователь вправе отказаться от&nbsp;получения push-уведомления через предложенные формы обратной связи в&nbsp;мобильной версии Сервисов 2ГИС или самостоятельно отключить возможность получения push-уведомления через настройки мобильных устройств.</p>\r\n<p>3.5. Администрация вправе использовать нотификаторы для информирования Пользователя о&nbsp;возможностях Сервисов 2ГИС и/или об&nbsp;изменении информационных ресурсов.</p>\r\n<p>3.6. Для использования персональные данных Пользователя в&nbsp;целях, не&nbsp;предусмотренных настоящей Политикой, Администрация запрашивает согласие Пользователя на&nbsp;такое использование.</p>\r\n<p>4. Обработка Информации</p>\r\n<p>4.1. Информация обрабатывается в&nbsp;соответствии с&nbsp;применимым законодательством.</p>\r\n<p>4.2. Информация не&nbsp;передается третьим лицам, за&nbsp;исключением следующих случаев:</p>\r\n<p>4.2.1. Пользователь выразил согласие на&nbsp;такую передачу;</p>\r\n<p>4.2.2. Передача аффилированному лицу Администрации&nbsp;&mdash; ООО &ldquo;ДГ-Софт&rdquo; и/или иным аффилированным лицам Администрации для обеспечения функционирования Сервисов 2ГИС и/или отдельных функциональных возможностей Сервисов 2ГИС, реализации партнерских и&nbsp;иных программ Сервисов 2ГИС, реагирования на&nbsp;запросы в&nbsp;службу поддержки;</p>\r\n<p>4.2.3. Передача <a href=\"https://law.2gis.kg/partners-list\">партнерам 2ГИС</a> данных авторизовавшихся в&nbsp;аккаунте Пользователей в&nbsp;целях взаимодействия при добавлении и/или актуализации последним информации в&nbsp;Сервисе 2ГИС на&nbsp;локации партнера 2ГИС;</p>\r\n<p>4.2.4. Передача предусмотрена применимым правом.</p>\r\n<p>4.2.5. Передача осуществляется в&nbsp;целях обеспечения возможности защиты прав и&nbsp;законных интересов Администрации и/или третьих лиц в&nbsp;случаях, когда Пользователь нарушает условия соглашений об&nbsp;использовании отдельных Сервисов 2ГИС.</p>\r\n<p>4.2.6. Передача обезличенного идентификатора (IDFA (IDentifier For Advertisers) или GAID (Google Advertiser&nbsp;ID)) устройства Пользователя маркетинговым партнерам 2ГИС на&nbsp;территории&nbsp;РФ для создания рекламных продуктов для отдельных групп пользователей или исключения отдельных групп пользователей из&nbsp;списка получателей специальных рекламных предложений.</p>\r\n<p>Пользователь может в&nbsp;любой момент отключить дальнейшие сбор, хранение и&nbsp;передачу идентификатора устройства, изменив настройки мобильного устройства.</p>\r\n<p>4.2.7. Передача рекламного идентификатора (IDFA (IDentifier For Advertisers) или GAID (Google Advertiser&nbsp;ID)) устройства Пользователя компании AppsFlyer Лтд, зарегистрированной в&nbsp;соответствии с&nbsp;законодательством государства Израиль и&nbsp;состоящей на&nbsp;учете в&nbsp;налоговом органе Российской Федерации (ИНН: 9909512348) для анализа и&nbsp;систематизации данных о&nbsp;действиях пользователей в&nbsp;Продукте.</p>\r\n<p>Пользователь может в&nbsp;любой момент отключить дальнейшие сбор, хранение и&nbsp;передачу идентификатора устройства, изменив настройки мобильного устройства.</p>\r\n<p>С&nbsp;политикой конфиденциальности AppsFlyer Лтд Пользователь может ознакомиться по&nbsp;адресу: <a href=\"https://www.appsflyer.com/gdpr/dpa.pdf\">https://www.appsflyer.com/gdpr/dpa.pdf</a>.</p>\r\n<p>4.2.8. Передача Информации, формирующей профиль Пользователя, партнерам 2ГИС (владельцы сайтов и&nbsp;приложений, рекламные сети, компании в&nbsp;сфере интернет-бизнеса и/или финансов) для создания рекламных продуктов для отдельных групп пользователей и/или отображения рекламы на&nbsp;сайтах, в&nbsp;программах, продуктах или сервисах партнеров.</p>\r\n<p>4.2.9. Передача персональных данных, доступ к&nbsp;которым Пользователь предоставляет Администрации через интернет-сервис поддержки клиентов (онлайн-чат) &ldquo;Чатра&rdquo;, ООО &ldquo;Дарвин&rdquo; (ИНН 7813243387) в&nbsp;целях хранения персональных данных на&nbsp;его серверах с&nbsp;использованием необходимых программно-аппаратных средств защиты. С&nbsp;документацией ООО &ldquo;Дарвин&rdquo; можно ознакомиться по&nbsp;адресу: <a href=\"https://chatra.com/ru/offer/\">https://chatra.com/ru/offer/</a>.</p>\r\n<p>4.2.10. Выполнения третьими лицами заявки Пользователя, оформленной в&nbsp;карточке Клиента, для оказания услуг, выполнения работ, продажи товаров Пользователю. При оформлении заявки в&nbsp;карточке Клиента на&nbsp;оказание услуг&nbsp;/ выполнение работ&nbsp;/ приобретение товара, данные, оставленные Пользователем, будут переданы Клиенту, товар и/или услуга&nbsp;/ работа которого вызвали интерес Пользователя.</p>\r\n<p>4.2.11. Персональные данные Пользователя в&nbsp;составе имя, фамилия, номер телефона, адрес электронной почты становятся доступными всем Пользователям Личного кабинета.</p>\r\n<p>4.2.12. Передача по&nbsp;запросу государственных или иных органов в&nbsp;целях исполнения требований законодательства.</p>\r\n<p>4.3. Трансграничная передача персональных данных на&nbsp;территории иностранных государств, не&nbsp;обеспечивающих адекватной защиты прав субъектов персональных данных, осуществляется только при наличии согласия субъекта и/или в&nbsp;целях исполнения договора и/или для выполнения требований законодательства в&nbsp;случаях, предусмотренных применимым законодательством.</p>\r\n<p>4.4. Перечень третьих лиц и&nbsp;передаваемых им&nbsp;персональных данных может быть запрошен у&nbsp;Ответственного за&nbsp;организацию обработки и&nbsp;защиты персональных данных Администрации.</p>\r\n<p>4.5. Пользователь настоящим уведомлен и&nbsp;соглашается, что Администрация может использовать и&nbsp;передавать персональные данные третьих лиц, которые предоставляются Пользователем при использовании Сервисов 2ГИС, для реализации отдельных функций Сервисов 2ГИС, при условии, что Пользователь гарантирует Администрации наличие согласия третьих лиц на&nbsp;такое использование и&nbsp;передачу.</p>\r\n<p>4.6. Пользователь настоящим уведомлен и&nbsp;соглашается, что при использовании Сервисов 2ГИС Администрация может получать данные об&nbsp;установленных на&nbsp;мобильном устройстве Пользователя приложениях, и&nbsp;использовать их&nbsp;для реализации отдельных функций Сервисов 2ГИС.</p>\r\n<p>4.7. Пользователь настоящим уведомлен и&nbsp;соглашается, что Администрация может получать статистические обезличенные (без привязки к&nbsp;Пользователю) данные о&nbsp;действиях Пользователя при использовании Сервисов 2ГИС и&nbsp;об&nbsp;установленных Пользователем настройках Сервисов 2ГИС.</p>\r\n<p>4.8. Администрация осуществляет сбор, запись, систематизацию, накопление, хранение, уточнение (обновление, изменение), извлечение, использование, передачу (распространение, предоставление, доступ), обезличивание, блокирование, удаление, уничтожение персональных данных граждан Кыргызской Республики с&nbsp;использованием баз данных, находящихся на&nbsp;территории Российской Федерации. Персональные данные Пользователей хранятся до&nbsp;достижения целей обработки Персональных данных или до&nbsp;отзыва согласия на&nbsp;обработку персональных данных пользователем. Обработка персональных данных осуществляется как с&nbsp;использованием автоматизированных средств, так и&nbsp;без использования средств автоматизации.</p>\r\n<p>4.9. Персональные данные удаляются Администрацией в&nbsp;соответствии с&nbsp;применимым законодательством.</p>\r\n<p>5. Права Пользователей</p>\r\n<p>5.1. Пользователи вправе:</p>\r\n<p>5.1.1. самостоятельно вносить изменения, дополнения в&nbsp;информацию о&nbsp;себе в&nbsp;аккаунте, Личном кабинете на&nbsp;Сайте Администрации.</p>\r\n<p>5.1.2. удалять Информацию о&nbsp;себе, предоставленную в&nbsp;рамках аккаунта, Личного кабинета на&nbsp;Сайте Администрации. Удаление аккаунта, Личного кабинета, Информации может повлечь невозможность использования некоторых Сервисов 2ГИС.</p>\r\n<p>5.1.3. по&nbsp;запросу получать от&nbsp;Администрации информацию, касающуюся обработки своих персональных данных.</p>\r\n<p>6. Меры по&nbsp;защите Информации</p>\r\n<p>6.1. Администрация принимает все необходимые и&nbsp;достаточные организационные и&nbsp;технические меры для защиты персональных данных Пользователей и&nbsp;третьих лиц от&nbsp;неправомерного или случайного доступа к&nbsp;ним, уничтожения, изменения, блокирования, распространения, а&nbsp;также от&nbsp;иных неправомерных действий с&nbsp;ними. К&nbsp;таким мерам относятся, в&nbsp;частности, внутренняя проверка процессов сбора, хранения и&nbsp;обработки персональных данных и&nbsp;мер безопасности, включая соответствующее шифрование и&nbsp;меры по&nbsp;обеспечению физической безопасности персональных данных для предотвращения неавторизированного доступа к&nbsp;системам, в&nbsp;которых хранятся персональные данные.</p>\r\n<p>7. Заключительные положения</p>\r\n<p>7.1. Настоящая Политика, отношения между Пользователем и&nbsp;Администрацией, возникающие в&nbsp;связи с&nbsp;применением настоящей Политики, а&nbsp;также вопросы, не&nbsp;урегулированные настоящей Политикой, регулируются действующим законодательством Российской Федерации и&nbsp;иным применимым законодательством.</p>\r\n<p>7.2. Все вопросы, касающиеся настоящей Политики, просим направлять в&nbsp;Службу поддержки пользователей 2ГИС (http://help.2gis.ru/feedback/), в&nbsp;Службу поддержки Пользователей Личного кабинета (<a href=\"mailto:feedback@account.2gis.com\">feedback@account.2gis.com</a>) либо по&nbsp;адресу: 630048, Российская Федерация, г. Новосибирск, пл.&nbsp;им. Карла Маркса, д.&nbsp;7, 13&nbsp;этаж.</p>\r\n<p>7.3. В&nbsp;случае выявления факта незаконного использования персональных данных, субъект персональных данных, чьи данные незаконно используются, обязан направить в&nbsp;адрес Администрации письменное заявление об&nbsp;удалении таких персональных данных. В&nbsp;заявлении необходимо указать реквизиты документа, удостоверяющего личность субъекта персональных данных, которые незаконно используются в&nbsp;отзыве без согласия субъекта персональных данных, имя Пользователя, разместившего отзыв. Заявление необходимо направить по&nbsp;адресу: 630048, Российская Федерация, г. Новосибирск, площадь&nbsp;им. Карла Маркса, д.7, 13&nbsp;этаж.</p>\r\n<p>7.4. Действующая редакция настоящей Политики размещена на&nbsp;сайте Администрации и&nbsp;доступна в&nbsp;сети Интернет по&nbsp;адресу: <a href=\"http://law.2gis.kg/privacy/\">http://law.2gis.kg/privacy/</a>.</p>\r\n<p>Редакция от&nbsp;05.08.2024&nbsp;г.</p>\r\n<p>&copy;&nbsp;ООО &ldquo;ДубльГИС&rdquo;, 2024</p>\r\n<p><strong>Купуялуулук саясаты</strong></p>\r\n<p><a href=\"https://law.2gis.kg/privacy/cookie\">&laquo;ДубльГИС&raquo; ЖЧК cookie файлдарын пайдалануу саясаты</a></p>\r\n<p>Ушул Купуялуулук саясаты Колдонуучулар жөнүндө маалыматтарды, Колдонуучулардын жеке берилмелерин кошо иштетүү жана коргоо тартибин аныктайт, аларды &laquo;ДубльГИС&raquo; Жоопкерчилиги чектелген коому каттоо/авторлоштуруу жана&nbsp;/же Администрациянын программалык продуктыларынын жана/же Кызматтарынын (мындан ары биргеликте &laquo;<strong>2ГИС кызматтары</strong>&raquo; деп аталат) каалаганын Колдонуучулар пайдаланган учурунда ала алат. </p>\r\n<p>2ГИС кызматтарын пайдалануудан мурда, Сиз ушул Саясаттын шарттары менен сөзсүз таанышып чыгууңуз зарыл.</p>\r\n<p>1. Жалпы жоболор</p>\r\n<p>1.1. Ушул Саясатта төмөнкү терминдер жана аныктамалар пайдаланылат:</p>\r\n<p><strong>Администрация&nbsp;же 2ГИС</strong> &mdash;\"ДубльГИС\" Жоопкерчилиги чектелген коому, НМКН 1045401929847, орун алган жери: 630048, Россия Федерациясы, Новосибирск ш., Карл Маркс атындагы аянт, 7-үй, 13-кабат.</p>\r\n<p><strong>№&nbsp;152-ФЗ мыйзамы</strong> &mdash; Россия Федерациясынын&nbsp;27.07.2006-жылдын N&nbsp;152-ФЗ &laquo;Жеке берилмелер жөнүндө&raquo; Федералдык мыйзамы </p>\r\n<p><strong>№&nbsp;149-ФЗ мыйзамы</strong> &mdash; Россия Федерациясынын&nbsp;27.07.2006-ж. N&nbsp;149-ФЗ &laquo;Маалымат, маалыматтык технологиялар жана маалыматты коргоо жөнүндө&raquo; Федералдык мыйзамы.</p>\r\n<p><strong>Маалымат&nbsp;</strong>&mdash; Колдонуучунун жеке берилмелерин камтыган Колдонуучулар жөнүндө маалымат.</p>\r\n<p><strong>Жеке берилмелер</strong>&nbsp;&mdash; белгилүү (конкреттүү) Колдонуучуга (жеке берилмелер субъектисине) түз&nbsp;же кыйыр тиешелүү бардык маалыматтар.</p>\r\n<p><strong>Колдонуучу&nbsp;</strong>&mdash; өзүнүн же башка бирөөнүн кызыкчылыгында (өзү өкүлү болгон Кардардын атынан жана кызыкчылыгында) иш алып барган жеке адам.\r\nКолдонуучу 14 жаштан баштап, эгерде бул бир катар функцияларды пайдалануу үчүн талап кылынса, 2ГИС Кызматтарында өз алдынча каттоону жүзөгө ашырууга жана мыйзамда белгиленген укук жөндөмдүүлүгүнүн чегинде акыркыларын пайдаланууга укуктуу.</p>\r\n<p><strong>Кардар</strong>&nbsp;&mdash; 2ГИС Уюмдар маалымдамасында алар жөнүндө маалымат жайгаштырылган юридикалык жак жана/же жеке ишкер.</p>\r\n<p><strong>2ГИС кызматтары</strong> &nbsp;&mdash; <a href=\"https://law.2gis.ru/licensing-agreement/\">https://law.2gis.ru/licensing-agreement/</a>, <a href=\"https://law.2gis.kz/licensing-agreement/\">https://law.2gis.kz/licensing-agreement/</a>, <a href=\"https://law.2gis.kg/licensing-agreement/\">https://law.2gis.kg/licensing-agreement/</a>, <a href=\"https://law.2gis.uz/licensing-agreement/\">https://law.2gis.uz/licensing-agreement/</a>, <a href=\"https://law.2gis.az/licensing-agreement/\">https://law.2gis.az/licensing-agreement/</a> дареги боюнча Интернет тармагында жайгаштырылган Лицензиялык макулдашууларда аныкталгандай 2ГИС Программалык продуктылары жана 2ГИС Онлайн кызматтары. </p>\r\n<p><strong>Cookies&nbsp;</strong>&mdash; 2ГИС cookie файлдарын пайдалануу саясатында аныкталгандай &laquo;cookie&raquo; файлдарынан алынган маалыматтар.</p>\r\n<p><strong>Нотификаторлор</strong>&nbsp;&mdash; маалыматтык жана/же жарнамалык электрондук билдирүүлөр, push-кабарламалар.</p>\r\n<p><strong>Саясат</strong> &mdash; Купуялуулуктун ушул саясаты.</p>\r\n<p>Бул пунктта көрсөтүлбөгөн терминдер жана аныктамалар Саясатта колдонулушу мүмкүн. Бул учурда мындай терминдин чечмелениши Саясаттын текстине ылайык жүргүзүлөт. Саясаттын текстинде терминдин&nbsp;же аныктаманын бирдиктүү чечмелениши жок болгон учурда, жогоруда көрсөтүлгөн даректер боюнча Интернетте жеткиликтүү болгон Лицензиялык келишимде аныкталган чечмелөөнү жетекчиликке алуу керек.</p>\r\n<p>1.2. 2ГИС Кызматтарын колдонуу менен, Сиз төмөнкүлөргө макул болосуз:</p>\r\n<ul>\r\n<li>2ГИС Кызматтарын пайдаланууну баштаганга чейин ушул Саясаттын шарттары менен толук көлөмдө таанышып чыктыңыз.</li>\r\n<li>Маалыматтарды иштетүү Лицензиялык макулдашуулардын (<a href=\"https://law.2gis.kg/licensing-agreement/\">https://law.2gis.kg/licensing-agreement/</a>, <a href=\"https://law.2gis.ru/licensing-agreement/\">https://law.2gis.ru/licensing-agreement/</a>, <a href=\"https://law.2gis.kz/licensing-agreement/\">https://law.2gis.kz/licensing-agreement/</a>, <a href=\"https://law.2gis.uz/licensing-agreement/\">https://law.2gis.uz/licensing-agreement/</a>, <a href=\"https://law.2gis.az/licensing-agreement/\">https://law.2gis.az/licensing-agreement/</a>) алкагында Администрациянын, Сиздин алдыңызда келишимдик милдеттемелерди, 2ГИС Кызматтарынын ишин камсыз кылууну да&nbsp;аткаруу үчүн зарыл. Сиздин, 2ГИС Кызматтарын каалаган формада пайдаланууну баштаганыңызда, Сиз ушул Саясаттын бардык шарттарын толук көлөмдө Сиз тараптан эч&nbsp;кандай алып салууларсыз жана чектөөсүз кабыл аласыз.</li>\r\n<li>Саясат (анын ичинде каалаган анын бөлүктөрү) Администрация тарабынан бул жөнүндө сизге атайын эскертүүсүз жана буга байланыштуу эч&nbsp;кандай компенсация төлөбөстөн өзгөртүлүшү мүмкүн. Саясаттын жаңы редакциясы, эгерде Саясаттын жаңы редакциясында башкача каралбаса, 2gis.kg дарегиндеги Администрациянын веб-сайтына жайгаштырылган учурдан тартып күчүнө кирет.</li>\r\n</ul>\r\n<p>1.3. Эгерде Сиз ушул Саясаттын шарттары менен макул болбосоңуз, бардык 2ГИС Кызматтарын пайдаланууну баштабаңыз&nbsp;же токтотуңуз.</p>\r\n<p>1.4. Бул Саясаттын шарттарын кабыл алуу менен, Сиз бул Саясатта каралган максаттар үчүн Администрация тарабынан Маалыматты иштетүүгө, ошондой эле ушул Саясатта көрсөтүлгөн учурларда Маалыматты үчүнчү жактарга берүүгө макулдугуңузду билдиресиз.</p>\r\n<p>1.5. 2ГИС Кызматтарын cookiesден маалыматтарды кабыл алуучу веб &mdash;браузердин жардамы менен, Сиз бул Саясатта каралган максаттар үчүн Администрация тарабынан cookiesден маалыматтарды чогултууга жана иштетүүгө жана Администрация тарабынан cookiesден алынган маалыматтарды, 2ГИС сookie файлдарын Пайдалануу саясатында көрсөтүлгөн учурларда үчүнчү жактарга берүүгө макулдугуңузду билдиресиз.</p>\r\n<p>1.6. Сиздин сookie файлдарынан маалыматтарды алуу боюнча веб-браузердин тандоосун өчүргөнүңүз жана/же бөгөт койгонуңуз, cookiesден маалыматтарды Администрация тарабынан чогултууга жана иштетүүгө тыюу салууну билдирет.</p>\r\n<p>1.7. Маалыматты иштетүүдө Администрация №&nbsp;152-ФЗ Мыйзамын, 149-ФЗ Мыйзамын жана башка колдонулуп жаткан башка мыйзамдарды жетекчиликке алат.</p>\r\n<p>2. Администрация чогулткан жана иштеткен Маалыматтын курамы</p>\r\n<p>2.1. Администрация Маалыматтын төмөнкү түрлөрүн чогултат жана иштетет: </p>\r\n<p>2.1.1. Колдонуучулар катталганда /2ГИС кызматтарын колдонууда өздөрү жөнүндө, анын ичинде Кардардын карточкасына кызмат көрсөтүүгө /жумушту аткарууга/товарды сатып алууга арызды тариздөөдө өз&nbsp;алдынча жарыялаган жеке берилмелер. Жеке берилмелерге, атап айтканда, аты, атасынын аты, фамилиясы, туулган датасы, сүрөтү, паспорттук берилмелери, телефон номери жана/же Колдонуучунун электрондук почта дареги кириши мүмкүн.</p>\r\n<p>2.1.2. Жеке кабинетте катталууда Колдонуучулар өзүлөрү жөнүндө өз&nbsp;алдынча жарыялаган жеке берилмелер. Жеке берилмелер, атап айтканда, Колдонуучунун аты, фамилиясы, атасынын аты, телефон номери жана&nbsp;/же электрондук почта дарегин камтышы мүмкүн.</p>\r\n<p>2.1.3. 2ГИС кызматтарын, анын ичинде Өздүк кабинетти (мисалга, аты, атасынын аты, фамилиясы, туулган датасы, паспорттук берилмелери, катталган дареги, телефон номери, Колдонуучунун электрондук почта дареги) пайдалануу процессинде Колдонуучунун жайгаштырган жеке берилмелери. </p>\r\n<p>2.1.4. Колдонуучу тарабынан кайтарым байланыш формасында, анын ичинде Кардардын аты, кызмат орду жайгаштырылуучу жеке берилмелер.</p>\r\n<p>2.1.5. Колдонуучу Администрацияга үчүнчү жактардын веб-сайттары&nbsp;же кызматтары аркылуу, анын ичинде Колдонуучу 2ГИС кызматтарында авторлоштурулганда берген башка жеке маалыматтар.</p>\r\n<p>2.1.6. 2ГИС кызматтары иштөө үчүн зарыл болгон жеке берилме болуп саналбаган берилмелер.</p>\r\n<p>Буларга Колдонуучунун түзмөгүндө орнотулган программалык камсыздоону колдонуу менен 2ГИС Кызматтарына автоматтык түрдө берилүүчү берилмелер, анын ичинде&nbsp;IP дареги, түзмөктүн жеке тармактык номери (MAC-дареги, ID&nbsp;түзмөктөр), электрондук сериялык номери (IMEI, MEID), жарнак идентификаторлору (GAID, IDFA, OAID жана Колдонуучунун операциялык тутумуна тиешелүү башкалары), cookiesден алынган маалыматтар, браузер жөнүндө, операциялык тутум, кирүү убактысы, издөө сурамдары, Колдонуучунун түзмөгүнүн жайгашкан жери жана кыймылы жөнүндө маалыматтар кирет. </p>\r\n<p>Эгерде Администрация ушул берилмелердин негизинде субъектти идентификациялай алса, берилмелер жеке берилмелерге кирет.</p>\r\n<p>2.1.7. 2ГИС кызматтарын пайдалануу боюнча Колдонуучунун алдында Администрация милдеттемелерди аткаруу үчүн, Администрациянын суроо-талабы боюнча Колдонуучу тарабынан кошумча берилген берилмелер.</p>\r\n<p>2.1.8. Колдонуучулар жөнүндө башка маалыматтар, аларды чогултуу жана/же иштетүү жеке 2ГИС өзүнчө кызматтарын колдонуу жөнүндө макулдашуулар жана/же жеке 2ГИС өзүнчө кызматтарын көрсөтүү эрежелери менен белгиленген. </p>\r\n<p>2.2. Программалык продуктуларды колдонуу жана/же 2ГИС кызматтарын көрсөтүү&nbsp;же алардын өзүнчө иштеши үчүн керектүү маалымат өзгөчө түрдө белгиленет. Башка маалыматтар Колдонуучу тарабынан анын каалоосу боюнча берилет. </p>\r\n<p>2.3. Жалпыга жеткиликтүү маалымат булактарынан Колдонуучу алган үчүнчү жактардын жеке маалыматтарын кошпогондо, Колдонуучуга үчүнчү жактардын уруксатысыз үчүнчү жактардын жеке маалыматтарын берүүгө тыюу салынат.</p>\r\n<p>2.4. Жалпы эреже боюнча, Администрация Колдонуучулар тарабынан берилген жеке берилмелердин тууралыгын текшербейт. 2ГИС өзүнчө кызматтарын колдонуу жөнүндө келишимдерде каралган учурларда, Колдонуучу ага берилген жеке берилмелеринин тууралыгын ырастоону камсыз кылууга милдеттүү.</p>\r\n<p>2.5. Администрация 2ГИС Кызматтарын колдонуу процессинде каттоодон, авторлоштуруудан өтпөгөн жана/же жеке маалыматын, анын ичинде кайтарым байланыш формаларында жайгаштырбаган колдонуучулардын жеке берилмелерин иштетпейт.</p>\r\n<p>2.6. Администрация Колдонуучу 2ГИС Кызматтарындагы жеткиликтүү шилтемелери аркылуу өтө ала турган, үчүнчү жактын Маалымат сайттары тарабынан маалыматты иштетүүнү көзөмөлдөбөйт жана жооп бербейт.</p>\r\n<p>3. Маалыматты чогултуу жана иштетүү максаттары</p>\r\n<p>3.1. Администрация 2&nbsp;ГИС Кызматтарын көрсөтүү боюнча Администрациянын милдеттемелерин аткаруу үчүн зарыл болгон Маалыматты гана чогултат жана иштетет.</p>\r\n<p>3.2. Администрация Маалыматты төмөнкүлөр үчүн пайдалана алат:</p>\r\n<p>3.2.1. Колдонуучу менен Администрациянын ортосундагы келишимдин тараптарын идентификациялоо;</p>\r\n<p>3.2.2. текшерүү сырбелгисин билдирүү максатында Колдонуучунун телефон номерине чалуу жолу менен Өздүк кабинетке катоодо Колдонуучуну аутентификациялоо;</p>\r\n<p>3.2.3. 2ГИС Кызматтарын пайдалануу менен Колдонуучуларга кызмат көрсөтүү жана 2ГИС Кызматтарын андан ары жакшыртуу, жаңы кызматтарды жана кызмат көрсөтүүлөрдү өнүктүрүү;</p>\r\n<p>3.2.4. Колдонуучулардын колдоо кызматына карата суроо-талаптарына жооп берүү, 2ГИС Кызматтарынын мүмкүнчүлүктөрү жөнүндө Колдонуучуларды маалымдоо, 2ГИС Кызматтарын пайдаланууга тийиштүү суроо-талаптарды жөнөтүү;</p>\r\n<p>3.2.5. маркетинг;</p>\r\n<p>3.2.6. ээсизделген берилмелердин негизинде статистикалык жана башка изилдөөлөрдү аткаруу;</p>\r\n<p>3.2.7. үчүнчү тараптардын интернет тармагында Колдонуучуларга таргеттик жарнактарды жана материалдарды көрсөтүү жана/же үчүнчү тараптар тарабынан Колдонуучуларга белгиленген мыйзамдык тартипте башка кызматтарды көрсөтүү максатары үчүн, Администрация менен келишим түзгөн үчүнчү жактарга cookiesден алынган берилмелерди берүү; </p>\r\n<p>3.2.8. алынган маалыматтын негизинде Колдонуучунун профилин түзүү жана колдонуучулардын айрым топтору үчүн жарнак продуктуларын түзүү жана&nbsp;/же өнөктөрдүн сайттарында, программаларында, продуктыларында&nbsp;же кызматтарында жарнактарды көрсөтүү үчүн тиешелүү Маалыматты 2ГИС өнөктөрүнө (сайттардын жана тиркемелердин, жарнак тармактарынын ээлери, интернет-бизнес жана&nbsp;/же финансы чөйрөсүндөгү компаниялар) берүү; </p>\r\n<p>3.2.9. кимдин кызыкчылыгында иштесе өнөктүк мамилелерди түзүү, Колдонуучу жана/же Кардар менен келишимдин шарттарын макулдашуу, ушундай келишимлерди түзүү жана аткаруу боюнча сүйлөшүүлөрдү жүргүзүү максатында, Колдонуучу менен болгон коммуникациялар; </p>\r\n<p>3.2.10. кызыкчылыктары менен Колдонуучу иштеген, Кардардын 2ГИС Уюмдар маалымдасына маалыматты кошуулар жана/же актуалдаштыруулар, 2ГИС Кызматтарынын, анын ичинде көрсөтүлгөн максаттар үчүн Колдонуучу менен байланыштардагы так эместиктерди четтетүү; </p>\r\n<p>3.3. Сиз Администрациядан алууга макулдук бересиз:</p>\r\n<p>3.3.1. 2ГИС Кызматтарын, нотификаторлорду, 2ГИС Кызматтарынын алкагында болгон&nbsp;же аларга байланыштуу маанилүү окуялар жөнүндө, ошондой эле өзүнчө жазылуулар болгон учурда&nbsp;&mdash; жазылганда көрсөтүлгөн электрондук почта дарегине 2ГИС жаңылыктары жөнүндө маалыматтык жана/же жарнак материалдарды, иштеп чыгуучулар үчүн иш-чаралар анонсторун жана ушундай иш-чаралардан материалдарды, чыккан макалалар (жарнактык эмес интервью), ар&nbsp;кандай бизнес чөйрөсүнүн компаниялары жөнүндө жөнөтмөлөрдү Сиздин аккаунтта көрсөтүлгөн электрондук дарекке жана мобилдик түзмөккө алууга; </p>\r\n<p>3.3.2. Сиздин Өздүк кабинетте көрсөтүлгөн телефон номерге, анын ичинде мессенджерлерде жана/же электрондук почта аркылуу, анын ичинде 2ГИС Өздүк кабинеттин функционалындагы өзгөрүүлөр жөнүндө кабарламалар, 2ГИС Кызматтарынын жана Административдик кызматтарынын (кабарлоолор үчүнчү жактардын жарнак билдирүүлөрү менен коштолушу мүмкүн) жаңы продуктулары жөнүндө маалымдоолор; </p>\r\n<p>3.4. Колдонуучу 2ГИС Кызматтарынын мобилдик версиясында сунушталган кайтарым байланыш формалары аркылуу push кабарлоолорду алуудан баш тартууга&nbsp;же мобилдик түзмөктөрдүн жөндөөлөрү аркылуу push кабарламаларды алуу мүмкүнчүлүгүн өз&nbsp;алдынча өчүрүүгө укуктуу.</p>\r\n<p>3.5. Администрация Колдонуучуга 2ГИС Кызматтарынын мүмкүнчүлүктөрү жана/же маалымат ресурстарынын өзгөрүшү жөнүндө маалымдоо үчүн нотификаторлорду колдонууга укуктуу.</p>\r\n<p>3.6. Колдонуучунун жеке берилмелерин, ушул Саясатта каралбаган максаттарда колдонуу үчүн Администрация Колдонуучунун мындай колдонууга макулдугун сурайт.</p>\r\n<p>4. Маалыматты иштетүү</p>\r\n<p>4.1. Маалымат колдонулуучу мыйзамдарга ылайык иштетилет.</p>\r\n<p>4.2. Кийинки учурларды кошпогондо, маалымат үчүнчү жактарга берилбейт:</p>\r\n<p>4.2.1. Колдонуучу ушундай берүүгө макулдугун билдирди;</p>\r\n<p>4.2.2. 2ГИС Кызматтарынын иштешин жана/же 2ГИС Кызматтарынын айрым функцияларын камсыз кылуу, 2ГИС Кызматтарынын өнөктүк жана башка программаларын ишке ашыруу, колдоо кызматына суроо-талаптарга жооп берүү үчүн, Администрациянын аффилирленген жагына&nbsp;&mdash; &laquo;ДГ-Софт&raquo; ЖЧКсына жана/же Администрациянын башка аффилирленген адамдарына өткөрүп берүү; </p>\r\n<p>4.2.3. 2ГИС өнөгүн локалдаштырууга 2ГИС Кызматында акыркы маалыматты кошуу жана/же жаңыртуу учурунда өз&nbsp;ара аракеттенүү максатында Колдонуучунун аккаунтунда авторлоштурулган берилмелерин 2ГИС өнөктөргө өткөрүп берүү;</p>\r\n<p>4.2.4. Өткөрүп берүү колдонулуучу укуктар менен каралган.</p>\r\n<p>4.2.5. Өткөрүп берүү Колдонуучу өзүнчө 2ГИС Кызматтарын колдонуу боюнча келишимдердин шарттарын бузган учурларда, Администрациянын жана/же үчүнчү жактардын укуктарын жана мыйзамдуу кызыкчылыктарын коргоо мүмкүнчүлүгүн камсыз кылуу максатында жүргүзүлөт.</p>\r\n<p>4.2.6. Колдонуучунун түзмөгүнүн ээсиздендирилген идентификаторун (IDFA (ID&nbsp;for Advertisers)&nbsp;же GAID (Google Advertiser&nbsp;ID)) белгилүү бир колдонуучу топтору үчүн жарнак продуктуларын түзүү&nbsp;же айрым колдонуучулар топторун атайын жарнак сунуштарын алуучулардын тизмесинен чыгаруу үчүн Россия Федерациясындагы 2ГИС маркетинг өнөктөштөрүнө өткөрүп берүү.</p>\r\n<p>Колдонуучу каалаган убакта мобилдик түзмөктүн жөндөөлөрүн өзгөртүү менен түзмөктүн идентификаторун андан ары чогултууну, сактоону жана өткөрүп берүүнү өчүрө алат.</p>\r\n<p>4.2.7. Продукттагы колдонуучулардын аракеттери жөнүндө берилмелерди талдоо жана системалаштыруу үчүн Израил мамлекетинин мыйзамдарына ылайык катталган жана Россия Федерациясынын салык органында (ИНН: 9909512348) катталган AppsFlyer Лтд компаниясынын Колдонуучусунун түзмөгүнүн жарнактык идентификаторун (IDFA (IDentifier For Advertisers)&nbsp;же GAID (Google Advertiser&nbsp;ID)) өткөрүп берүү.</p>\r\n<p>Колдонуучу каалаган убакта мобилдик түзмөктүн жөндөөлөрүн өзгөртүү менен түзмөктүн идентификаторун андан ары чогултууну, сактоону жана өткөрүп берүүнү өчүрө алат.</p>\r\n<p>Колдонуучу AppsFlyer Лтд купуялуулук саясаты менен <a href=\"https://www.appsflyer.com/gdpr/dpa.pdf\">https://www.appsflyer.com/gdpr/dpa.pdf</a> дареги боюнча тааныша алат. </p>\r\n<p>4.2.8. Колдонуучунун профилин түзгөн маалыматты белгилүү бир колдонуучу топтору үчүн жарнак продуктыларын түзүү жана/же өнөктөрдүн сайттарында, программаларында, продуктыларын&nbsp;же кызматтарында жарнак көрсөтүү үчүн, 2ГИС өнөктөрүнө (сайт жана тиркеме ээлери, жарнак тармактары, интернет бизнес жана/же финансы чөйрөсүндөгү компаниялар) өткөрүп берүү.</p>\r\n<p>4.2.9. Керектүү программалык аппараттык коргоо каражаттарын колдонуу менен жеке берилмелерди анын серверлеринде сактоо үчүн, Колдонуучу кардарларды колдоо &laquo;Чатра&raquo; онлайн кызматы (онлайн чат), &laquo;Дарвин&raquo; ЖЧК (ИНН 7813243387) аркылуу Администрацияга мүмкүнчүлүк берген жеке берилмелерди өткөрүп берет. &laquo;Дарвин&raquo; ЖЧКсынын документтерин <a href=\"https://chatra.com/ru/offer/\">https://chatra.com/ru/offer/</a> дареги боюнча тапса болот.</p>\r\n<p>4.2.10. Колдонуучуга кызмат көрсөтүү, жумуш аткаруу, товар сатуу үчүн Кардардын картасында таризделген Колдонуучунун арызын үчүнчү жактар тарабынан аткаруу. Кызмат көрсөтүү/иштерди аткаруу/товарларды сатуу үчүн Кардардын картасына арыз тариздөөдө, Колдонуучу калтырган берилмелер, Колдонуучуну кызыктырган товарлар жана/же кызматтар/жумуштар Кардарга өткөрүлүп берилет.</p>\r\n<p>4.2.11. Аты-жөнү, фамилиясы, телефон номери, электрондук почта дарегинен турган Колдонуучунун жеке берилмелери бардык Өздүк кабинеттин Колдонуучулары үчүн жеткиликтүү болот.</p>\r\n<p>4.2.12. Өкмөттүн&nbsp;же башка бийликтин сууроо-талабы боюнча мыйзамдуу талаптарды аткаруу максатында өткөрүп берүү.</p>\r\n<p>4.3. Жеке берилмелер субъекттеринин укуктарын адекваттуу коргоону камсыз кылбаган чет мамлекеттердин аймагында жеке маалыматтарды чек арадан өткөрүп берүү, субъекттин макулдугу болгондо гана жана/же келишимди аткаруу максатында жана/же колдонуудагы мыйзамда каралган учурларда мыйзамдын талаптарын аткаруу максатында аткарылат.</p>\r\n<p>4.4. Үчүнчү жактардын жана аларга берилген жеке берилмелердин тизмеси, Администрациянын жеке берилмелерди иштетүүнү жана коргоону уюштурууга Жооптуудан суралышы мүмкүн.</p>\r\n<p>4.5. Колдонуучу ушуну менен кабарланат жана Колдонуучу 2ГИС Кызматтарынын айрым функцияларын ишке ашыруу үчүн 2ГИС Кызматтарын колдонууда Колдонуучу тарабынан берилүүчү үчүнчү жактардын жеке берилмелерин колдонууга жана өткөрүп берүүгө, Администрацияга Колдонуучу мындай пайдаланууга жана өткөрүп берүүгө үчүнчү тараптын макулдугуна кепилдик берген шартында макулдугун берет.</p>\r\n<p>4.6. Колдонуучу ушуну менен кабарланат жана 2ГИС Кызматтарын колдонууда Администрация Колдонуучунун мобилдик түзмөгүнө орнотулган тиркемелер жөнүндө маалыматтарды алып, аларды 2ГИС Кызматтарынын айрым функцияларын ишке ашыруу үчүн колдоно аларына макул болот.</p>\r\n<p>4.7. Колдонуучу ушуну менен кабарланат жана Администрация 2ГИС Кызматтарын колдонууда жана Колдонуучу тарабынан белгиленген 2ГИС Кызматтарынын жөндөөлөрү боюнча Колдонуучунун аракеттери тууралуу статистикалык ээсиздендирилген (Колдонуучуга байлоосу жок) берилмелерди ала алаарына макул болот.</p>\r\n<p>4.8. Администрация Россия Федерациясынын аймагында жүргөн берилмелер базасын пайдаланып, Кыргыз Республикасынын жарандарынын жеке берилмелерин чогултуу, эсепке алуу, системалаштыруу, топтоо, сактоо, тактоо (жаңыртуу, өзгөртүү), чыгарып алуу, колдонуу, өткөрүп берүү (таратуу, камсыз кылуу, жеткиликтүүлү), ээсиздендирүү, бөгөттөө, өчүрүү, жок кылууну аткарат. Колдонуучулардын Жеке берилмелери, Жеке берилмелерди иштетүү максаттарына жеткенге чейин&nbsp;же колдонуучу тарабынан жеке берилмелерди иштетүүгө макулдугу алынып салынганга чейин сакталат. Жеке берилмелерди иштетүү автоматташтырылган каражаттарды колдонуу менен&nbsp;да, автоматташтыруу каражаттарын колдонуусуз да&nbsp;жүргүзүлөт.</p>\r\n<p>4.9. Жеке берилмелер Администрация тарабынан колдонуудагы мыйзамдарга ылайык өчүрүлөт.</p>\r\n<p>5. Колдонуучулардын укуктары</p>\r\n<p>5.1. Колдонуучулар укуктуу:</p>\r\n<p>5.1.1. Администрация Сайтынын Өздүк кабинетке өзү жөнүндө маалыматка өзгөртүүлөрдү, толуктоолорду өз алдынча киргизүүгө.</p>\r\n<p>5.1.2. Администрация Сайтында Өздүк кабинеттин аккаунтунун алкагында берилген өзү жөнүндө Маалыматты өчүрүүгө. Аккаунтту, Өздүк кабинетти, Маалыматты өчүрүү айрым 2ГИС Кызматтарын пайдалануунун мүмкүн эместигине алып келет. </p>\r\n<p>5.1.3. Администрациядан алардын жеке маалыматтарын иштетүү боюнча суроо боюнча маалымат алуу.</p>\r\n<p>6. Маалыматты коргоо чаралары</p>\r\n<p>6.1. Администрация Колдонуучулардын жана үчүнчү жактардын жеке берилмелерин аларга уруксатсыз же кокусунан кирүүдөн, жок кылуудан, өзгөртүүдөн, блокировкалоодон, таратуудан, ошондой эле алар менен болгон башка мыйзамсыз аракеттерден коргоо үчүн бардык зарыл жана жетиштүү уюштуруучулук жана техникалык чараларды көрөт. Мындай чаралар, атап айтканда, жеке маалыматтарды чогултуунун, сактоонун жана иштетүүнүн ички текшерүүсүн жана коопсуздук чараларын, анын ичинде тиешелүү шифрлөөнү жана жеке берилмелер сакталган тутумдарга уруксатсыз кирүүнү болтурбоо үчүн жеке берилмелердин физикалык коопсуздугун камсыз кылуу чараларын камтыйт.</p>\r\n<p>7. Корутунду жоболор</p>\r\n<p>7.1. Бул Саясат, Колдонуучу менен Администрациянын ортосундагы ушул Саясатты колдонууга байланыштуу пайда болгон мамилелер, ошондой эле бул Саясат менен жөнгө салынбаган маселелер Россия Федерациясынын колдонуудагы мыйзамдары жана башка колдонулуп жаткан мыйзамдар менен жөнгө салынат.</p>\r\n<p>7.2. Бул Саясатка байланыштуу бардык суроолорду 2ГИС Колдоо кызматына (<a href=\"http://help.2gis.ru/feedback/\">http://help.2gis.ru/feedback/</a>), Өздүк кабинеттин (f<a href=\"mailto:eedback@account.2gis.com\">eedback@account.2gis.com</a>) Колдонуучуларынын Колдоо Кызматына (<a href=\"mailto:feedback@account.2gis.com\">feedback@account.2gis.com</a>) же 630048, Россия Федерациясы, Новосибирск ш., Карл Маркс атындагы. аят, 7-үй, 13 &ndash;кабат дареги боюнча жөнөтүүнүн суранабыз.</p>\r\n<p>7.3. Жеке берилмелерди мыйзамсыз колдонуу фактысы аныкталган учурда, берилмелери мыйзамсыз колдонулган жеке берилмелер субъектиси, мындай жеке берилмелердин жок кылынгандыгы жөнүндө Администрацияга жазуу жүзүндө арыз жөнөтүүгө милдеттүү. Арызда жеке берилмелер субъектисинин макулдугу жок пикирде мыйзамсыз колдонулган жеке берилме субъектисинин өздүгүн ырастоочу документтин реквизиттери, кароону жайгаштырган Колдонуучунун аты-жөнү көрсөтүлүшү керек. Арызды 630048, Россия Федерациясы, Новосибирск ш., Карл Маркс атынд. аянт, 7-үй, 13- кабат дареги боюнча жөнөтүү зарыл.</p>\r\n<p>7.4. Бул Саясаттын учурдагы редакциясы Администрациянын сайтында жайгаштырылган жана Интернетте <a href=\"http://law.2gis.kg/privacy/\">http://law.2gis.kg/privacy/</a> дареги боюнча жеткиликтүү.</p>\r\n<p>05.08.2024-ж. редакциясы</p>\r\n<p>&copy; &ldquo;ДубльГИС&rdquo; ЖЧК, 2024</p>\r\n<hr />\r\n<h2>Смотрите также:</h2>\r\n<ul>\r\n<li><a href=\"/privacy/red201120\">Редакция от&nbsp;20.11.20</a> (утратила силу 05.08.2024)</li>\r\n<li><a href=\"/privacy/red261020\">Редакция от&nbsp;26.10.20</a> (утратила силу 20.11.2020)</li>\r\n<li><a href=\"/privacy/red040820\">Редакция от&nbsp;04.08.20</a> (утратила силу 26.10.2020)</li>\r\n<li><a href=\"/privacy/red311015\">Редакция от&nbsp;30.10.15</a> (утратила силу 04.08.2020)</li>\r\n</ul>","module":{"id":"1-8","type":"usercontent"}}}],"initedModules":[{"slot":{"templates":{},"modules":{},"utils":{},"config":{"mainModule":"page","projectName":"infoportal","city.cookieName":"project","mapsApi.libURL":"https://maps.api.2gis.ru/2.0/loader.js?pkg=full","static.prefix":"https://hstatic.2gis.com/","schema":"https","crmEndpoint":"https://info.2gis.ru/moscow/advtilda","infoApi.host":"ayahuasca.2gis.com","monitor.url":"/novosibirsk/monitor","server.listenArgs":[3000],"server.instanceCount":1,"server.useCluster":true,"WebApi.catalogU