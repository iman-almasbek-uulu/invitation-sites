    <script>
      const desktopQR = ".cta_block__qr";
      const buttonEnableFriendsId = ".steps-block_button_open_tab";
      const buttonDownloadId1 = ".steps-block_button_update1";
      function waitForElement(querySelector, timeout) {
        return new Promise((resolve, reject) => {
          var timer = false;
          if (document.querySelectorAll(querySelector).length) return resolve();
          const observer = new MutationObserver(() => {
            if (document.querySelectorAll(querySelector).length) {
              observer.disconnect();
              if (timer !== false) clearTimeout(timer);
              return resolve();
            }
          });
          observer.observe(document.body, {
            childList: true,
            subtree: true
          });
          if (timeout)
            timer = setTimeout(() => {
              observer.disconnect();
              reject();
            }, timeout);
        });
      }
      function changeQR() {
        let elements = document.querySelectorAll(desktopQR);
        elements.forEach((element) => {
          //element.style.textAlign = "center";
          //element.style.paddingTop = "6px";
          var qrcode = new QRCode(element, {
          width : parseInt(element.clientWidth, 10),
          height : parseInt(element.clientHeight, 10),
          });
          //buttonEnableFriendsLink.clickURL
          //qrcode.makeCode(buttonEnableFriendsLink.clickURL);
          qrcode.makeCode(window.location.href);
          waitForElement(desktopQR + " > canvas", 3000)
          .then(function () {
            document.querySelector(desktopQR + " > canvas").style.width = '100%'
            console.log('QR style changed');
            }
          )
        });
      }
      const oneLinkDownloadUrl = "https://2gis.onelink.me/QOvt";
      const oneLinkEnableFriendsUrl = "https://2gis.onelink.me/R9s6";
      const mediaSource = {keys:["utm_source","media_source","source","pid","origin_pid","source_pid","media"],defaultValue:"friends_landing"};
      const campaign1 = {keys:["utm_campaign","campaign","c"],defaultValue:"downloadorupdate_link"};
      const campaign2 = {keys:["utm_campaign","campaign","c"],defaultValue:"invite_link"};
      const utm_source = {paramKey:"utm_source",keys:["utm_source","media_source","source"]};
      const utm_medium = {paramKey:"utm_medium",keys:["utm_medium","medium"]};
      const utm_campaign = {paramKey:"utm_campaign",keys:["utm_campaign","campaign"]};
      const afSub4 = {keys:["af_sub4"]};
      const afSub5 = {keys:["af_sub5"]};
      var deepLinkValue = {keys:["deep_link_value"],defaultValue:"dgis%3A%2F%2F2gis.ru%2Fmapfriends%2Finvite"};
      var af_dp = {paramKey:"af_dp",keys:["deep_link_value"],defaultValue:"dgis%3A%2F%2F2gis.ru%2Fmapfriends%2Finvite"};
      const urlParams = new URLSearchParams(window.location.search);
      const getParamUserId = urlParams.get("user_id");
      if (getParamUserId !== null) {
        deepLinkValue.defaultValue = "dgis%3A%2F%2F2gis.ru%2Fuser%2F" + getParamUserId;
        af_dp.defaultValue = "dgis%3A%2F%2F2gis.ru%2Fuser%2F" + getParamUserId;
      }
      const custom_ss_ui = {paramKey:"af_ss_ui",defaultValue:"true"};
      const buttonDownloadLink = window.AF_SMART_SCRIPT?.generateOneLinkURL({
        oneLinkURL: oneLinkDownloadUrl,
        afParameters: {
          mediaSource: mediaSource,
          campaign: campaign1,
          afCustom: [
            utm_source,
            utm_medium,
            utm_campaign,
            custom_ss_ui
          ],
          afSub4: afSub4,
          afSub5: afSub5
        }
      });
      const buttonEnableFriendsLink = window.AF_SMART_SCRIPT?.generateOneLinkURL({
        oneLinkURL: oneLinkEnableFriendsUrl,
        afParameters: {
          mediaSource: mediaSource,
          campaign: campaign2,
          afCustom: [
            utm_source,
            utm_medium,
            utm_campaign,
            af_dp,
            custom_ss_ui
          ],
          afSub4: afSub4,
          afSub5: afSub5,
          deepLinkValue: deepLinkValue
        }
      });
      function clickDownload() {
        console.log(buttonDownloadLink.clickURL);
        window.open(buttonDownloadLink.clickURL);
        //window.open(button1Url.clickURL, "_self");
      }
      function clickEnableFriends() {
        console.log(buttonEnableFriendsLink.clickURL);
        window.open(buttonEnableFriendsLink.clickURL);
      }
      function changeButtonEnableFriends() {
        let button2 = document.querySelectorAll(buttonEnableFriendsId);
        button2.forEach((button) => {
          button.setAttribute('data-event-element', 'invite');
          button.addEventListener("click", (e) => {
            clickEnableFriends();
          });
        });
      }
      function changeButtonDownload(selector) {
        let button3 = document.querySelector(selector);  
        button3.setAttribute('data-event-element', 'install_update'); 
        button3.addEventListener("click", (e) => {
          clickDownload();
        });
      }
    </script>
  
