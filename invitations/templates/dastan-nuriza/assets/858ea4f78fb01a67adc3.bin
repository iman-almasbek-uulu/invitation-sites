			],
			accessToken: null,
			ranks: [],
			champion: {},
			initialized: false,
			isParticipant: false,

			contestBasePath: '/bonuses/contests/contest2.0_series5',

			showDefaultScoreText() {
				const date = '2025-07-29T07:00:00.000+03:00';

				return (new Date()) < (new Date(date));
			},

			hashString(str) {
				let hash = 0;
				for (let i = 0; i < str.length; i++) {
					const char = str.charCodeAt(i);
					hash = (hash << 5) - hash + char;
					hash |= 0; // Convert to 32bit integer
				}
				return hash;
			},

			getRandomPicture(userName) {
				const pictures = [
					'img/user-empty-1.png',
					'img/user-empty-2.png',
					'img/user-empty-3.png',
				];

				const hash = this.hashString(userName);
				const index = Math.abs(hash) % pictures.length;
				return pictures[index];
			},


			getHowToHeading() {
				if (this.hasEnded()) {
					return 'Как нужно было играть?';
				}

				return 'Как играть?';
			},

			getHowToJoinHeading() {
				if (this.hasEnded()) {
					return 'Кто принимает участие?';
				}

				return 'Как присоединиться?';
			},

			getIntroCopyText() {
				if (this.hasEnded()) {
					return 'Конкурс завершён. Итоги&nbsp;— 6&nbsp;августа. Будьте на&nbsp;связи!<br><br>';
				}

				return 'С&nbsp;9&nbsp;до&nbsp;29&nbsp;июля делитесь видео, фото и&nbsp;отзывами о&nbsp;местах столицы и&nbsp;выигрывайте подарки';
			},

			getPicture(winner) {
				const picture = winner['photo'];

				if (! picture) {
					return this.getRandomPicture(winner['name']);
				}

				return picture.replace(/_448x448\.jpg$/, '_200x200.jpg');
			},
			getWinnerPrizeImage(winner) {
				const prize = winner['prize'];

				if (prize === 'PlayStation 5 Slim') {
					return 'img/icons/prize-ps5.svg';
				}

				if (prize === 'iPhone 16 Pro') {
					return 'img/icons/prize-iphone.svg';
				}

				if (prize === 'фен Dyson Pro') {
					return 'img/icons/prize-dyson.svg';
				}

				if (prize === 'MacBook Air M4') {
					return 'img/icons/prize-macbook.svg';
				}

				if (prize === 'электросамокат Xiaomi') {
					return 'img/icons/prize-samokat.svg';
				}

				if (prize === 'Сертификат в Золотое яблоко') {
					return 'img/icons/prize-ga.svg';
				}

				if (prize === 'Промокодов от Отелло') {
					return 'img/icons/prize-otello.svg';
				}

				return '';
			},
			getRanksTabText() {
				return this.showWinners() ?
						'Победители' :
						'Мой результат';
			},
			showWinners() {
				return true;
			},
			showTimer() {
				return !this.hasEnded() && (new Date() > new Date(this.startDate));
			},
			progressWidth(targetScore) {
				const percent = (this.me.score / targetScore) * 100;
				return `${Math.round(percent)}%`;
			},
			progressText(targetScore) {
				return `${this.me.score} / ${targetScore} мест`;
			},
			showZeroScoreText() {
				return !this.me.score && this.initialized;
			},
			showNonZeroScoreText() {
				return (this.me.score > 0) && this.initialized;
			},
			auth() {
				window.location = this.getCookie('version') === null ?
						'dgis://2gis.ru/mapfriends/invite' :
						'dgis://2gis.ru/mapfriends/contest'
				;
			},
			showQr(){
				return (this.accessToken === null) && (this.getCookie('version') === null);
			},
			hasEnded() {
				const endDateString = document.querySelector('.timer').getAttribute('data-date');
				return new Date() > new Date(endDateString);
			},
			isAuthorized() {
				return this.initialized && this.accessToken;
			},
			isObjectEmpty(object) {
				return Object.keys(object).length === 0
			},
			getCookie(name) {
				const cookies = document.cookie.split(';');
				for (let cookie of cookies) {
					const [cookieName, cookieValue] = cookie.trim().split('=');
					if (cookieName === name) {
						return decodeURIComponent(cookieValue);
					}
				}
				return null;
			},
			previewPicture(templateUrl) {
				if (!templateUrl) {
					return 'img/blank.png';
				}
				return templateUrl.replace('{width}x{height}', '200x200');
			},
			isParticipateButtonVisible() {
				/* убираем кнопку «Участвовать», если showIOSBlocked() = true */
				return !this.isParticipant && this.initialized &&
						!this.hasEnded()   && !this.showIOSBlocked();
			},
			isParticipantCaptionVisible () {
				return this.initialized && this.isParticipant;
			},
			isAuthorizedButtonVisible() {
				/* убираем кнопку «Авторизоваться», если showIOSBlocked() = true */
				return this.initialized && !this.isAuthorized() &&
						!this.showWinners() && !this.showIOSBlocked();
			},
			isTabsBlockVisible() {

				if (! this.showTabs) {
					return false;
				}

				return this.initialized &&
						!this.isParticipateButtonVisible() &&
						!this.isAuthorizedButtonVisible() &&
						!this.showIOSBlocked() &&
						!(this.hasEnded() && !this.isParticipant && !this.showWinners())
					;
			},isIOS74() {
				const platform = this.getCookie('platform');
				const version  = this.getCookie('version');
				return platform === 'iOS' && /^7\.4/.test(version || '');
			},
			showIOSBlocked() {
				/* true, если проблемная iOS + пользователь не залогинен */
				return this.isIOS74() && !this.accessToken;
			},
			hasPrize() {
				return this.me.claims_standard_prize;
			},
			initStickyUser() {
				$('.ranks__list').each(function(){
					$(this).find('.ranks__list-item-user-trigger').each(function(){
						$(this).remove();
					});

					var list = $(this),
							user = list.find('.ranks__list-item._user'),
							trigger = $('<div class="ranks__list-item-user-trigger"></div>').insertAfter(user);


					if (!user.length) return;

					(new IntersectionObserver(function(entries, self) {
						entries.forEach(function(entry) {
							if (entry.isIntersecting) {
								list.removeClass('_user-sticky');
							} else {
								list.addClass('_user-sticky');
							};
						});
					}, {
						rootMargin: '0px 0px -20px 0px',
						threshold: 0
					})).observe(trigger[0]);
				});
			},
			plural(number, word1, word4, word5) {
				if (number % 100 === 11 || number % 100 === 12 || number % 100 === 13 || number % 100 === 14) return word5;
				if (number % 10 === 1) return word1;
				if (number % 10 === 2 || number % 10 === 3 || number % 10 === 4) return word4;
				return word5;
			},
			printScore(score) {
				return score + this.plural(score, ' место', ' места', ' мест');
			},
			printScoreAndCountry(score, country) {
				const printScore = this.printScore(score);

				if (country) {
					return `${printScore} (${country})`;
				}

				return printScore;
			},
			isCurrentUser(winner) {
				return winner['public_user_id'] === this.me.participant.public_user_id;
			},
			printName(winner) {
				const name = winner['Имя'] ?? winner['name'];
				return this.isCurrentUser(winner) ?
						`<em>Я</em> · ${name}`: name;
			},
			async participate() {
				this.isParticipant = true;

				this.$nextTick(() => {
					if (this.showTabs) {
						$(this.$refs.rating).click();
					}

					if (document.querySelector('body').classList.contains('_popup-show')) {
						W.trigger('popup:hide');
					}
				});

				await this.makeApiCall(
						this.contestBasePath + '/participation',
						'PUT'
				);

				this.processJsonResponse(await this.fetchRatingOrDemoData());

				this.$nextTick(() => {
					this.initStickyUser();
				});
			},
			async makeApiCall(endPoint, method = 'GET', queryParameters = {}) {
				let requestUrl = `https://bonuses.api.2gis.ru${endPoint}`;
				const queryString = (new URLSearchParams(queryParameters).toString());

				if (queryString) {
					requestUrl += `?${queryString}`;
				}

				return await fetch(requestUrl, {
					method,
					headers: {
						'Content-Type': 'application/json',
						'Authorization': `Bearer ${this.accessToken}`
					}
				});
			},
			async fetchParticipationData() {
				const response = await this.makeApiCall(
						this.contestBasePath + '/participation'
				);
				const json = await response.json();
				this.isParticipant = json.is_participant ?? false;
			},
			async fetchRating() {
				const response = await this.makeApiCall(
						this.contestBasePath + '/rating',
						'GET',
						{top: 1}
				);
				return await response.json();
			},
			async init() {
				const qs = new URLSearchParams(window.location.search);
				const brokenAndroid = qs.get('frtne') === 'true'
				&& !(this.getCookie('platform') || this.getCookie('version') || this.getCookie('auth_access_token'));

				if (brokenAndroid) {
					location.replace(
							'dgis://2gis.ru/webview?url=https%3A%2F%2Ffriends-contest.2gis.ru%2Fseries5%2F&send_cookies=true'
					);
					return;
				}

				this.accessToken = this.getCookie('auth_access_token');

				this.accessToken = new URL(window.location.href).searchParams.get('access_token') ??
						this.accessToken;

				if (this.accessToken || this.isDemo) {
					if (!this.isDemo) {
						await this.fetchParticipationData();
					}
					this.processJsonResponse(await this.fetchRatingOrDemoData());
				}

				this.regularPrizes = this.allPrizes.filter(prize => (!prize.superPrize & !prize.simplePrize));
				this.simplePrizes = this.allPrizes.filter(prize => (!prize.superPrize & prize.simplePrize) );
				this.superPrizes = this.allPrizes.filter(prize => prize.superPrize);


				if (!this.showWinners()){
					this.prizes = this.allPrizes.filter(prize => this.me.score < prize.score);
					this.claimedPrizes = this.allPrizes.filter(prize => this.me.score >= prize.score);
				}

				this.initialized = true;

				this.$nextTick(() => {
					this.showAuthButton();
					this.showWonPopup();
					this.setActiveTab();
					this.renderPrizesSlider();
					this.initStickyUser();
				});

			},
			setActiveTab() {
				if (! this.showTabs) {
					return;
				}

				if (!this.hasEnded() && (!this.isAuthorized() || !this.isParticipant)) {
					return;
				}

				if (this.hasEnded() && !this.isParticipant && !this.showWinners()) {
					return;
				}

				$(this.$refs.rating).click();
			},
			processJsonResponse(json) {

				this.me = json.me ?? this.me;

				if (!json.top || !json.top.length) {
					return;
				}
				let top = json.top;
				top = top.filter((item) => {
					return ((item.position >= 1) && (item.position <= 3)) ||
						((item.position >= 98) && (item.position <= 100)) ||
						((item.position >= 298) && (item.position <= 300)) ||
						item.position === this.me.position
					;
				});

				if (!this.isObjectEmpty(this.me)) {
					const isMeInTop = top.some((item) => {
						return item.participant.public_user_id === this.me.participant.public_user_id;
					});

					if (!isMeInTop) top.push(this.me);
				}

				if (this.hasEnded()) {
					this.ranks = top;
					return;
				}

				this.champion = top[0];
				this.ranks = top.slice(1);
			},
