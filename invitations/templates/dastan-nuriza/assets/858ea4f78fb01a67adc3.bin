						"participant": {
							"public_user_id": "02bc4d0b618e4eb19be6171bc5457999",
							"name": "Karina Abramova",
							"avatar": "http://mresizer.photo.2gis.com/images/profile/xxx.jpg",
							"avatar_preview_tpl": "img/temp/rank4.jpg"
						},
						"score": 1
					},
					participants_count: 101,
				};
			},
			showAuthButton() {
				return;

				document.querySelector('body').classList.remove('_authed');

				let authPopup = `<div class="popup__hidden"><div class="auth-message">
            <h2 class="auth-message__heading">Авторизуйтесь, чтобы участвовать</h2>
            <p class="auth-message__copy">Нажмите кнопку «Включить Друзей», завершите настройку и&nbsp;возвращайтесь сюда, чтобы присоединиться к&nbsp;игре.</p>
        </div></div>`;
				authPopup = $(authPopup).appendTo('body').find('.auth-message');
				W.trigger('popup:show',{
					el: authPopup,
					class: '_auth'
				});

				$('.header .header__tabs-item[data-rel="ranks"]').each(function() {
					$(this).off('click');
					$(this).on('click', function (){
						W.trigger('popup:show',{
							el: authPopup,
							class: '_auth'
						});
					});
				});
			},
			showWonPopup() {
				if (!this.hasEnded() || !this.hasPrize()) {
					return;
				}

				$('.ranks__list-item._user').on('click',() => {
					W.trigger('popup:show',{
						el: $(this.$refs.won)
					});
				});

				W.trigger('popup:show',{
					el: $(this.$refs.won)
				});
			},
			async fetchRatingOrDemoData() {
				return this.isDemo ?
						this.getDemoData() :
						await this.fetchRating();
			},
			renderPrizesSlider() {
				$('.prizes').each(function(){
					let p = $(this);
					let length = p.find('.swiper-slide').length;

					if (length <= 1) {
						return;
					}

					p.find('.prizes__slider').append('<div class="slider-pagination"></div>');
					let swiper = new Swiper(p.find('.swiper')[0],{
						spaceBetween: 12,
						slidesPerView: 'auto',
						pagination: {
							el: p.find('.slider-pagination')[0],
							bulletClass: 'slider-pagination__item',
							bulletActiveClass: '_active',
							lockClass: '_hidden'
						}
					});
				});
			}
		}));
	});
</script>


</body></html>
