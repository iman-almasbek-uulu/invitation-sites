8cd1cf5ddb5d65b1cddaf08&amp;w=750&amp;q=75 750w, /event/_next/image?url=https%3A%2F%2Fcms.russpass.ru%2Fv1%2Ffile%2F68cd1cf5ddb5d65b1cddaf08&amp;w=828&amp;q=75 828w, /event/_next/image?url=https%3A%2F%2Fcms.russpass.ru%2Fv1%2Ffile%2F68cd1cf5ddb5d65b1cddaf08&amp;w=1080&amp;q=75 1080w, /event/_next/image?url=https%3A%2F%2Fcms.russpass.ru%2Fv1%2Ffile%2F68cd1cf5ddb5d65b1cddaf08&amp;w=1200&amp;q=75 1200w, /event/_next/image?url=https%3A%2F%2Fcms.russpass.ru%2Fv1%2Ffile%2F68cd1cf5ddb5d65b1cddaf08&amp;w=1920&amp;q=75 1920w, /event/_next/image?url=https%3A%2F%2Fcms.russpass.ru%2Fv1%2Ffile%2F68cd1cf5ddb5d65b1cddaf08&amp;w=2048&amp;q=75 2048w, /event/_next/image?url=https%3A%2F%2Fcms.russpass.ru%2Fv1%2Ffile%2F68cd1cf5ddb5d65b1cddaf08&amp;w=3840&amp;q=75 3840w" src="/event/_next/image?url=https%3A%2F%2Fcms.russpass.ru%2Fv1%2Ffile%2F68cd1cf5ddb5d65b1cddaf08&amp;w=3840&amp;q=75"></div></div><a class="banner_Link__25LLa" href="https://russpass.ru/luggage-storage" target="_blank"></a></div></div></div></div></div><div class="activityDetail_footerContent__tbSC6" id="activityDetailsMap"><div class="activity-map"><div class="activity-map__wrap"><div class="style_controlsWrapperRelative__YPAfn"><div class="compact-route-controls"><div class="route-controls__item"><button class="button button--third button--small button--floating">SVO</button></div><div class="route-controls__item"><button class="button button--third button--small route-controls__button">DME</button></div></div></div><div class="activity-map__background"></div><div class="style_mapWrapper__pWspm"><div class="style_mapWrapper__pWspm" style="position:relative;width:100%;height:100%"><div id="yandex-map-container-activity" style="width:100%;height:100%" class="ya-map activity_map"></div></div></div></div></div></div></div></main><div class="layoutNota_footer__HI4jH"></div></div><span></span><div class="Toastify" id="portal-notify"></div><div class="styles_popup-wrapper__2eokV"></div></div></div><img src="https://top-fwz1.mail.ru/counter?id=3357868;js=na" style="position:fixed;left:-9999px" alt="Top.Mail.Ru"></div><script id="__NEXT_DATA__" type="application/json">{"props":{"pageProps":{"language":"ru","eventId":"5e5617a2826e00001944d03a","eventData":{"errorCode":0,"id":"5e5617a2826e00001944d03a","title":"Аэроэкспресс","description":"\u003cp\u003e\u003cstrong\u003eВ расписании возможны изменения. Перед покупкой проверяйте актуальную информацию в блоке «Расписание».\u003c/strong\u003e \u003cbr\u003e\u003cbr\u003e «Аэроэкспресс» — это наиболее удобный, быстрый и точный способ добраться из аэропорта в центр города и обратно. Современные электропоезда курсируют по маршрутам «Домодедово — Павелецкий вокзал», «Шереметьево — Белорусский вокзал — Одинцово». Выбирая «Аэроэкспресс», пассажиры получают высокий уровень безопасности движения, клиентоориентированный сервис, малое время в пути, разнообразные тарифы, комфорт в пути следования и в терминалах. \u003cbr\u003e\u003cbr\u003e \u003cstrong\u003eДля детей до 7 лет проезд в поездах и автобусах «Аэроэкспресс» бесплатный при предъявлении документа, удостоверяющего возраст ребенка.\u003c/strong\u003e \u003cbr\u003e\u003cbr\u003eАэроэкспрессы в Москве курсируют по маршрутам: \u003cbr\u003e\u003cbr\u003e\u003cstrong\u003eОдинцово — аэропорт Шереметьево\u003c/strong\u003e\u003cbr\u003e\u003cbr\u003eг. Одинцово\u003cbr\u003e\u003cbr\u003eОстановки: Одинцово — Баковка — Сколково — Немчиновка — Сетунь — Рабочий поселок — Кунцевская — Фили — Тестовская — Беговая — Белорусский вокзал — Савеловский вокзал — Окружная — Лианозово — Аэропорт Шереметьево (терминалы B, C) — Аэропорт Шереметьево (терминалы D, E, F)\u003cbr\u003e\u003cbr\u003e\u003cstrong\u003eПавелецкий вокзал — аэропорт Домодедово\u003c/strong\u003e\u003cbr\u003e\u003cbr\u003eПавелецкая пл., д. 1А, стр. 1\u003cbr\u003e\u003cbr\u003eОстановки: Павелецкий вокзал — Верхние котлы — Станция Домодедово — Аэропорт Домодедово \u003cbr\u003e\u003cbr\u003e\u003cstrong\u003eОстановка «Станция Домодедово» есть не на всех поездах данного направления. Перед поездкой ознакомьтесь с расписанием.\u003c/strong\u003e\u003c/p\u003e","participants":{},"type":"Транспорт","kind":"aeroexpress","season":{},"price":{"discount":{},"regularPrice":600},"isFavorite":false,"isActualizedByPartner":false,"isCanBuy":true,"place":{"title":"Аэроэкспресс","id":"603deb308a901600198e38ed","address":"Аэропорт Шереметьево, г. Химки","image":"https://cms.russpass.ru/v1/file/603deac28a901600198e38e4","coordinates":{"longitude":"37.41485671055908","latitude":"55.96362991144163"},"isPublished":false,"schedule":{"all":{"workingTime":"05:00-00:30"},"monday":{"workingTime":"05:00-00:30","closed":false},"tuesday":{"workingTime":"05:00-00:30","closed":false},"wednesday":{"workingTime":"05:00-00:30","closed":false},"thursday":{"workingTime":"05:00-00:30","closed":false},"friday":{"workingTime":"05:00-00:30","closed":false},"saturday":{"workingTime":"05:00-00:30","closed":false},"sunday":{"workingTime":"05:00-00:30","closed":false}}},"isRusspassRecommends":false,"rating":{},"hasDiscount":false,"images":[{"url":"https://cms.russpass.ru/v1/file/5f11b839a0eff2001856058b","imageAlt":"Аэроэкспресс"},{"url":"https://cms.russpass.ru/v1/file/5f11b840a0eff20018560591","imageAlt":"Аэроэкспресс"},{"url":"https://cms.russpass.ru/v1/file/65a68b517b750101b4ee078d","imageAlt":"Аэроэкспресс"},{"url":"https://cms.russpass.ru/v1/file/5f11b84ca0eff2001856059d","imageAlt":"Аэроэкспресс"},{"url":"https://cms.russpass.ru/v1/file/65a68b557b750101b4ee07e6","imageAlt":"Аэроэкспресс"}],"banners":[{"title":"Сдайте багаж на хранение","imgUrl":"https://cms.russpass.ru/v1/file/68cd1cf5ddb5d65b1cddaf08","description":"\u003cp\u003eИ насладитесь прогулкой по городу налегке\u003c/p\u003e","linkText":"Узнать больше","url":"https://russpass.ru/luggage-storage"}],"details":[{"aeroexpress":{"map":[{"title":"SVO","points":[{"title":"Одинцово","coordinates":["55.672347","37.282248"],"pointType":"station","chipPosition":"left"},{"title":"Бако