а":[null,"البريد الإلكتروني"],"© $years, $legalName":[null,"© $years, $legalName"],"Страница не найдена":[null,"لم يتم العثور على الصفحة"],"Такой страницы не существует":[null,"لا توجد مثل هذه الصفحة"],"Войдите в %1 любым удобным способом":[null,"قم بتسجيل الدخول إلى %1 بأي طريقة متاحة"],"Войдите":[null,"تسجيل الدخول"],"с помощью номера телефона, который был указан при регистрации":[null,"باستخدام رقم الهاتف الذي تم تحديده أثناء التسجيل"],"Подтвердите номер":[null,"تأكيد رقمك"],"Введите код, отправленный в СМС, на номер %1":[null,"أدخل الرمز المرسل في الرسائل النصية القصيرة إلى رقم %1"],"Подтверждение":[null,"تأكيد"],"Вы отказались использовать текущий аккаунт":[null,"لقد رفضت استخدام حسابك الجاري"],"Используем текущий аккаунт?":[null,"هل نستخدم حساب جاري؟"],"Забыли пароль?":[null,"هل نسيت كلمة المرور؟"],"Мы отправили вам ссылку для восстановления пароля":[null,"لقد أرسلنا لك الرابط لإعادة تعيين كلمة المرور"],"Ничего страшного, бывает! На какую почту вам прислать ссылку для восстановления пароля?":[null,"لا بأس، هذا يحدث! إلى أي بريد إلكتروني يجب أن نرسل الرابط لإعادة تعيين كلمة المرور الخاصة بك؟"],"Придумайте новый пароль для входа в %1. Для надёжности его длина должна быть больше шести символов":[null,"قم بإنشاء كلمة مرور جديدة لتسجيل الدخول إلى %1. من اجل الموثوقية ، يجب أن تكون أطول من ستة أحرف."],"Новый пароль":[null,"كلمة مرور جديدة"],"Сохраняем...":[null,"جاري الحفظ..."],"Сохранить":[null,"حفظ"],"Регистрируем...":[null,"جاري التسجيل..."],"Успешно":[null,"بنجاح"],"Регистрация":[null,"تسجيل"],"Подтверждение пароля":[null,"تأكيد كلمة المرور"],"У меня есть аккаунт. [Войти].":[null,"لدي حساب. [تسجيل الدخول]."],"Используйте этот пароль для входа в аккаунт %1":[null,"استخدم كلمة المرور هذه للدخول إلى حساب %1"],"Всё получилось":[null,"لقد نجحت"]}}</script><script>window.__locale="en-US"</script><script>window.__countryCode="ru"</script><script>
