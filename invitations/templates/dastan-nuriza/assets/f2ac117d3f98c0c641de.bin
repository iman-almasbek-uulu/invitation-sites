  html,
  body {
    height: 100%;
    width: 100%;
  }

  body {
    font-family: 'Arial Narrow', 'Ubuntu Condensed', 'Roboto Condensed', 'Droid Sans', Helvetica, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
