зионное соглашение","subnav":[],"active":true,"mods":{"active":true,"expanded":true},"level":3},{"url":"https://law.2gis.kg/advert-rules/","text":"Правила оказания рекламных и информационных услуг с использованием Продуктов 2ГИС","subnav":[{"url":"https://law.2gis.kg/advert-rules/requirements/","text":"Требования к рекламным материалам","subnav":[],"mods":{},"level":4},{"url":"https://law.2gis.kg/advert-rules/technical-requirements/","text":"Требования к оформлению рекламных материалов","subnav":[],"mods":{},"level":4}],"mods":{},"level":3},{"url":"https://law.2gis.kg/informational-requirements/","text":"Требования к информационным материалам","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/privacy/","text":"Политика конфиденциальности","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/rules/","text":"Соглашение об использовании сервисов 2ГИС","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/dialer-licensing-agreement/","text":"Лицензионное соглашение «2GIS Dialer»","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/browser-licensing-agreement/","text":"Лицензионное соглашение «2GIS для браузера»","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/api-rules/","text":"Правовая информация по API 2ГИС","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/requests-rules/","text":"Правила работы сервиса Получения Заявок","subnav":[{"url":"https://law.2gis.kg/requests-rules/agreement/","text":"Пользовательское соглашение","subnav":[],"mods":{},"level":4}],"mods":{},"level":3},{"url":"https://law.2gis.kg/actions-rules/","text":"Правила проведения Акций","subnav":[{"url":"https://law.2gis.kg/actions-rules/agents2020/","text":"Правила и условия проведения Акции «Конкурс Спецагентов»","subnav":[],"mods":{},"level":4},{"url":"https://law.2gis.kg/actions-rules/aviators/","text":"Правила и условия проведения Акции «Новогодние Авиаторы»","subnav":[],"mods":{},"level":4},{"url":"https://law.2gis.kg/actions-rules/promo-be-a-friend/","text":"Правила проведения Акции «Будь другом»","subnav":[],"mods":{},"level":4}],"mods":{},"level":3},{"url":"https://law.2gis.kg/agents-giveaway-rules/","text":"Правила проведения Акции в социальных сетях","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/giveaway-rules/","text":"Правила проведения Акции по добавлению Контента","subnav":[{"url":"https://law.2gis.kg/giveaway-rules/red01122020/","text":"Правила проведения Акции по добавлению Контента (утратили силу 04.10.2021г.)","subnav":[],"mods":{},"level":4}],"mods":{},"level":3},{"url":"https://law.2gis.kg/counting-clicks/","text":"Правила учета Рекламных показов","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/privacy-partner/","text":"Политика конфиденциальности Партнёра 2ГИС","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/partner-agreement/","text":"Соглашение с партнёром 2ГИС","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/partners-list/","text":"Перечень Партнёров 2ГИС","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/microsite/","text":"Соглашение об использовании Микросайта и требования к контенту для Микросайта ","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/copyright/","text":"Информация о Правообладателях","subnav":[],"mods":{},"level":3},{"url":"https://law.2gis.kg/promo-add-friends/","text":"Правила проведения Акций по добавлению друзей ","subnav":[],"mods":{},"level":3}],"mods":{"active":false,"expand":true,"expanded":true},"level":2}]}}],"initedModules":[{"elements":{"link":{},"subnavLink":{}},"slot":{"templates":{},"modules":{},"utils":{},"config":{"mainModule":"page","projectName":"infoportal","city.cookieName":"project","mapsApi.libURL":"https://maps.api.2gis.ru/2.0/loader.js?pkg=full","static.prefix":"https://hstatic.2gis.com/","schema":"https","crmEndpoint":"https://info.2gis.ru/moscow/advtilda","infoApi.host":"ayahuasca.2gis.com","monitor.url":"/novosibirsk/monitor","server.listenArgs":[3000],"server.instanceCount":1,"server.useCluster":true,"WebApi.catalogUrl":"https://catalog.api.2gis.ru/2.0/","WebApi.key":"rudxfw6016","suggestUrl":"https://catalog.api.2gis.ru/suggest","logger.app":{"filename":"./logs/app.log","json":false,"timestamp":true},"logger.leaks":{"file":{"filename":"./logs/leaks.log","json":false,"timestamp":true}},"logger.graylog":{"graylogHost":"logserver.test","graylogPort":12201,"level":"warn"},"logger.crash":{"emails":[{"email":"al.kolpakov@2gis.ru"},{"email":"d.donov@2gis.ru"}]},"addFirmHref":"https://reklama.2gis.ru/%1/add-info/?utm_source=partner_network&utm_medium=add_info&utm_campaign=%2","feedbackApi.url":"https://feedback.api.2gis.ru/","feedback.rulesUrl":"https://law.2gis.ru/rules/","feedback.editPhotoUrl":"https://2gis.ru/$photoId","feedback.advertismentHref":"https://reklama.2gis.ru/%2/partner_network/feedback?calculate_for=%1&utm_source=partner_network&utm_medium=ad_link&utm_campaign=feedback","log_channels":["debug","warn"],"projectListTTL":600000,"storeLink.android":"https://play.google.com/store/apps/details?id=ru.dublgis.dgismobile&utm_source=2gisru&utm_medium=link&utm_campaign=android","storeLink.ios":"http://itunes.apple.com/ru/app/2gis/id481627348?mt=8","storeLink.windowsphone":"http://www.windowsphone.com/ru-ru/store/app/2gis/4c2d3b4e-c1f1-439b-bf16-f8b0d829fe87","storeLink.blackberry":"http://appworld.blackberry.com/webstore/content/39967127/","debug":true,"debugRequests":false,"cityselectorJsPath":"/vendor/cityselector.js","photorJsPath":"/vendor/photor.min.js","barrelJsPath":"/vendor/jqbarrel.js","scrollToJsPath":"/vendor/jquery.scrollTo.min.js","colorBoxJsPath":"/vendor/jquery.colorbox.min.js","analyticsJsPath":"/vendor/downloadPc.js","baronJsPath":"/vendor/baron.min.js","placeholderJsPath":"/vendor/placeholder.min.js","momentJsPath":"/vendor/moment.js","momentRuJsPath":"/vendor/moment_ru.js","momentCzJsPath":"/vendor/moment_cz.js","jqueryMask":"/vendor/jquery-masked.min.js","jqueryAppear":"/vendor/jquery-appear.js","suggest.defaultCountCities":2,"suggest.defaultCountFirms":6,"suggest.defaultCountGeo":2,"suggest.defaultCountRoutes":1,"suggest.defaultCountStation":1,"suggest.countForSearchCity":3,"flags.cookieName":"flags","flags.cookieDomain":".2gis.ru","flags.list.rateUsAlreadyShow":"rateUsAlreadyShow"},"isInited":true,"isEnableShowTrack":true,"isServer":true,"isClient":false,"isGrym":false},"type":"nav"}]},{"type":["main"],"modules":[{"type":"usercontent","data":{"mods":{"rel":"law"},"title":"Лицензионное соглашение","content":"<p>Настоящий документ &laquo;Лицензионное соглашение на&nbsp;использование программных продуктов и/или онлайн-сервисов 2ГИС&raquo; представляет собой предложение Общества с&nbsp;ограниченной ответственностью &laquo;ДубльГИС&raquo; (далее&nbsp;&mdash; &laquo;Правообладатель&raquo;), заключить соглашение на&nbsp;изложенных ниже условиях.</p>\r\n<p><strong>Перед использованием программных продуктов и/или онлайн-сервисов 2ГИС, пожалуйста, ознакомьтесь с&nbsp;условиями настоящего лицензионного соглашения.</strong></p>\r\n<p><strong>1. Общие положения</strong></p>\r\n<p>1.1. Пользуясь программными продуктами и/или онлайн-сервисами 2ГИС, Вы&nbsp;соглашаетесь с&nbsp;тем, что:</p>\r\n<p>а) Вы&nbsp;ознакомились с&nbsp;условиями настоящего Соглашения в&nbsp;полном объеме до&nbsp;начала использования Программных продуктов и/или Онлайн-сервисов 2ГИС.</p>\r\n<p>б) Начало использования Вами Программных продуктов и/или Онлайн-сервисов 2ГИС в&nbsp;любой форме означает, что&nbsp;Вы принимаете все условия настоящего Соглашения в&nbsp;полном объеме без каких-либо изъятий и&nbsp;ограничений с&nbsp;Вашей стороны. Использование программных продуктов и/или Онлайн-сервисов 2ГИС на&nbsp;иных условиях не&nbsp;допускается.</p>\r\n<p>в) Если Вы&nbsp;не&nbsp;согласны с&nbsp;условиями настоящего Соглашения или не&nbsp;имеете права на&nbsp;его заключение, Вам следует незамедлительно прекратить любое использование Программных продуктов и/или Онлайн-сервисов 2ГИС.</p>\r\n<p>г) Соглашение (в&nbsp;том числе любая из&nbsp;его частей) может быть изменено Правообладателем без какого-либо специального уведомления. Новая редакция Соглашения вступает в&nbsp;силу с&nbsp;момента ее&nbsp;размещения на&nbsp;Сайте Правообладателя, если иное не&nbsp;предусмотрено новой редакцией Соглашения.</p>\r\n<p>1.2. Во&nbsp;всем, что не&nbsp;предусмотрено настоящим Соглашением, отношения в&nbsp;связи с&nbsp;использованием Онлайн-сервисов 2ГИС регулируются Соглашением об&nbsp;использовании сервисов 2ГИС (<a href=\"http://law.2gis.kz/rules/\">http://law.2gis.kg/rules/</a>), а&nbsp;также Политикой конфиденциальности (<a href=\"http://law.2gis.kz/privacy/\">http://law.2gis.kg/privacy/</a>).</p>\r\n<p>1.3. Действующая версия настоящего Соглашения доступна на&nbsp;Сайте Правообладателя по&nbsp;адресу:&nbsp;<a href=\"http://law.2gis.kz/licensing-agreement/\">http://law.2gis.kg/licensing-agreement/</a>.</p>\r\n<p>1.4. В&nbsp;случае противоречия между редакцией Соглашения, включенной в&nbsp;состав распространяемых экземпляров Программных продуктов 2ГИС, и&nbsp;последней редакцией Соглашения, размещенной на&nbsp;Сайте Правообладателя, приоритет имеет редакция Соглашения, размещенная на&nbsp;Сайте Правообладателя.</p>\r\n<p><strong>2. Определения</strong></p>\r\n<p>Используемые в&nbsp;настоящем Лицензионном соглашении слова и&nbsp;выражения имеют следующие значения, если иное прямо не&nbsp;определено далее по&nbsp;тексту:</p>\r\n<p>2.1.&nbsp;<strong>Лицензия (Соглашение)</strong>&nbsp;&mdash; настоящее Лицензионное соглашение на&nbsp;использование Программных продуктов и/или Онлайн-сервисов 2ГИС.</p>\r\n<p>2.2.&nbsp;<strong>Онлайн-сервисы 2ГИС</strong>&nbsp;&mdash; совокупность Программных продуктов 2ГИС и&nbsp;аппаратных средств Правообладателя, доступ к&nbsp;которым предоставляется Пользователям с&nbsp;использованием Сайта Правообладателя.</p>\r\n<p>2.3.&nbsp;<strong>Правообладатель</strong>&nbsp;&mdash; Общество с&nbsp;ограниченной ответственностью &laquo;ДубльГИС&raquo;, ОГРН 1045401929847, место нахождения: 630048, г. Новосибирск, пл. Карла Маркса, д.&nbsp;7, 13&nbsp;этаж.</p>\r\n<p>2.4.&nbsp;<strong>Пользователь</strong>&nbsp;&mdash; физическое лицо, действующее в своем или чужом интересе. \r\nС 14 лет Пользователь вправе самостоятельно осуществлять регистрацию в Сервисах 2ГИС, если это требуется для использования ряда функций, и пользоваться последними в пределах правоспособности, установленной законодательством. </p>\r\n<p>2.5.&nbsp;<strong>Программные продукты 2ГИС</strong>&nbsp;&mdash; принадлежащие Правообладателю программные комплексы 2ГИС, объединяющие в&nbsp;своем составе Цифровые планы и/или Справочники организаций, а&nbsp;также каждая входящая в&nbsp;их&nbsp;состав или используемая совместно с&nbsp;ними программа для ЭВМ или база данных в&nbsp;отдельности, а&nbsp;также все последующие их&nbsp;обновления и&nbsp;модификации, предназначенные для использования на&nbsp;настольных и&nbsp;карманных персональных компьютерах, мобильных телефонах, коммуникаторах, смартфонах.</p>\r\n<p>2.6.&nbsp;<strong>Справочник организаций</strong>&nbsp;&mdash; база данных электронного справочника, включающая информацию о&nbsp;наименованиях, местонахождении, телефонах, адресах электронной почты и&nbsp;сайтов, видах производимых и&nbsp;реализуемых товаров (выполняемых работ, оказываемых услуг) и&nbsp;прочие сведения об&nbsp;организациях и&nbsp;индивидуальных предпринимателях, находящихся в&nbsp;пределах определенной территории, совпадающей с&nbsp;границами совмещенного с&nbsp;ним Цифрового плана, а&nbsp;также иных организациях по&nbsp;усмотрению Правообладателя.</p>\r\n<p>2.7.&nbsp;<strong>Сайт Правообладателя</strong>&nbsp;&mdash; интернет-сайты, размещенные в&nbsp;домене по&nbsp;адресу&nbsp;<a href=\"http://2gis.kz/\">2gis.kg</a>, 2gis.com, а&nbsp;также прочих доменах, входящих в&nbsp;домен&nbsp;<a href=\"http://2gis.kz/\">2gis.kg</a>, 2gis.com.</p>\r\n<p>2.8.&nbsp;<strong>Цифровой план</strong>&nbsp;&mdash; база данных электронной карты, включающая геоинформационные данные о&nbsp;географических объектах и&nbsp;населенных пунктах в&nbsp;пределах территории, ограниченной определенными географическими координатами.</p>\r\n<p>2.9.&nbsp;<strong>Коммерческое использование</strong>&nbsp;&mdash; выходящее за&nbsp;рамки разрешенного по&nbsp;настоящему Соглашению функционального применения и/или предоставленных прав на&nbsp;использование фрагментов карт использование Программных продуктов и/или Онлайн-сервисов 2ГИС, а&nbsp;также иных Объектов интеллектуальной собственности физическим лицом в&nbsp;целях получения дохода (прибыли), а&nbsp;индивидуальным предпринимателем или организацией&nbsp;&mdash; в&nbsp;целях извлечения предпринимательской выгоды, в&nbsp;том числе их&nbsp;предоставление или обеспечение к&nbsp;ним доступа на&nbsp;возмездной основе, т.е.&nbsp;за&nbsp;плату или любое встречное предоставление товаров, работ, услуг, либо с&nbsp;одновременным предоставлением товаров, работ, услуг на&nbsp;возмездной основе в&nbsp;том или ином виде. Коммерческое использование Программных продуктов и/или Онлайн-сервисов 2ГИС, а&nbsp;также иных Объектов интеллектуальной собственности может быть разрешено Правообладателем на&nbsp;основании отдельного соглашения с&nbsp;Пользователем.</p>\r\n<p>2.10.&nbsp;<strong>Пин-код</strong>&nbsp;&mdash; уникальная последовательность цифр, генерируемая программно-аппаратными средствами Правообладателя по&nbsp;запросу Пользователя и&nbsp;предназначенная для обеспечения связи отдельных Онлайн-сервисов 2ГИС и/или Программных продуктов 2ГИС, а&nbsp;также их&nbsp;связи с&nbsp;иными программными продуктами, сервисами.</p>\r\n<p>2.11.&nbsp;<strong>Политика конфиденциальности</strong>&nbsp;&mdash; Политика конфиденциальности, размещенная в&nbsp;сети Интернет по&nbsp;адресу:&nbsp;<a href=\"http://law.2gis.kz/privacy/\">http://law.2gis.kg/privacy/</a>.</p>\r\n<p><strong>3. Исключительные права</strong></p>\r\n<p>3.1. Программные продукты и&nbsp;Онлайн-сервисы 2ГИС в&nbsp;целом и&nbsp;включаемые в&nbsp;их&nbsp;состав или используемые совместно с&nbsp;ними программы для ЭВМ, базы данных, картографические, справочно-информационные и&nbsp;прочие текстовые материалы, изображения и&nbsp;иные объекты авторских и/или смежных прав, а&nbsp;равно объекты патентных прав, товарные знаки, коммерческие обозначения и&nbsp;фирменные наименования, а&nbsp;также иные части Программных продуктов и/или Онлайн-сервисов 2ГИС (независимо от&nbsp;того, входят&nbsp;ли они в&nbsp;их&nbsp;состав или являются дополнительными компонентами, и&nbsp;возможно&nbsp;ли их&nbsp;извлечение из&nbsp;их&nbsp;состава и&nbsp;использование самостоятельно) в&nbsp;отдельности (далее&nbsp;&mdash; &laquo;Объекты интеллектуальной собственности&raquo;), защищены в&nbsp;соответствии с&nbsp;Частью IV&nbsp;Гражданского кодекса Российской Федерации принадлежат Правообладателю на&nbsp;исключительном праве, если иное не&nbsp;указано в&nbsp;уведомлении о&nbsp;правах.</p>\r\n<p>3.2. Правообладатель сохраняет исключительные права на&nbsp;любые результаты переработки (модификации) Объектов интеллектуальной собственности, допускаемые в&nbsp;соответствии с&nbsp;настоящей Лицензией, и&nbsp;вправе в&nbsp;любое время отозвать свое разрешение на&nbsp;их&nbsp;использование по&nbsp;своему усмотрению без компенсации каких-либо расходов Пользователя на&nbsp;их&nbsp;создание и&nbsp;применение.</p>\r\n<p>3.3. Уведомление о&nbsp;правах на&nbsp;Объект интеллектуальной собственности размещается на&nbsp;таком Объекте или доводится до&nbsp;сведения Пользователя при его предоставлении. Отсутствие уведомления о&nbsp;правах не&nbsp;означает отсутствие его правовой защиты или разрешение на&nbsp;его свободное использование.</p>\r\n<p><strong>4. Предоставление Лицензии</strong></p>\r\n<p>4.1. Использование Программных продуктов и/или Онлайн-сервисов 2ГИС разрешается строго на&nbsp;условиях настоящей Лицензии. Если Пользователь не&nbsp;принимает условия Лицензии в&nbsp;полном объеме, Пользователь не&nbsp;имеет права использовать Программные продукты и/или Онлайн-сервисы 2ГИС в&nbsp;каких-либо целях. Использование Программных продуктов и/или Онлайн-сервисов 2ГИС с&nbsp;нарушением (невыполнением) какого-либо из&nbsp;условий Лицензии запрещено.</p>\r\n<p>4.2. Права и&nbsp;способы использования Программных продуктов и/или Онлайн-сервисов 2ГИС, в&nbsp;явном виде не&nbsp;предоставленные/ не&nbsp;разрешенные Пользователю по&nbsp;настоящему Соглашению, считаются не&nbsp;предоставленными/ запрещенными Правообладателем.</p>\r\n<p>4.3. Использование Программных продуктов и/или Онлайн-сервисов 2ГИС на&nbsp;условиях настоящей Лицензии в&nbsp;некоммерческих целях разрешается Пользователю на&nbsp;безвозмездной основе.</p>\r\n<p>4.4. Правообладатель вправе размещать в&nbsp;Программных продуктах и/или Онлайн-сервисах 2ГИС любые информационные и/или рекламные материалы и&nbsp;ссылки на&nbsp;интернет-сайты третьих лиц, а&nbsp;также предоставлять право использования Программных продуктов и/или Онлайн-сервисов 2ГИС указанным способом третьим лицам по&nbsp;отдельному соглашению.</p>\r\n<p><strong>5. Права Пользователя</strong></p>\r\n<p>5.1. Правообладатель предоставляет Пользователю право использования Программных продуктов и/или Онлайн-сервисов 2ГИС на&nbsp;условиях простой (неисключительной) непередаваемой лицензии на&nbsp;территории всех стран мира указанными в&nbsp;настоящем разделе способами.</p>\r\n<p><strong>5.2. Функциональное использование Программных продуктов 2ГИС</strong></p>\r\n<p>Пользователь вправе применять Программные продукты 2ГИС по&nbsp;их&nbsp;прямому функциональному назначению в&nbsp;соответствии с&nbsp;Руководством Пользователя, в&nbsp;целях чего произвести их&nbsp;установку на&nbsp;настольном или карманном персональном(-ых) компьютере(-ах), смартфоне(-ах) или других устройствах (далее&nbsp;&mdash; &laquo;Устройства&raquo;).</p>\r\n<p>В&nbsp;соответствии с&nbsp;настоящим пунктом Пользователь вправе произвести установку Программных продуктов 2ГИС на&nbsp;неограниченное число Устройств, а&nbsp;также хранить или установить копии Программных продуктов на&nbsp;устройстве хранения данных (например, на&nbsp;сервере сети), предназначенном и&nbsp;используемом исключительно для установки и&nbsp;работы Программного продукта на&nbsp;других имеющихся компьютерах в&nbsp;пределах локальной сети.</p>\r\n<p><strong>5.3. Воспроизведение Программных продуктов 2ГИС</strong></p>\r\n<p>Пользователь вправе воспроизводить Программные продукты 2ГИС, экземпляры которых распространяются Правообладателем, в&nbsp;некоммерческих целях на&nbsp;безвозмездной основе на&nbsp;любых Устройствах и&nbsp;прочих видах материальных носителей при условии сохранения в&nbsp;неизменном виде комбинации, состава и&nbsp;содержания Программных продуктов 2ГИС по&nbsp;сравнению с&nbsp;тем, как они предоставляются и/или рекомендуются для использования Правообладателем.</p>\r\n<p><strong>5.4. Распространение Программных продуктов 2ГИС</strong></p>\r\n<p>Пользователь вправе распространять Программные продукты 2ГИС посредством передачи их&nbsp;экземпляров, воспроизведенных в&nbsp;соответствии с&nbsp;пунктом 4.3 настоящего Соглашения, в&nbsp;некоммерческих целях на&nbsp;безвозмездной основе и&nbsp;при соблюдении их&nbsp;целостности, если иное не&nbsp;предусмотрено письменным разрешением Правообладателя.</p>\r\n<p><strong>5.5. Функциональное использование Онлайн-сервисов 2ГИС</strong></p>\r\n<p>Пользователь вправе использовать Онлайн-сервисы 2ГИС по&nbsp;прямому функциональному назначению на&nbsp;неограниченном числе Устройств в&nbsp;соответствии с&nbsp;условиями настоящей Лицензии. По&nbsp;усмотрению Правообладателя для использования некоторых Онлайн-сервисов 2ГИС или их&nbsp;дополнительных функциональных возможностей может потребоваться принятие Пользователем условий отдельного соглашения.</p>\r\n<p><strong>5.6. Использование в&nbsp;сети Интернет ссылок на&nbsp;фрагменты карт с&nbsp;Онлайн-сервисов 2ГИС</strong></p>\r\n<p>Пользователь вправе использовать html-ссылки на&nbsp;фрагменты карт с&nbsp;использованием Онлайн-сервиса 2ГИС на&nbsp;указанных ниже условиях.</p>\r\n<p>Чтобы показать расположение нужного здания, достаточно поставить специальную ссылку на&nbsp;Цифровой план из&nbsp;Онлайн-сервиса 2ГИС следующего вида:</p>\r\n<div class=\"grey-back\">&lt;a href=\"<strong>{Адрес ссылки на \r\nфрагмент}</strong>\" target=\"_blank\" title=\"2gis.ru \r\n&mdash; Городской информационный сервис\"&gt;<strong>{Текст ссылки, обычно это \r\nадрес}</strong>&lt;/a&gt;</div>\r\n<p>Чтобы узнать адрес ссылки на&nbsp;фрагмент Цифрового плана, необходимо:</p>\r\n<ol>\r\n<li><a href=\"https://law.2gis.kg/licensing-agreement/\">Зайти на&nbsp;Сайт Правообладателя&nbsp;</a><a href=\"http://2gis.kz/\">2gis.kg</a>.</li>\r\n<li>Выбрать нужное здание (при этом на&nbsp;карте появится карточка с&nbsp;адресом здания).</li>\r\n<li>Кликнуть по&nbsp;тексту &laquo;Ссылка на&nbsp;это место&raquo;, расположенному в&nbsp;правом углу над картой. Под курсором появится окошко с&nbsp;адресом ссылки на&nbsp;выбранный фрагмент.</li>\r\n</ol>\r\n<p>По&nbsp;ссылке будет открываться в&nbsp;точности тот&nbsp;же самый фрагмент, который был выбран в&nbsp;момент клика по&nbsp;тексту &laquo;Ссылка на&nbsp;это место&raquo;. Для удобства пользователей в&nbsp;Онлайн-сервисе 2ГИС предусмотрены: навигация по&nbsp;карте, просмотр ближайших остановок, информации о&nbsp;фирмах в&nbsp;зданиях.</p>\r\n<p>Использование ссылок на&nbsp;Онлайн-сервис 2ГИС является наиболее простым и&nbsp;оперативным вариантом его использования и&nbsp;поэтому рекомендуется для сайтов с&nbsp;большим количеством адресов (каталоги компаний, новостроек и&nbsp;т.п.). Онлайн-сервис 2ГИС обновляется ежемесячно.</p>\r\n<p><strong>5.7. Использование в&nbsp;сети Интернет фрагментов карт из&nbsp;Программных продуктов и/или Онлайн-сервисов 2ГИС</strong></p>\r\n<p>Пользователь вправе создавать фрагменты карт из&nbsp;Цифровых планов городов путем копирования визуального отображения картографических данных, порождаемого Программными продуктами и/или Онлайн-сервисами 2ГИС, а&nbsp;также производные таких фрагментов карт (с&nbsp;дополнениями, сокращениями, изменением угла поворота и&nbsp;прочими переработками) и&nbsp;доводить их&nbsp;до&nbsp;всеобщего сведения в&nbsp;сети Интернет при условии наличия подписи к&nbsp;каждому из&nbsp;фрагментов с&nbsp;указанием источника заимствования и&nbsp;активной ссылки на&nbsp;сайт&nbsp;<a href=\"http://2gis.kz/\">www.2gis.kg</a>&nbsp;приведенного ниже вида:</p>\r\n<p><a title=\"Программа 2ГИС &mdash; Городской Информационный Справочник. Скачивайте бесплатно!\" target=\"_blank\" href=\"http://www.2gis.kg\">&copy;&nbsp;2ГИС&nbsp;&mdash; Городской Информационный Справочник</a></p>\r\n<p><strong>5.8. Использование в&nbsp;СМИ, полиграфии и&nbsp;наружной рекламе фрагментов карт из&nbsp;Программных продуктов и/или Онлайн-сервисов 2ГИС</strong></p>\r\n<p>Пользователь вправе воспроизводить фрагменты карт путем копирования визуального отображения картографических данных, порождаемого Программными продуктами и/или Онлайн-сервисами 2ГИС, а&nbsp;также производные таких фрагментов карт (с&nbsp;дополнениями, сокращениями, изменением угла поворота и&nbsp;прочими переработками) в&nbsp;периодических печатных изданиях, полиграфии, наружной рекламе и&nbsp;прочих печатных и&nbsp;электронных изданиях, при условии наличия подписи к&nbsp;каждому из&nbsp;фрагментов приведенного ниже вида:</p>\r\n<div class=\"grey-back\"><strong>&copy;&nbsp;2ГИС. Городской\r\nинформационный сервис. <br /><a href=\"http://www.2gis.kg\">www.2gis.kg</a></strong></div>\r\n<p>Размер шрифта, используемого для подписи фрагментов карт в&nbsp;печатных изданиях и&nbsp;полиграфии, должен составлять не&nbsp;менее 5&nbsp;pt, в&nbsp;наружной рекламе&nbsp;&mdash; не&nbsp;менее&nbsp;2% от&nbsp;площади макета.</p>\r\n<p>5.9. Использование Программных продуктов и/или Онлайн-сервисов 2ГИС указанными в&nbsp;пунктах 4.7-4.8 Соглашения способами допускается при одновременном соблюдении следующих условий:</p>\r\n<p>а) дальнейшее использование фрагментов карт возможно только в&nbsp;информационных целях (например, для показа места расположения или схемы проезда к&nbsp;определенному объекту);</p>\r\n<p>б) объем использования картографических материалов (площадь фрагмента карты) оправдана вышеуказанными информационными целями.</p>\r\n<p>5.10. Чтобы воспользоваться возможностью обеспечения связи отдельных Программных продуктов и/или Онлайн-сервисов 2ГИС, в&nbsp;том числе их&nbsp;связи с&nbsp;иными программными продуктами, сервисами, Пользователю необходимо ввести полученный от&nbsp;Правообладателя пин-код.</p>\r\n<p>5.11. Право использования Программных продуктов и/или Онлайн-сервисов 2ГИС в&nbsp;соответствии с&nbsp;настоящим разделом предоставляется при условии соблюдения Пользователем ограничений, установленных настоящим Соглашением.</p>\r\n<p><strong>6. Ограничения использования (Объем разрешенного использования)</strong></p>\r\n<p>6.1. Пользователь не&nbsp;имеет права самостоятельно или с&nbsp;привлечением третьих лиц:</p>\r\n<p>6.1.1. Вскрывать технологию, эмулировать, создавать новые версии, изменять, декомпилировать, дизассемблировать, дешифровать и&nbsp;производить иные действия с&nbsp;кодом Программных продуктов и/или Онлайн-сервисов 2ГИС, имеющие целью нарушение системы защиты Программных продуктов и/или Онлайн-сервисов 2ГИС от&nbsp;несанкционированного использования, извлечение картографических материалов, справочно-информационных и&nbsp;прочих материалов из&nbsp;баз данных, а&nbsp;также получение информации о&nbsp;реализации алгоритмов, используемых в&nbsp;Программных продуктах и/или Онлайн-сервисах 2ГИС.</p>\r\n<p>6.1.2. Создавать программные или справочно-информационные продукты и/или сервисы с&nbsp;использованием Программных продуктов и/или Онлайн-сервисов 2ГИС, а&nbsp;также включаемых в&nbsp;их&nbsp;состав баз данных или извлеченных (извлекаемых) из&nbsp;них текстовых, картографических и&nbsp;справочно-информационных материалов, а&nbsp;равно иных Объектов интеллектуальной собственности, указанных в&nbsp;пункте 2.1 настоящего Соглашения.</p>\r\n<p>6.1.3. Воспроизводить и&nbsp;распространять Программные продукты 2ГИС в&nbsp;коммерческих целях без письменного согласия Правообладателя.</p>\r\n<p>6.1.4. Извлекать из&nbsp;баз данных, включаемых в&nbsp;состав Программных продуктов 2ГИС, любые картографические, справочно-информационные и&nbsp;прочие материалы и&nbsp;осуществлять их&nbsp;последующее использование в&nbsp;любой форме и&nbsp;любым способом.</p>\r\n<p>6.1.5. Использовать базы данных, входящие в&nbsp;состав Программных продуктов 2ГИС, отдельно от&nbsp;таких Программных продуктов 2ГИС.</p>\r\n<p>6.1.6. Обеспечивать доступ к&nbsp;Онлайн-сервисам 2ГИС в&nbsp;коммерческих целях, в&nbsp;том числе путем трансляции из&nbsp;них данных любыми способами, включая использование фреймов и&nbsp;прочих программных методов и&nbsp;способов, обеспечивающих получение данных с&nbsp;Онлайн-сервиса 2ГИС и&nbsp;их&nbsp;представление на&nbsp;сайте третьих лиц, если иное не&nbsp;предусмотрено отдельным соглашением с&nbsp;Правообладателем.</p>\r\n<p>6.1.7. Удалять или любым способом изменять товарные знаки, промышленные образцы и&nbsp;уведомления об&nbsp;авторских и&nbsp;любых иных правах, включенные в&nbsp;Программные продукты и/или Онлайн-сервисы 2ГИС, а&nbsp;также наложенные на&nbsp;Цифровые планы и&nbsp;прочие картографические материалы.<br /><br />6.1.8. Применять при использовании Программных продуктов и/или Онлайн-сервисов 2ГИС&nbsp;стороннее программное обеспечение.</p>\r\n<p>6.2. Во&nbsp;избежание сомнений ЗАПРЕЩАЕТСЯ копирование, воспроизведение, переработка, распространение, доведение до&nbsp;всеобщего сведения (размещение в&nbsp;свободном доступе (опубликование) в&nbsp;сети Интернет), использование в&nbsp;средствах массовой информации и/или коммерческое использование картографических материалов и&nbsp;справочно-информационных материалов, как прямо извлеченных из&nbsp;баз данных, включаемых в&nbsp;состав Программных продуктов и/или Онлайн-сервисов 2ГИС, так и&nbsp;полученных путем копирования результатов обработки данных с&nbsp;использованием Программных продуктов и/или Онлайн-сервисов 2ГИС, а&nbsp;также производных от&nbsp;таких материалов продуктов (с&nbsp;дополнениями, сокращениями и&nbsp;прочими переработками), за&nbsp;исключением случаев, прямо предусмотренных настоящей Лицензией.</p>\r\n<p><strong>7. Автоматические обновления</strong></p>\r\n<p>7.1. Периодически Программные продукты 2ГИС могут взаимодействовать с&nbsp;программно-аппаратными средствами Правообладателя для проверки наличия обновлений Программных продуктов 2ГИС, как то&nbsp;модификаций Программных продуктов 2ГИС, дополнительных модулей к&nbsp;ним, а&nbsp;также обновлений баз данных по&nbsp;городам (далее &laquo;Обновления&raquo;).</p>\r\n<p>7.2. Устанавливая Программные продукты 2ГИС, Пользователь соглашается на&nbsp;возможность осуществления ими запросов, а&nbsp;также получение и&nbsp;установку Обновлений в&nbsp;автоматическом режиме.</p>\r\n<p><strong>8. Политика конфиденциальности</strong></p>\r\n<p>8.1. От&nbsp;Пользователя не&nbsp;требуется предоставление персональных данных для использования Программных продуктов и/или Онлайн-сервисов 2ГИС, если иное прямо не&nbsp;предусмотрено отдельным соглашением на&nbsp;использование таких Программных продуктов и/или Онлайн-сервисов 2ГИС.</p>\r\n<p>8.2. Порядок обработки и&nbsp;защиты информации о&nbsp;Пользователях, полученной Правообладателем в&nbsp;связи с&nbsp;использованием Пользователями Программных продуктов и/или Онлайн-сервисов 2ГИС определяется Политикой конфиденциальности с&nbsp;учетом особенностей, установленных настоящим Соглашением и&nbsp;соглашениями об&nbsp;использовании отдельных Программных продуктов и/или Онлайн-сервисов 2ГИС.</p>\r\n<p><strong>9. Ответственность по&nbsp;Лицензии</strong></p>\r\n<p>9.1. Ввиду предоставления в&nbsp;рамках Лицензии права использования Программных продуктов и/или Онлайн-сервисов 2ГИС в&nbsp;некоммерческих целях на&nbsp;безвозмездной основе к&nbsp;отношениям сторон по&nbsp;Лицензии не&nbsp;применимы положения законодательства о&nbsp;защите прав потребителей.</p>\r\n<p>9.2. Программные продукты и/или Онлайн-сервисы 2ГИС предоставляются на&nbsp;условиях &laquo;как есть&raquo;, в&nbsp;связи с&nbsp;чем Пользователю не&nbsp;представляются какие-либо гарантии, что: они будут соответствовать требованиям Пользователя; предоставляться непрерывно, быстро, надежно и&nbsp;без ошибок; результаты, которые могут быть получены с&nbsp;их&nbsp;использованием, будут точными и&nbsp;надежными; все ошибки будут исправлены.</p>\r\n<p>9.3. Правообладатель прилагает все усилия к&nbsp;тому, чтобы информация, размещённая в&nbsp;справочнике и&nbsp;на&nbsp;карте, была точной, однако Правообладатель не&nbsp;даёт никакой гарантии в&nbsp;отношении точности такой информации и&nbsp;не&nbsp;несёт за&nbsp;это ответственности. Использование каких-либо материалов и&nbsp;данных из&nbsp;состава Программных продуктов и/или Онлайн-сервисов 2ГИС относится исключительно на&nbsp;риск Пользователя, Правообладатель не&nbsp;будет нести ответственности за&nbsp;какую-либо потерю прибыли или иной ущерб, произошедший в&nbsp;результате использования Программных продуктов и/или Онлайн-сервисов 2ГИС.</p>\r\n<p>9.4. Все информационные и/или рекламные материалы, размещаемые в&nbsp;Программных продуктах и/или Онлайн-сервисах 2ГИС, предоставлены третьими лицами. Правообладатель не&nbsp;несет ответственности за&nbsp;достоверность информационных и/или рекламных материалов третьих лиц, доступность их&nbsp;интернет-сайтов и&nbsp;их&nbsp;содержание, а&nbsp;также за&nbsp;любые последствия, связанные с&nbsp;использованием информации и/или рекламы, а&nbsp;также интернет-сайтов третьих лиц.</p>\r\n<p>9.5. Поскольку Программные продукты и/или Онлайн-сервисы 2ГИС находятся на&nbsp;стадии постоянного дополнения и&nbsp;обновления новых функциональных возможностей, форма и&nbsp;характер продуктов и&nbsp;предоставляемых услуг могут время от&nbsp;времени меняться без предварительного уведомления Пользователя. Правообладатель вправе по&nbsp;собственному усмотрению прекратить (временно или окончательно) предоставление Программных продуктов и/или Онлайн-сервисов 2ГИС (или каких-либо отдельных частей продуктов или функций сервисов) всем Пользователям вообще или отдельному Пользователю в&nbsp;частности, а&nbsp;также изменить или отозвать Лицензию без предварительного уведомления.</p>\r\n<p>9.6. Пользователь несет ответственность за&nbsp;любое нарушение обязательств, установленных настоящим Соглашением&nbsp;и (или) применимым правом, а&nbsp;также за&nbsp;все последствия таких нарушений (включая любые убытки, которые может понести Правообладатель и&nbsp;иные третьи лица).</p>\r\n<p>9.7. Правообладатель оставляет за&nbsp;собой право преследования нарушителей исключительных прав на&nbsp;Объекты интеллектуальной собственности в&nbsp;соответствии с&nbsp;гражданским, административным и&nbsp;уголовным законодательством по&nbsp;своему усмотрению.</p>\r\n<p><strong>10. Применимое право и&nbsp;арбитраж</strong></p>\r\n<p>10.1. Настоящее Соглашение, порядок его заключения и&nbsp;исполнения, а&nbsp;также вопросы, не&nbsp;урегулированные настоящим Соглашением, регулируются действующим законодательством Российской Федерации.</p>\r\n<p>10.2. В&nbsp;случае любого спора, возникающего между сторонами из&nbsp;настоящего Соглашения или в&nbsp;связи с&nbsp;ним, в&nbsp;том числе в&nbsp;связи с&nbsp;толкованием, исполнением, нарушением, прекращением или недействительностью настоящего Соглашения, Стороны должны сначала попытаться разрешить его путем дружественных переговоров.</p>\r\n<p>10.3. Все споры по&nbsp;Соглашению или в&nbsp;связи с&nbsp;ним подлежат рассмотрению в&nbsp;суде по&nbsp;месту нахождения Правообладателя в&nbsp;соответствии с&nbsp;действующим процессуальным правом Российской Федерации.</p>\r\n<p><strong>11. Право Правообладателя на&nbsp;прекращение Соглашения</strong></p>\r\n<p>Настоящее соглашение может быть изменено или прекращено Правообладателем в&nbsp;одностороннем порядке без предварительного уведомления Пользователя и&nbsp;без выплаты какой-либо компенсации в&nbsp;связи с&nbsp;этим, без ущерба для любых иных прав и&nbsp;средств защиты Правообладателя и&nbsp;без ответственности перед Пользователем за&nbsp;любые убытки и&nbsp;ущерб, которые могут быть ему причинены</p>\r\n<p><strong>12. Обязанности после прекращения Соглашения</strong></p>\r\n<p>12.1. После прекращения лицензии по&nbsp;любой причине право Пользователя использовать Программные продукты и/или Онлайн-сервисы 2ГИС автоматически прекращается, и&nbsp;Пользователь обязан немедленно прекратить использование таких сервисов и&nbsp;удалить, уничтожить Программные продукты 2ГИС, находящиеся во&nbsp;владении или под контролем Пользователя, или иным образом на&nbsp;постоянной основе исключить возможность их&nbsp;использования, если применимо.</p>\r\n<p>12.2. Прекращение использования Программных продуктов и/или Онлайн-сервисов 2ГИС, вызванное любыми причинами, не&nbsp;влияет на&nbsp;права стороны по&nbsp;настоящему Соглашению, возникшие до&nbsp;даты прекращения.</p>\r\n<p><strong>13. Форс-мажор</strong></p>\r\n<p>Ни&nbsp;одна из&nbsp;сторон не&nbsp;несет ответственность за&nbsp;любые неисполнение или несвоевременное исполнение обязательств по&nbsp;настоящему Соглашению, вызванное причинами, находящимися вне ее&nbsp;разумного контроля. Такое неисполнение или несвоевременное исполнение не&nbsp;будет являться нарушением настоящего Соглашения, и&nbsp;срок исполнения соответствующих обязательств увеличивается на&nbsp;обоснованный период времени.</p>\r\n<p><strong>14. Делимость</strong></p>\r\n<p>Если любая часть настоящего Соглашения признана судом компетентной юрисдикции или иной компетентной инстанции или арбитром недействительной, незаконной или не&nbsp;обеспеченной правовой санкцией, такая часть будет отделена от&nbsp;остальных условий Соглашения, которые остаются действительными и&nbsp;обеспеченными правовой санкцией в&nbsp;максимальной степени, допустимой законом.</p>\r\n<p><strong>15. Отказ от&nbsp;прав</strong></p>\r\n<p>Неиспользование или просрочка использования любой из&nbsp;сторон своих прав, полномочий или средств защиты по&nbsp;настоящему Соглашению не&nbsp;является отказом от&nbsp;таких прав, и&nbsp;одноразовое или частичное использование таких прав, полномочий или средств защиты не&nbsp;препятствует иному или дальнейшему их&nbsp;использованию. Отказ от&nbsp;права должен быть оформлен письменно. Средства защиты, предоставляемые по&nbsp;настоящему Соглашению, носят кумулятивный характер и&nbsp;не&nbsp;исключают применения средств защиты, предоставляемых по&nbsp;закону.</p>\r\n<p><strong>16. Заголовки</strong></p>\r\n<p>Заголовки в&nbsp;настоящем Соглашении используются исключительно для удобства и&nbsp;не&nbsp;учитываются при толковании положений Соглашения.</p>\r\n<p><strong>17. Уведомление о&nbsp;правах</strong></p>\r\n<p>17.1. Настоящий раздел содержит лицензии и&nbsp;уведомления для программного обеспечения с&nbsp;открытым исходным кодом встроенного в&nbsp;Программный продукт 2ГИС версии 4.0 для рабочего стола (далее &laquo;2ГИС Desktop&nbsp;4.0&raquo;). 2ГИС Desktop&nbsp;4.0 включает в&nbsp;себя различное программное обеспечение с&nbsp;открытым исходным кодом (&laquo;Компоненты программного обеспечения&raquo;), которое лицензируется в&nbsp;соответствии с&nbsp;лицензиями на&nbsp;программное обеспечение с&nbsp;открытым исходным кодом. Лицензионные соглашения для каждого Компонента программного обеспечения сопровождают файлы Компонента программного обеспечения и&nbsp;предоставляют права использовать, копировать, модифицировать и&nbsp;распространять Компоненты программного обеспечения (при условии соблюдения определенных обязательств в&nbsp;установленных случаях), и&nbsp;в&nbsp;форме исходного кода и&nbsp;двоичного кода, за&nbsp;исключениями определяемыми соответствующей лицензией ниже.</p>\r\n<p>17.2. Об&nbsp;авторских правах</p>\r\n<p>Материалы, содержащиеся в&nbsp;2ГИС Desktop&nbsp;4.0, являются охраняемыми авторским правом. Законы об&nbsp;авторских правах запрещают копирование, воспроизведение, использование и&nbsp;распространение данных, логотипов, графических изображений, иллюстраций, дизайна продукта и&nbsp;связанных с&nbsp;ним документов (руководства, официальные документы, таблицы и&nbsp;т.д.) в&nbsp;целом или частично без разрешения правообладателя авторских прав.</p>\r\n<p>Логотипы Boost, GNU Crypto, Tukaani, JSON, SQLite, Tinyxml, Zlib, Snappy, Qt&nbsp;являются зарегистрированными товарными знаками и&nbsp;охраняемой авторским правом собственностью их&nbsp;правообладателей.</p>\r\n<p>Включенные в&nbsp;2ГИС Desktop&nbsp;4.0&nbsp;тексты, графика, изображения и&nbsp;обозначения продуктов являются собственностью соответствующих авторов данных элементов.</p>\r\n<p>17.3. О&nbsp;программном обеспечении</p>\r\n<p>Законы об&nbsp;авторских правах запрещают использование, копирование, сдачу в&nbsp;аренду, изменения и&nbsp;распространения программного обеспечения полностью или частично, без разрешения правообладателя авторских прав.</p>\r\n<p>Использование 2ГИС Desktop&nbsp;4.0&nbsp;на условиях соответствующих лицензионных соглашений не&nbsp;означает передачу Пользователям никаких имущественных или неимущественных прав на&nbsp;использование Компонентов программного обеспечения. Данные права предоставляются Пользователям соответствующими лицензиями на&nbsp;Компоненты программного обеспечения.</p>\r\n<p>Перечень Компонентов программного обеспечения:</p>\r\n<p>a) Boost</p>\r\n<div class=\"accordion\">\r\n<div class=\"accordion__item\">\r\n<input id=\"a\" class=\"accordion__input\" name=\"a\" type=\"checkbox\" /> <label class=\"accordion__label\" for=\"a\">Предоставляется на&nbsp;условиях Boost Software License, Version&nbsp;1.0 от&nbsp;17&nbsp;августа 2003&nbsp;года.</label>\r\n<div class=\"accordion__content\">\r\n<p><a target=\"_blank\" href=\"http://www.boost.org/LICENSE_1_0.txt\">http://www.boost.org/LICENSE_1_0.txt</a></p>\r\n<p>Permission is&nbsp;hereby granted, free of&nbsp;charge, to&nbsp;any person or&nbsp;organization obtaining a&nbsp;copy of&nbsp;the software and accompanying documentation covered by&nbsp;this license (the &laquo;Software&raquo;) to&nbsp;use, reproduce, display, distribute, execute, and transmit the Software, and to&nbsp;prepare derivative works of&nbsp;the Software, and to&nbsp;permit third-parties to&nbsp;whom the Software is&nbsp;furnished to&nbsp;do&nbsp;so, all subject to&nbsp;the following:</p>\r\n<p>THE SOFTWARE IS&nbsp;PROVIDED &laquo;AS&nbsp;IS&raquo;, WITHOUT WARRANTY OF&nbsp;ANY KIND, EXPRESS OR&nbsp;IMPLIED, INCLUDING BUT NOT LIMITED TO&nbsp;THE WARRANTIES OF&nbsp;MERCHANTABILITY, FITNESS FOR A&nbsp;PARTICULAR PURPOSE, TITLE AND NON-INFRINGEMENT. IN&nbsp;NO&nbsp;EVENT SHALL&nbsp;THE COPYRIGHT HOLDERS OR&nbsp;ANYONE DISTRIBUTING THE SOFTWARE BE&nbsp;LIABLE FOR ANY DAMAGES OR&nbsp;OTHER LIABILITY, WHETHER IN&nbsp;CONTRACT, TORT OR&nbsp;OTHERWISE, ARISING FROM, OUT OF&nbsp;OR&nbsp;IN&nbsp;CONNECTION WITH THE SOFTWARE OR&nbsp;THE USE OR&nbsp;OTHER DEALINGS IN&nbsp;THE SOFTWARE.</p>\r\n</div>\r\n</div>\r\n</div>\r\n<p>b) Cryptopp</p>\r\n<div class=\"accordion\">\r\n<div class=\"accordion__item\">\r\n<input id=\"a\" class=\"accordion__input\" name=\"a\" type=\"checkbox\" /> <label class=\"accordion__label\" for=\"a\">Сборник Crypto++ Library предоставляется на&nbsp;условиях Boost Software License&nbsp;1.0</label>\r\n<div class=\"accordion__content\">\r\n<p><a target=\"_blank\" href=\"http://www.boost.org/users/license.html\">http://www.boost.org/users/license.html</a> </p>\r\n<p>Permission is&nbsp;hereby granted, free of&nbsp;charge, to&nbsp;any person or&nbsp;organization obtaining a&nbsp;copy of&nbsp;the software and accompanying documentation covered by&nbsp;this license (the &laquo;Software&raquo;) to&nbsp;use, reproduce, display, distribute, execute, and transmit the Software, and to&nbsp;prepare derivative works of&nbsp;the Software, and to&nbsp;permit third-parties to&nbsp;whom the Software is&nbsp;furnished to&nbsp;do&nbsp;so, all subject to&nbsp;the following:</p>\r\n<p>THE SOFTWARE IS&nbsp;PROVIDED &laquo;AS&nbsp;IS&raquo;, WITHOUT WARRANTY OF&nbsp;ANY KIND, EXPRESS OR&nbsp;IMPLIED, INCLUDING BUT NOT LIMITED TO&nbsp;THE WARRANTIES OF&nbsp;MERCHANTABILITY, FITNESS FOR A&nbsp;PARTICULAR PURPOSE, TITLE AND NON-INFRINGEMENT. IN&nbsp;NO&nbsp;EVENT SHALL&nbsp;THE COPYRIGHT HOLDERS OR&nbsp;ANYONE DISTRIBUTING THE SOFTWARE BE&nbsp;LIABLE FOR ANY DAMAGES OR&nbsp;OTHER LIABILITY, WHETHER IN&nbsp;CONTRACT, TORT OR&nbsp;OTHERWISE, ARISING FROM, OUT OF&nbsp;OR&nbsp;IN&nbsp;CONNECTION WITH THE SOFTWARE OR&nbsp;THE USE OR&nbsp;OTHER DEALINGS IN&nbsp;THE SOFTWARE.</p>\r\n</div>\r\n</div>\r\n</div>\r\n<p>c) Lzma</p>\r\n<p>LZMA SDK</p>\r\n<p>LZMA SDK было написано и&nbsp;передано в&nbsp;общественную собственность Игорем Павловым.</p>\r\n<p><br />d) Jsoncpp</p>\r\n<div class=\"accordion\">\r\n<div class=\"accordion__item\">\r\n<input id=\"a\" class=\"accordion__input\" name=\"a\" type=\"checkbox\" /> <label class=\"accordion__label\" for=\"a\">Копирайт 2007-2010 Baptiste Lepilleur</label>\r\n<div class=\"accordion__content\">\r\n<p><a target=\"_blank\" href=\"http://jsoncpp.sourceforge.net/LICENSE%20\">http://jsoncpp.sourceforge.net/LICENSE </a></p>\r\n<p>Permission is&nbsp;hereby granted, free of&nbsp;charge, to&nbsp;any person obtaining a&nbsp;copy of&nbsp;this software and associated documentation files (the &laquo;Software&raquo;), to&nbsp;deal in&nbsp;the Software without restriction, including without limitation the rights to&nbsp;use, copy, modify, merge, publish, distribute, sublicense, and/or sell copies of&nbsp;the Software, and to&nbsp;permit persons to&nbsp;whom the Software is&nbsp;furnished to&nbsp;do&nbsp;so, subject to&nbsp;the following conditions:</p>\r\n<p>THE SOFTWARE IS&nbsp;PROVIDED &laquo;AS&nbsp;IS&raquo;, WITHOUT WARRANTY OF&nbsp;ANY KIND, EXPRESS OR&nbsp;IMPLIED, INCLUDING BUT NOT LIMITED TO&nbsp;THE WARRANTIES OF&nbsp;MERCHANTABILITY, FITNESS FOR A&nbsp;PARTICULAR PURPOSE AND NONINFRINGEMENT. IN&nbsp;NO&nbsp;EVENT SHALL&nbsp;THE AUTHORS OR&nbsp;COPYRIGHT HOLDERS BE&nbsp;LIABLE FOR ANY CLAIM, DAMAGES OR&nbsp;OTHER LIABILITY, WHETHER IN&nbsp;AN&nbsp;ACTION OF&nbsp;CONTRACT, TORT OR&nbsp;OTHERWISE, ARISING FROM, OUT OF&nbsp;OR&nbsp;IN&nbsp;CONNECTION WITH THE SOFTWARE OR&nbsp;THE USE OR&nbsp;OTHER DEALINGS IN&nbsp;THE SOFTWARE.</p>\r\n</div>\r\n</div>\r\n</div>\r\n<p>e) sqlite</p>\r\n<div class=\"accordion\">\r\n<div class=\"accordion__item\">\r\n<input id=\"a\" class=\"accordion__input\" name=\"a\" type=\"checkbox\" /> <label class=\"accordion__label\" for=\"a\">15&nbsp;сентября 2001 года</label>\r\n<div class=\"accordion__content\">\r\n<p> Автор отказывается от&nbsp;авторских прав на&nbsp;этот исходный код.</p>\r\n<p>In&nbsp;place of&nbsp;a&nbsp;legal notice, here is&nbsp;a&nbsp;blessing:</p>\r\n<p>May you do&nbsp;good and not evil.<br /><br />May you find forgiveness for yourself and forgive others.<br /><br />May you share freely, never taking more than you give.</p>\r\n</div>\r\n</div>\r\n</div>\r\n<p>f) Zlib</p>\r\n<div class=\"accordion\">\r\n<div class=\"accordion__item\">\r\n<input id=\"a\" class=\"accordion__input\" name=\"a\" type=\"checkbox\" /> <label class=\"accordion__label\" for=\"a\">Копирайт 1995-2004 Jean-loup Gailly and Mark Adler</label>\r\n<div class=\"accordion__content\">\r\n<p><a target=\"_blank\" href=\"http://www.gzip.org/zlib/zlib_license.html\">http://www.gzip.org/zlib/zlib_license.html</a></p>\r\n<p>This software is&nbsp;provided &rsquo;as-is&rsquo;, without any express or&nbsp;implied warranty. In&nbsp;no&nbsp;event will the authors be&nbsp;held liable for any damages arising from the use of&nbsp;this software.</p>\r\n<p>Permission is&nbsp;granted to&nbsp;anyone to&nbsp;use this software for any purpose, including commercial applications, and to&nbsp;alter it&nbsp;and redistribute it&nbsp;freely, subject to&nbsp;the following restrictions:<br /><br />1. The origin of&nbsp;this software must not be&nbsp;misrepresented; you must not claim that you wrote the original software. If&nbsp;you use this software in&nbsp;a&nbsp;product, an&nbsp;acknowledgment in&nbsp;the product documentation would be&nbsp;appreciated but is&nbsp;not required.<br /><br />2. Altered source versions must be&nbsp;plainly marked as&nbsp;such, and must not be&nbsp;misrepresented as&nbsp;being the original software.<br /><br />3. This notice may not be&nbsp;removed or&nbsp;altered from any source distribution.</p>\r\n</div>\r\n</div>\r\n</div>\r\n<p>g) TinyXML-2</p>\r\n<div class=\"accordion\">\r\n<div class=\"accordion__item\">\r\n<input id=\"a\" class=\"accordion__input\" name=\"a\" type=\"checkbox\" /> <label class=\"accordion__label\" for=\"a\">Копирайт 2000-2006 Lee Thomson</label>\r\n<div class=\"accordion__content\">\r\n<p><a target=\"_blank\" href=\"http://www.grinninglizard.com\">www.grinninglizard.com</a></p>\r\n<p>This software is&nbsp;provided &rsquo;as-is&rsquo;, without any express or&nbsp;implied warranty. In&nbsp;no&nbsp;event will the authors be&nbsp;held liable for any damages arising from the use of&nbsp;this software.</p>\r\n<p>Permission is&nbsp;granted to&nbsp;anyone to&nbsp;use this software for any purpose, including commercial applications, and to&nbsp;alter it&nbsp;and redistribute it&nbsp;freely, subject to&nbsp;the following restrictions:<br /><br />1. The origin of&nbsp;this software must not be&nbsp;misrepresented; you must not claim that you wrote the original software. If&nbsp;you use this software in&nbsp;a&nbsp;product, an&nbsp;acknowledgment in&nbsp;the product documentation would be&nbsp;appreciated but is&nbsp;not required.<br /><br />2. Altered source versions must be&nbsp;plainly marked as&nbsp;such, and must not be&nbsp;misrepresented as&nbsp;being the original software.<br /><br />3. This notice may not be&nbsp;removed or&nbsp;altered from any source distribution.</p>\r\n</div>\r\n</div>\r\n</div>\r\n<p>h) snappy</p>\r\n<div class=\"accordion\">\r\n<div class=\"accordion__item\">\r\n<input id=\"a\" class=\"accordion__input\" name=\"a\" type=\"checkbox\" /> <label class=\"accordion__label\" for=\"a\">Копирайт 2011, Google Inc. Все права охраняются законом.</label>\r\n<div class=\"accordion__content\">\r\n<p>Redistribution and use in&nbsp;source and binary forms, with or&nbsp;without modification, are permitted provided that the following conditions are met:</p>\r\n<p>* Redistributions of&nbsp;source code must retain the above copyright notice, this list of&nbsp;conditions and the following disclaimer.<br /><br />* Redistributions in&nbsp;binary form must reproduce the above copyright notice, this list of&nbsp;conditions and the following disclaimer in&nbsp;the documentation and/or other materials provided with the distribution.<br /><br />* Neither the name of&nbsp;Google Inc. nor the names of&nbsp;its contributors may be&nbsp;used to&nbsp;endorse or&nbsp;promote products derived from this software without specific prior written permission.<br /><br />THIS SOFTWARE IS&nbsp;PROVIDED BY&nbsp;THE COPYRIGHT HOLDERS AND CONTRIBUTORS &laquo;AS&nbsp;IS&raquo; AND ANY EXPRESS OR&nbsp;IMPLIED WARRANTIES, INCLUDING, BUT NOT LIMITED TO, THE IMPLIED WARRANTIES OF&nbsp;MERCHANTABILITY AND FITNESS FOR A&nbsp;PARTICULAR PURPOSE ARE DISCLAIMED. IN&nbsp;NO&nbsp;EVENT SHALL&nbsp;THE COPYRIGHT OWNER OR&nbsp;CONTRIBUTORS BE&nbsp;LIABLE FOR ANY DIRECT, INDIRECT, INCIDENTAL, SPECIAL, EXEMPLARY, OR&nbsp;CONSEQUENTIAL DAMAGES (INCLUDING, BUT NOT LIMITED TO, PROCUREMENT OF&nbsp;SUBSTITUTE GOODS OR&nbsp;SERVICES; LOSS OF&nbsp;USE, DATA, OR&nbsp;PROFITS; OR&nbsp;BUSINESS INTERRUPTION) HOWEVER CAUSED AND ON&nbsp;ANY THEORY OF&nbsp;LIABILITY, WHETHER IN&nbsp;CONTRACT, STRICT LIABILITY, OR&nbsp;TORT (INCLUDING NEGLIGENCE OR&nbsp;OTHERWISE) ARISING IN&nbsp;ANY WAY OUT OF&nbsp;THE USE OF&nbsp;THIS SOFTWARE, EVEN IF&nbsp;ADVISED OF&nbsp;THE POSSIBILITY OF&nbsp;SUCH DAMAGE.</p>\r\n</div>\r\n</div>\r\n</div>\r\n<p>i) Qt</p>\r\n<div class=\"accordion\">\r\n<div class=\"accordion__item\">\r\n<input id=\"a\" class=\"accordion__input\" name=\"a\" type=\"checkbox\" /> <label class=\"accordion__label\" for=\"a\">Копирайт 2013 Digia Plc и\\или ее&nbsp;дочерние компании.</label>\r\n<div class=\"accordion__content\">\r\n<p><a target=\"_blank\" href=\"http://www.qt-project.org/legal\">http://www.qt-project.org/legal </a></p>\r\n<p>You may use, distribute and copy the Qt&nbsp;GUI Toolkit under the terms of&nbsp;GNU Lesser General Public License version 2.1, which is&nbsp;displayed below.<br />This library is&nbsp;free software; you can redistribute it&nbsp;and/or modify it&nbsp;under the terms of&nbsp;the GNU Lesser General Public License as&nbsp;published by&nbsp;the Free Software Foundation; either version 2.1 of&nbsp;the License, or&nbsp;(at&nbsp;your option) any later version. </p>\r\n<p>This library is&nbsp;distributed in&nbsp;the hope that it&nbsp;will be&nbsp;useful, but WITHOUT ANY WARRANTY; without even the implied warranty of&nbsp;MERCHANTABILITY or&nbsp;FITNESS FOR A&nbsp;PARTICULAR PURPOSE. See the GNU Lesser General Public License for more details. Copy of&nbsp;the GNU General Public License will be&nbsp;provided to&nbsp;you along with product. If&nbsp;not, see <a target=\"_blank\" href=\"http://www.gnu.org/licenses/\">http://www.gnu.org/licenses/</a>.</p>\r\n</div>\r\n</div>\r\n</div>\r\n<p>17.4. Пользователь может получать, модифицировать и&nbsp;распространять исходные коды Компонентов программного обеспечения в&nbsp;соответствии с&nbsp;условиями соответствующих лицензий на&nbsp;них. Эти исходные коды могут быть доступны для скачивания на&nbsp;сайте Правообладателя или могут быть предоставлены Правообладателем по&nbsp;запросу Пользователя, при условии, что Правообладатель не&nbsp;принимает запросы, касающиеся содержания этих исходных кодов.</p>\r\n<p>17.5. Взаимодействие 2ГИС Desktop&nbsp;4.0&nbsp;с Компонентами программного обеспечения иное, чем предусмотрено настоящим соглашением, не&nbsp;подпадает под действие гарантии. Правообладатель не&nbsp;несет ответственности за&nbsp;любой финансовый ущерб или упущенную выгоду, включая любые иски третьих сторон, возникающие в&nbsp;результате использования Компонентов программного обеспечения, предоставляемого с&nbsp;2ГИС Desktop&nbsp;4.0.</p>\r\n<p>17.6. Любые вопросы относительно программного обеспечения с&nbsp;открытым кодом, включенного в&nbsp;2ГИС Desktop&nbsp;4.0, должны быть направлены <a href=\"mailto:support@2gis.ru\">support@2gis.ru</a>.</p>\r\n<p><strong>18. Информация о правообладателях</strong></p>\r\n<p>18.1. Со списком других правообладателей можно ознакомиться по адресу: <a href=\"https://law.2gis.kg/copyright/\">https://law.2gis.kg/copyright/</a>.<strong>&nbsp;</strong></p>\r\nРедакция от&nbsp;05.08.2024&nbsp;г.<br />\r\n<p><strong>Лицензиялык макулдашуу</strong></p>\r\n<p>Бул &laquo;2ГИС Программалык продуктуларды жана/же Онлайн кызматтарды пайдаланууга лицензиялык макулдашуу&raquo; документи, &laquo;ДубльГИС&raquo; Жоопкерчилиги чектелген коомдун (мындан ары- &laquo;Укук ээси&raquo;) төмөнкү баяндалган шарттарда макулдашуу түзүү сунушун билдирет.</p>\r\n<p><strong>2ГИС Программалык продуктуларын жана/же Онлайн кызматтарын пайдалануудан мурда, сураныч, ушул лицензиялык макулдашуунун шарттары менен таанышыңыз.</strong></p>\r\n<p><strong>1. Жалпы жоболор</strong></p>\r\n<p>1.1. 2ГИС Программалык продукттарын жана/же 2ГИС Онлайн кызматтарын колдонуп, Сиз төмөнкүлөргө менен макул болосуз:</p>\r\n<p>а) Сиз ушул Макулдашуунун шарттары менен 2ГИС Программалык продуктуларын жана/же Онлайн кызматтарын пайдалануу башталганга чейин толук көлөмдө таанышып чыгуу.</p>\r\n<p>Сиздин 2ГИС Программалык продуктыларын жана/же Онлайн кызматтарын пайдаланып баштоо, ушул Макулдашуунун бардык шарттарын Сиз тараптан кандайдыр бир алып салууларсыз жана чектөөлөрсүз толук көлөмдө Сиздин кабыл алгандыгыңызды билдирет. 2ГИС Программалык продуктыларын жана/же Онлайн кызматтарын башка шарттарда пайдаланууга жол берилбейт.</p>\r\n<p>в) Эгерде, Сиз ушул Макулдашуунун шарттары менен макул болбосоңуз&nbsp;же аны түзүүгө сиздин укугуңуз жок болсо, 2ГИС Программалык продуктыларын жана/же Онлайн кызматтарын каалагандай пайдаланууну тез арада токтотуу.</p>\r\n<p>г) Макулдашуу (анын ичинде анын бардык бөлүгү) Укук ээси тарабынан кандайдыр бир атайын кабарлоосуз өзгөртүлүшү мүмкүн. Макулдашуунун жаңы редакциясы, эгерде Макулдашуунун жаңы редакциясы тарабынан башкасы каралбаса, Укук ээсинин сайтына жайгаштырылган учурдан тартып күчүнө кирет.</p>\r\n<p>1.2. Ушул Макулдашууда каралбаган бардык учурларда, 2ГИС Онлайн кызматтарын пайдаланууга байланыштуу мамилелер 2ГИС Кызматтарын пайдалануу жөнүндө макулдашуу (<a href=\"http://law.2gis.kg/rules/\">http://law.2gis.kg/rules/</a>), ошондой эле Купуялуулук саясаты (h<a href=\"ttp://law.2gis.kg/privacy/\">ttp://law.2gis.kg/privacy/</a>) менен жөнгө салынат.</p>\r\n<p>1.3. Ушул Макулдашуунун колдонуудагы редакциясы Укук ээсинин сайтында:&nbsp;<a href=\"http://law.2gis.kg/licensing-agreement/\">http://law.2gis.kg/licensing-agreement/</a>&nbsp;дареги боюнча жеткиликтүү.</p>\r\n<p>1.4. 2ГИС Программалык продуктыларынын таралуучу нускаларынын курамына киргизилген Макулдашуунун редакциясы жана Макулдашуунун акыркы редакциясынын ортосундагы карама-каршылыктар болгон учурда, Укук ээсинин Сайтында жайгаштырылган Макулдашуунун редакциясы артыкчылыкка ээ&nbsp;болот.</p>\r\n<p><strong>2. Аныктамалар</strong></p>\r\n<p>Ушул лицензиялык макулдашууда колдонулуучу сөздөр жана түшүндүрүүлөр, эгерде текст боюнча андан ары башкача түздөн-түз аныкталбаса, төмөнкүдөй мааниге ээ&nbsp;болот:</p>\r\n<p>2.1.&nbsp;<strong>Лицензия (Макулдашуу)</strong>&nbsp;&minus;2ГИС Программалык продуктуларын жана/же Онлайн кызматтарын пайдаланууга чыныгы лицензиялык макулдашуу.</p>\r\n<p>2.2.&nbsp;<strong>2ГИС Онлайн кызматтары</strong>&nbsp;&mdash; Укук ээсинин 2ГИС Программалык продуктуларынын жана аппараттык каражаттарынын жыйындысы, аларга кирүү Укук ээсинин сайтын Колдонуучуга пайдалануу менен берилет.</p>\r\n<p>2.3.&nbsp;<strong>Укук ээси</strong>&nbsp;&mdash; &laquo;ДубльГИС&raquo; Жоопкерчилиги чектелген коому, ОГРН 1045401929847, орун алган жери: 630048, Новосибирск ш., Карл Маркс аянты, 7-үй, 13-кабат.</p>\r\n<p>2.4.&nbsp;<strong>Колдонуучу&nbsp;</strong>&mdash; өзүнүн же башка бирөөнүн кызыкчылыгында иш алып барган жеке адам.\r\nКолдонуучу 14 жаштан баштап, эгерде бул бир катар функцияларды пайдалануу үчүн талап кылынса, 2ГИС Кызматтарында өз алдынча каттоону жүзөгө ашырууга жана мыйзамда белгиленген укук жөндөмдүүлүгүнүн чегинде акыркыларын пайдаланууга укуктуу.</p>\r\n<p>2.5.&nbsp;<strong>2ГИС Программалык продуктылары</strong>&nbsp;&mdash; өз&nbsp;курамында Санариптик пландарды жана/же уюмдардын Маалымдамаларын бириктирип туруучу Укук ээсине таандык 2ГИС программалык комплекстери, ошондой эле алардын курамына кирген ар&nbsp;бири&nbsp;же алар менен бирге пайдаланылуучу ЭЭМ үчүн программа&nbsp;же өз-өзүнчө берилмелер базасы, ошондой эле столдук жана чөнтөктүк жеке компьютерлерде, мобилдик телефондордо, коммуникаторлордо, смартфондордо пайдалануу үчүн арналган алардын бардык кийинки жаңылоолору жана модификациялары.</p>\r\n<p>2.6.&nbsp;<strong>Уюмдар маалымдамасы&nbsp;</strong>&mdash; өндүрүлүүчү жана сатылуучу товарлардын (аткарылган иштердин, көрсөтүлгөн кызматтардын) аталыштары, жайгашкан жери, телефондору, электрондук почтасынын жана сайттарынын даректери, түрлөрү жөнүндө маалыматты жана аны менен айкалышкан Санариптик планынын чектери менен дал келген белгилүү бир аймактын чектеринде турган уюмдар, жеке ишкерлер, ошондой эле Укук ээсинин каалоосу боюнча башка буюмдар жөнүндө башка маалыматтарды камтыган электрондук маалымдаманын берилмелер базасы.</p>\r\n<p>2.7.&nbsp;<strong>Укук ээсинин Сайты&nbsp;</strong>&mdash; 2gis.kg, 2gis.com дареги боюнча доменге, ошондой эле 2gis.kg, 2gis.com доменине кирүүчү башка домендерге жайгаштырылган интернет-сайттар.</p>\r\n<p>2.8.&nbsp;<strong>Санариптик план</strong>&nbsp;&mdash; белгилүү географиялык координаттар менен чектелген аймактын чегиндеги географиялык объекттер жана калктуу конуштар жөнүндө геомаалыматтык берилмелерди камтыган электрондук картанын маалымат базасы.</p>\r\n<p>2.9.&nbsp;<strong>Коммерциялык пайдалануу</strong>&nbsp;&mdash; ушул Макулдашуу боюнча уруксат берилген функционалдык колдонуу жана/же карта фрагменттерин пайдаланууга, 2ГИС Программалык продуктуларды жана/же 2ГИС Онлайн кызматтарды пайдаланууга берилген, ошондой эле жеке адамдын киреше (пайда) алуу максатында башка интеллектуалдык менчиктин башка Объектилерин пайдаланууга, ал&nbsp;эми жеке ишкер&nbsp;же уюм тарабынан&nbsp;&mdash; ишкердик пайданы алуу максатында, анын ичинде аларды берүүнү камсыз кылуу&nbsp;же аларга акы төлөнүүчү негизде берүү&nbsp;же камсыз кылуу,&nbsp;б.&nbsp;а. акы төлөп&nbsp;же товарларды, жумуштарды, кызматтарды каршы берүү&nbsp;же бир убакта товарларды, жумуштарды, кызматтарды тигил&nbsp;же бул формада акы төлөнүүчү негизде берүү укуктарынын чектен чыгышы. 2ГИС Программалык продуктуларды жана/же Онлайн кызматтарды, ошондой эле башка Интеллектуалдык менчик объекттерин Коммерциялык пайдаланууга Укук ээси тарабынан Колдонуучу менен өзүнчө макулдашуунун негизинде уруксат берилиши мүмкүн.</p>\r\n<p>2.10.&nbsp;<strong>Пин-коду</strong>&nbsp;&mdash; Колдонуучунун суроо-талабы боюнча Укук ээсинин программалык-аппараттык каражаттары менен иштеп чыгарылуучу жана өзүнчө 2ГИС Онлайн-кызматтарды жана/же 2ГИС Программалык продуктылардын байланышы менен, ошондой эле алардын башка программалык продуктылар, кызматтар менен байланышын камсыз кылуу үчүн арналган сандардын өзгөчө ырааттуулугу.</p>\r\n<p>2.11.&nbsp;<strong>Купуялуулук саясаты</strong>&nbsp;&mdash; http://law.2gis.kg/privacy/дареги боюнча Интернет тармагында жайгаштырылган Купуялуулук саясаты.</p>\r\n<p><strong>3. Өзгөчө укуктар</strong></p>\r\n<p>3.1. 2ГИС Программалык продуктулар жана Онлайн кызматтары жалпысынан жана анын курамына киргизилүүчү&nbsp;же ЭЭМ, берилмелер базасы үчүн алар менен биргеликте программалар, картографиялык, маалымдама-маалыматтык жана башка тексттик материалдар, автордук жана/же чектеш укуктардын сүрөттөрү жана башка объекттери , ага тете патенттик укуктар объекттери, товардык белгилер, коммерциялык белгилөөлөр жана фирмалык аталыштар, ошондой эле башка бөлүгүн 2ГИС Программалык продуктулардын жана/же Онлайн кызматтардын (алар алардын курамына киргендигине карабастан&nbsp;же кошумча компоненттери болуп саналабы жана аларды алардын курамынан чыгарууга жана өз&nbsp;алдынча пайдаланууга мүмкүнбү) өз-өзүнчө башка бөлүктөрү (мындан ары&nbsp;&mdash; \"Интеллектуалдык менчиктин объектилери), Россия Федерациясынын IV&nbsp;Жарандык кодексинин Бөлүмүнө ылайык корголгон, укук ээсине таандык болгон өзгөчө укук менен, эгерде укуктар жөнүндө кабарлоодо башкача көрсөтүлбөсө Укук ээсине тиешелүү.</p>\r\n<p>3.2. Укук ээси, ушул Лицензияга ылайык жол берилген Интеллектуалдык менчик объекттерин кайра иштетүүнүн бардык жыйынтыктарына (модификациялоо) өзгөчө укуктарды сактайт жана аларды пайдалануунуга берилген өз уруксатын каалаган убакта Колдонуучуга аларды жаратууга жана колдонууга кеткен кандайдыр-бир чыгымдарын компенсация кылбастан чакырып алууга укуктуу.</p>\r\n<p>3.3. Интеллектуалдык менчик объектине укуктар жөнүндө кабарлоо ушундай Объектиде жайгаштырылат же аны берүүдө Колдонуучуга жеткирилет. Укуктар жөнүндө кабарламанын жоктугу анын укуктук жактан корголушунун же аларды эркин пайдаланууга уруксаттын жоктугун билдирбейт.</p>\r\n<p><strong>4. Лицензия берүү</strong></p>\r\n<p>4.1. 2ГИС Программалык продуктуларын жана/же Онлайн кызматтарын пайдаланууга ушул лицензиянын шарттарында гана уруксат берилет. Эгерде Колдонуучу Лицензия шарттарын толук көлөмдө кабыл албаса, Колдонуучу ар кандай максатта 2ГИС Программалык продукттарды жана/же Онлайн кызматтарды колдонууга укугу жок. Лицензиянын кайсыл бир шарттарын бузуу (аткарбоо) менен 2ГИС Программалык продуктуларын жана/же Онлайн-кызматтарын пайдаланууга тыюу салынат.</p>\r\n<p>4.2. 2ГИС Программалык продукттарды жана/же Онлайн кызматтарды колдонуу укуктары жана ыкмалары, ушул Макулдашуу боюнча Колдонуучуга ачык түрдө берилбесе/уруксат берилбесе, Укук ээси тарабынан берилбеген/тыюу салынган деп эсептелет.</p>\r\n<p>4.3. Ушул лицензиянын шарттарында, 2ГИС Программалык продуктуларды жана/же Онлайн-кызматтарды коммерциялык эмес максаттарда пайдаланууга Колдонуучуга акысыз негизде уруксат берилет.</p>\r\n<p>4.4. Укук ээси 2ГИС Программалык продукттарда жана/же Онлайн кызматтарда каалаган маалыматтык жана/же жарнактык материалдарды жана үчүнчү жактардын интернет-сайттарына шилтемелерди жайгаштырууга, ошондой эле 2ГИС Программалык продукттарды жана/же Онлайн кызматтарды колдонуу укугун үчүнчү жактарга өзүнчө макулдашуу боюнча, көрсөтүлгөн ыкма менен берүүгө укуктуу.</p>\r\n<p><strong>5. Колдонуучунун укуктары</strong></p>\r\n<p>5.1. Колдонуучуга Укук ээси 2ГИС Программалык продуктуларын жана/же Онлайн кызматтарын, жөнөкөй (өзгөчө эмес) өткөрүп берилбей турган лицензиянын шарттарында, дүйнөнүн бардык өлкөлөрүнүн аймагында, ушул бөлүмдө көрсөтүлгөн ыкмалар менен пайдалануу укугун берет.</p>\r\n<p><strong>5.2. 2ГИС Программалык продуктуларды функционалдык колдонуу</strong></p>\r\n<p>Колдонуучу 2ГИС Программалык продуктуларын, столдо же жеке чөнтөктүк компьютерде (лерде), смартфондо(-дордо) же башка түзмөктөрдө (мындан ары &mdash; \"Түзмөк\") орнотуу максатында, алардын түздөн-түз функционалдык багыты боюнча Колдонуучунун Колдонмосуна ылайык колдонууга укугу бар.</p>\r\n<p>Ушул пунктка ылайык, Колдонуучу 2ГИС Программалык продуктуларын чексиз Түзмөктөргө орнотууга, ошондой эле Программалык продуктулардын көчүрмөлөрүн, Программалык продуктыны локалдык тармактын чегинде болгон башка компьютерлерге орнотуу жана иштөө үчүн гана арналган берилмелерди сактоо түзмөгүндө (мисалы, тармактын серверинде) сактоого же орнотууга укугу бар.</p>\r\n<p><strong>5.3. 2ГИС Программалык продуктуларды иштетүү</strong></p>\r\n<p>Колдонуучу 2ГИС Программалык продуктуларды чыгарууга укугу бар, алардын нускалары Укук ээси тарабынан, коммерциялык эмес максатта кайтарымсыз негизде, алар Укук ээси тарабынан пайдалануу үчүн берилгендей жана/же сунуш кылынганга салыштырганда, 2ГИС Программалык продуктылардын комбинацияларын, курамын жана мазмунун өзгөртүлбөгөн түрдө сактоо шартында, ар&nbsp;кандай Түзмөктөрдө жана материалдык алып жүрүүчүлөрдүн башка түрлөрүндө таркатылат.</p>\r\n<p><strong>5.4. 2ГИС Программалык продуктуларды таркатуу</strong></p>\r\n<p>Колдонуучу 2ГИС Программалык продуктуларды, ушул Макулдашуунун&nbsp;4.3. пунктуна ылайык, коммерциялык эмес максатта кайтарымсыз негизде жана алардын бүтүндүгүн сактоо менен, эгерде Укук ээсинин жазуу жүзүндөгү уруксаты менен башкача каралбаса, алардын нускаларын өткөрүп берүү жолу менен таркатууга укугу бар</p>\r\n<p><strong>5.5. 2ГИС Онлайн кызматтарын функционалдык пайдалануу</strong></p>\r\n<p>Колдонуучу ушул Лицензиянын шарттарына ылайык, Түзмөктөрдүн чектелбеген санында түздөн-түз функционалдык дайындоо боюнча 2ГИС Онлайн кызматтарын пайдаланууга укуктуу. Укук ээсинин кароосу боюнча айрым 2ГИС Онлайн кызматтарын&nbsp;же алардын кошумча функционалдык мүмкүнчүлүктөрүн пайдалануу үчүн, Колдонуучу тарабынан өзүнчө макулдашуунун шарттарын кабыл алуу талап кылынышы мүмкүн.</p>\r\n<p><strong>5.6. Интернет тармагында 2ГИС Онлайн кызматтары менен карталар фрагменттерине шилетемелерди пайдалануу</strong></p>\r\n<p>Колдонуучу 2ГИС Онлайн кызматы менен карталар фрагменттерине html-шилетемелерди төмөнкү көрсөтүлгөн шарттарда пайдаланууга укуктуу.</p>\r\n<p>Керектүү имараттын жайгашышын көрсөтүш үчүн, 2ГИС Онлайн кызматынын Санариптик планына төмөнкү түрдөгү атайын шилтемени коюу жетиштүү:&nbsp;<a title=\"2gis.ru &mdash; Шаардык маалыматтык кызмат\" target=\"_blank\" href=\"https://law.2gis.kg/licensing-agreement/%7B%D0%A4%D1%80%D0%B0%D0%B3%D0%BC%D0%B5%D0%BD%D1%82%D0%BA%D0%B5%20%D1%88%D0%B8%D0%BB%D1%82%D0%B5%D0%BC%D0%B5%D0%BD%D0%B8%D0%BD%20%D0%B4%D0%B0%D1%80%D0%B5%D0%B3%D0%B8%7D\">{Шилтеменин тексти, адатта бул дарек}</a></p>\r\n<p>Санариптик пландын фрагментине шилтеменин дарегин билиш үчүн:</p>\r\n<p>1. Укук ээсинин Сайтына кириш керек&nbsp;<a href=\"https://law.2gis.kg/licensing-agreement/\">2gis.kg</a>.</p>\r\n<p>2. Керектүү имаратты тандоо (бул учурда картада имараттын дареги менен карточка пайда болот).</p>\r\n<p>3. Картанын үстүндө оң&nbsp;бурчта жайгашкан &laquo;Бул жерге шилтеме&raquo; текстин чыкылдатыңыз. Курсордун астында тандалган фрагментке шилтеменин дареги менен терезече пайда болот.</p>\r\n<p>Шилтеме боюнча дал ошондой фрагмент ачылат, ал&nbsp;&laquo;Бул жерге шилтеме&raquo; тексти боюнча чыкылдатуу учурунда тандалган. Колдонуучулар үчүн 2ГИС Онлайн кызматында ыңгайлуу болуш үчүн: карта менен навигация, жакынкы аялдамаларды көрүү, фирмалар жана имараттар жөнүндө маалыматтар каралган.</p>\r\n<p>2ГИС Онлайн кызматтарына шилтемелерди пайдалануу аны пайдалануунун кыйла жөнөкөйүрөөк жана ыкчам варианты болуп саналат жана ошондуктан көп сандагы (компаниялар, жаңы конуштар каталогдору, ж.б.) даректери менен сайттар үчүн сунуш кылынат. 2ГИС Онлайн кызматы ай&nbsp;сайын жаңыланып турат.</p>\r\n<p><strong>5.7. Интернет тармагында 2ГИС Программалык продуктылардын жана/же Онлайн-кызматынын карталар фрагментин пайдалануу</strong></p>\r\n<p>Колдонуучу 2ГИС Программалык продуктыларынан жана/же Онлайн кызматынан пайда болгон картографиялык берилмелерди, ошондой эле карталардын ушундай фрагменттеринин туундуларын (толуктоолор, кыскартуулар, айлануу бурчун өзгөртүү жана башка кайра иштетүүлөр менен) көрүп чагылдырууну көчүрүү жолу менен шаарлардын Санариптик пландарынын карта фрагменттерин түзүүгө жана Интернет тармагында алынган булакты жана&nbsp;<a href=\"http://www.2gis.kg/\">www.2gis.kg</a>&nbsp;төмөндө келтирилген түрдөгү сайтка активдүү шилтемени көрсөтүү менен фрагменттердин ар&nbsp;биринде кол тамгасынын болгон шартында жалпы бардыгына маалымдоого укугу бар:</p>\r\n<p><a href=\"https://2gis.kg/bishkek\">&copy;&nbsp;2ГИС&nbsp;&mdash; Шаардык Маалыматтык Маалымдама</a></p>\r\n<p>5.8. ММКда, полиграфияда жана тышкы жарнамаларда 2ГИС Программалык продуктылардын жана/же Онлайн кызматтарынын карталар фрагментин пайдалануу</p>\r\n<p>Колдонуучу 2ГИС Программалык продуктыларынан жана/же Онлайн кызматтарынан пайда болгон картографиялык берилмелерди, ошондой эле карталардын ушундай фрагменттеринин туундуларын (толуктоолор, кыскартуулар, айлануу бурчун өзгөртүү жана башка кайра иштетүүлөр менен) көрүп чагылдырууну көчүрүү жолу менен карта фрагменттерин мезгилүү басылмаларга, полиграфияга, тышкы жарнамаларга жана башка басма жана электрондук басылмаларга, төмөндө келтирилген фрагменттердин ар&nbsp;биринде кол тамгасынын болгон шартында чыгарууга укугу бар:</p>\r\n<p>&copy;&nbsp;2ГИС. Шаардык маалыматтык кызмат.<br /><a href=\"http://www.2gis.kg\">www.2gis.kg</a></p>\r\n<p>Басылмаларда жана полиграфияда карталардын фрагменттерине кол коюу үчүн колдонулган шрифттин өлчөмү кеминде 5&nbsp;pt, тышкы жарнакта&nbsp;&mdash; макеттин аянтынын&nbsp;2% нан кем эмес болушу керек.</p>\r\n<p>5.9. Макулдашуунун&nbsp;4.7-4.8-пункттарында көрсөтүлгөн ыкмалар менен 2ГИС программалык продуктуларды жана/же Онлайн кызматтарды пайдаланууга, төмөнкү шарттар бир мезгилде сакталган учурда жол берилет:</p>\r\n<p>а) карталардын фрагменттерин андан ары маалыматтык максаттарда гана колдонууга болот (мисалы, белгилүү бир объектинин жайгашкан ордун&nbsp;же жүрүү схемасын көрсөтүү үчүн);</p>\r\n<p>б) картографиялык материалдарды пайдалануу көлөмү (картанын фрагментинин аянты) жогоруда аталган маалыматтык максаттар менен акталган.</p>\r\n<p>5.10. Өзүнчө 2ГИС Программалык продуктуларды жана/же Онлайн кызматтары менен, анын ичинен алардын башка программалык продуктылар, кызматтар менен байланышты камсыз кылуу мүмкүнчүлүгүн пайдалануу үчүн, Колдонуучу Укук ээсинен алган пин-кодду киргизүүсү зарыл.</p>\r\n<p>5.11. Ушул бөлүмгө ылайык 2ГИС Программалык продуктуларды жана/же Онлайн кызматтарын пайдалануу укугу, Колдонуучу ушул Макулдашуу менен белгиленген чектөөлөрдү сактаган учурда берилет.</p>\r\n<p><strong>6. Пайдалануунун чектөөлөрү (Уруксат берилген пайдалануунун көлөмү)</strong></p>\r\n<p>6.1. Колдонуучу өз&nbsp;алдынча&nbsp;же үчүнчү жактарды тартуу менен төмөнкүлөргө укугу жок:</p>\r\n<p>6.1.1. Технологиясын ачууга, эмуляциялоого, жаңы версияларды түзүүгө, өзгөртүүгө, декомпиляциялоого, дизассембляциялоого, дешифрлөөгө жана 2ГИС Программалык продуктуларды жана/же Онлайн кызматтарынын санкцияланбаган пайдалануудан коргоо тутумун бузуу максатында, 2ГИС Программалык продуктулардын жана/же Онлайн кызматтарынын коду менен башка иш-аракеттерди жүргүзүүгө, картографиялык материалдарды, маалымдама-маалыматтык жана башка материалдарды берилмелер базаларынан чыгарууга, ошондой эле 2ГИС Программалык продуктуларда жана/же Онлайн-кызматтарда пайдалынылуучу алгоритмдерди ишке ашыруу жөнүндө маалымат алууга.</p>\r\n<p>6.1.2. Программалык&nbsp;же маалымдама-маалыматтык продуктуларды жана/же 2ГИС Программалык продуктулардын жана/же Онлайн кызматтарын, ошондой эле алардын курамына киргизилүүчү берилмелер базаларын&nbsp;же алардан алынган (алынуучу) тексттик, картографиялык жана маалымдама-маалыматтык материалдарды, ага тете эле ушул Макулдашуунун&nbsp;2.1-пунктунда көрсөтүлгөн башка интеллектуалдык менчик Объектилерин пайдалануу менен кызматтарды түзүүгө.</p>\r\n<p>6.1.3. Укук ээсинин жазуу жүзүндөгү макулдугусуз коммерциялык максаттарда 2ГИС Программалык продуктуларды чыгаруу жана жайылтуу.</p>\r\n<p>6.1.4. 2ГИС Программалык продуктулардын курамына киргизилүүчү берилмелер базасынан каалаган картографиялык, маалымдама-маалыматтык жана башка материалдарды алууга, кийин аларды каалаган формада жана каалаган ыкма менен пайдаланууга.</p>\r\n<p>6.1.5. 2ГИС программалык продуктулардын курамына кирген берилмелер базасын, ушундай 2ГИС программалык продуктыларынан өзүнчө пайдалануу.</p>\r\n<p>6.1.6. 2ГИС Онлайн-кызматтарга коммерциялык максаттарда жетүүнү, анын ичинде ар&nbsp;кандай ыкмалар менен, фреймдерди жана 2ГИС Онлайн кызматтардан берилмелерди алууну камсыз кылуучу башка программалык методдорду, ыкмаларды пайдаланууну жана аларды, эгерде Укук ээси менен өзүнчө макулдашууда башкасы каралбаса, үчүнчү жактардын сайттарына сунуштоону кошкондо, алардан трансляциялоо жолу менен камсыз кылуу.</p>\r\n<p>6.1.7. 2ГИС Программалык продуктыларга жана/же Онлайн кызматтарга киргизилген, ошондой эле Санариптик пландарга жана картографиялык материалдарга салынган автордук жана ар&nbsp;кандай башка укуктар тууралуу товардык белгилерди, өнөр жай үлгүлөрүн жана кабарлоолорду, жок кылууга&nbsp;же бардык ыкмалар менен өзгөртүүгө.</p>\r\n<p>6.2. Күмөн саноолорго жол бербөө үчүн, көчүрүүгө, кайра чыгарууга, иштетүүгө, жайылтууга, жалпыга жеткиликтүү кылууга (Интернетке эркин кирүүгө (жарыялоого), массалык маалымат каражаттарында колдонууга жана/же 2ГИС Программалык продуктыларынын жана /&nbsp;же Онлайн кызматтарынын курамына киргизилүүчү берилмелер базаларынан түз алынган, ошондой эле 2ГИС Программалык продуктыларын жана /&nbsp;же Онлайн кызматтарын пайдаланып берилмелерди иштетүүнүн жыйынтыктарын көчүрүү жолу менен алынган картографиялык материалдарды жана маалымдама материалдарды, ошондой эле ушул Лицензияда каралган учурлардан башка, ушундай материалдардын (толуктоолор, кыскартуулар жана башка иштетүү менен) туундуларын коммерциялык колдонууга ТЫЮУ САЛЫНАТ.</p>\r\n<p><strong>7. Автоматтык жаңылоолор</strong></p>\r\n<p>7.1. 2ГИС Программалык продуктуларынын жаңыланышын, 2ГИС Программалык продуктуларынын модификацияларын, алардын кошумча модулдарын, ошондой эле шаарлар боюнча (мындан ары&nbsp;&mdash; &laquo;Жаңылоолор&raquo;) берилмелер базаларында жаңылоолор болгондугун текшерүү үчүн, мезгил-мезгили менен 2ГИС Программалык продуктулары Укук ээсинин программалык-аппараттык каражаттары менен өз&nbsp;ара аракеттениши мүмкүн.</p>\r\n<p>7.2. 2ГИС Программалык продуктуларын орнотуу менен, Колдонуучу алар менен суроо-талаптарды аткаруу мүмкүнчүлүгүнө, ошондой эле Жаңылоолорду автоматтык шарттамда алууга жана орнотууга макул болот.</p>\r\n<p><strong>8. Купуялуулук саясаты</strong></p>\r\n<p>8.1. Колдонуучудан 2ГИС Программалык продуктыларын жана/же Онлайн кызматтарын пайдалануу үчүн, эгерде ушундай 2ГИС Программалык продуктыларын жана/же Онлайн кызматтарын пайдаланууга өзүнчө макулдашуу менен башкача каралбаса жеке берилмелерди берүү талап кылынбайт.</p>\r\n<p>8.2. Колдонуучулардын 2ГИС Программалык продуктыларын жана/же Онлайн кызматтарын пайдалануусуна байланыштуу Укук ээси тарабынан Колдонуучулар жөнүндө алынган маалыматты иштетүү жана коргоо тартиби, Купуялуулук саясаты менен, ушул Макулдашуу жана өзүнчө 2ГИС Программалык продуктыларын жана/же Онлайн кызматтарын пайдалануу жөнүндө макулдашуулар менен белгиленген өзгөчөлүктөрүн эске алуу менен аныкталат.</p>\r\n<p><strong>9. Лицензия боюнча жоопкерчилик</strong></p>\r\n<p>9.1. Лицензиянын алкагында 2ГИС Программалык продуктуларды жана/же Онлайн кызматтарын пайдалануу укугу коммерциялык эмес максатта акысыз негизде берилип жаткандыгына байланыштуу тараптардын лицензия боюнча мамилелерине керектөөчүлөрдүн укуктарын коргоо жөнүндө Мыйзамдын жоболору колдонулбайт.</p>\r\n<p>9.2. 2ГИС Программалык продуктуларды жана/же Онлайн кызматтары &laquo;болгондой&raquo; шарттарда берилет, ага байланыштуу Колдонуучуга кандайдыр-бир кепилдиктер берилбейт, алар: Колдонуучунун талаптарына алар шайкеш келет; үзгүлтүксүз, тез, ишеничтүү жана катасыз берилет; аларды пайдалануу менен алынган жыйынтыктар так жана ишеничтүү болот; бардык каталар оңдолгон болот.</p>\r\n<p>9.3. Маалымдамада жана картада жайгаштырылган маалымат так болуш үчүн Укук ээси бардык күчүн жумшайт, бирок Укук ээси мындай маалыматтын тактыгы боюнча эч&nbsp;кандай кепилдик бербейт жана ал&nbsp;үчүн жооп бербейт. 2ГИС Программалык продуктулар жана/же Онлайн кызматтар курамындагы кандайдыр-бир материалдарды жана берилмелерди пайдалануу Колдонуучунун тобокелдигине кирет, Укук ээси кандайдыр-бир кирешенин жок болушуна&nbsp;же 2ГИС Программалык продуктуларды жана/же Онлайн кызматтарын пайдалануунун натыйжасында башка зыянга учуроосуна жооп бербейт.</p>\r\n<p>9.4. 2ГИС Программалык продуктуларда жана/же Онлайн кызматтарда жайгаштырылган бардык маалыматтык жана/же жарнамалык материалдар үчүнчү адамдар тарабынан берилген. Укук ээси үчүнчү адамдардын маалыматтык жана/же жарнамалык материалдарынын чындыгы, алардын интернет-сайттары жана алардын мазмуну, ошондой эле маалыматты жана/же жарнаманы пайдалануу менен байланыштуу кесепеттер үчүн жооп бербейт.</p>\r\n<p>9.5. 2ГИС Программалык продуктулары жана/же Онлайн кызматтары жаңы функционалдык мүмкүнчүлүктөрүнүн дайыма толуктоо жана жаңылоо стадиясында болгондуктан, продуктылардын жана көрсөтүлүүчү кызматтардын формасы жана мүнөзү убак-убагы менен Колдонуучуну алдын-ала кабарлоосуз алмаштырылып турушу мүмкүн. Укук ээси өзүнүн каалоосу боюнча дээрлик бардык Колдонуучуларга&nbsp;же өзүнчө Колдонуучуга 2ГИС Программалык продуктуларды жана/же Онлайн кызматтарын&nbsp;(же продуктыларынын кандайдыр-бир өзүнчө бөлүктөрүн&nbsp;же кызматтардын функцияларын) берүүнү токтотууга (убактылуу&nbsp;же биротоло), ошондой эле алдын ала кабарлоосуз лицензияны өзгөртүүгө&nbsp;же чакыртып алууга укуктуу.</p>\r\n<p>9.6. Колдонуучу, ушул Макулдашуу&nbsp;(же) колдонулуучу укук менен белгиленген милдеттемелердин ар&nbsp;кандай бузууларына, ошондой эле ушундай бузуулардын (Укук ээсинин жана башка үчүнчү адамдардын зыяндарын кошкондо) бардык кесепеттери үчүн жооп берет.</p>\r\n<p>9.7. Укук ээси өзүнүн каалоосу боюнча жарандык, административдик жана кылмыш-жаза мыйзамдарына ылайык интеллектуалдык менчиктин Объектилерине өзгөчө укук бузуучуларды жоопкерчиликке тартуу укугун өзүнө калтырат.</p>\r\n<p><strong>10. Колдонулуучу укук жана арбитраж</strong></p>\r\n<p>10.1. Ушул Макулдашуу, аны түзүү жана аткаруу тартиби, ошондой эле ушул Макулдашуу менен жөнгө салынбаган маселелер, Россия Федерациясынын колдонуудагы мыйзамдары менен жөнгө салынат.</p>\r\n<p>10.2. Ушул Макулдашуудан&nbsp;же аны менен, анын ичинен Макулдашууну чечмелөө, аткаруу, бузуу, токтотуу&nbsp;же жараксыздыгына байланыштуу тараптардын ортосунда ар&nbsp;кандай талаш-тартыштар келип чыккан учурда, Тараптар башында достук сүйлөшүүлөр жолу менен чечүүгө аракет кылууга тийиш.</p>\r\n<p>10.3. Макулдашуу боюнча&nbsp;же аны менен байланыштуу бардык талаш-тартыштар, Укук ээсинин турган жери боюнча, Россия Федерациясынын колдонуудагы процессуалдык укугуна ылайык сотто каралат.</p>\r\n<p><strong>11. Укук ээсинин макулдашууну токтотууга укугу</strong></p>\r\n<p>Бул макулдашуу Укук ээси менен Колдонуучуну алдын ала билдирүүсүз жана ага байланыштуу кандайдыр-бир компенсацияны төлөп бербестен, Укук ээсин коргоонун башка укуктарына жана каражаттарына зыян келтирбестен жана Колдонуучуга бардык чыгымдар жана ага келтириле турган зыян келтирүүлөр үчүн жооп бербестен, бир тараптуу тартипте өзгөртүлүшү&nbsp;же токтотулушу мүмкүн.</p>\r\n<p><strong>12. Макулдашуу токтотулгандан кийин милдеттер</strong></p>\r\n<p>12.1. Лицензия токтогондон кийин Колдонуучунун 2ГИС Программалык продуктуларды жана/же Онлайн кызматтарды пайдалануу укугу бардык себептер менен автоматтык түрдө токтотулат жана Колдонуучу мындай кызматтарды пайдаланууну тезинен токтотууга жана Колдонуучунун ээлигиндеги&nbsp;же көзөмөлүндөгү&nbsp;же туруктуу негизде башкача түрдө болгон 2ГИС Программалык продуктыларын өчүрүүгө, жок кылууга милдеттүү.</p>\r\n<p>12.2. 2ГИС Программалык продуктуларын жана/же Онлайн кызматтарын пайдалануунун токтотуу датасына чейин пайда болгон бардык себептер менен токтотуу, ушул Макулдашуу боюнча тараптардын укуктарына таасир этпейт.</p>\r\n<p><strong>13. Форс-мажор</strong></p>\r\n<p>Тараптардын бири да&nbsp;анын акыл-эстүү көзөмөлүнөн тышкары турган себептерден улам, ушул Макулдашуу боюнча милдеттемелерди аткарбагандыгы&nbsp;же өз&nbsp;убагында аткарбагандыгы үчүн жооп бербейт. Аткарбагандык&nbsp;же өз&nbsp;убагында аткарбагандык ушул Макулдашууну бузган болуп эсептелбейт жана тиешелүү милдеттемелерди аткаруу мөөнөтү негизделген убакыт мезгилине көбөйөт.</p>\r\n<p><strong>14. Бөлүнүшү</strong></p>\r\n<p>Эгерде ушул макулдашуунун каалаган бөлүгү компетенттүү юрисдикциядагы сот&nbsp;же башка компетенттүү инстанция&nbsp;же арбитр тарабынан жараксыз, мыйзамсыз&nbsp;же укуктук санкция менен камсыздалбаган деп таанылса, мындай бөлүгү Макулдашуунун калган шарттарынан бөлүнөт, алар жарактуу жана мыйзам жол берген максималдуу даражада укуктук санкция менен камсыздалган боюнча калат.</p>\r\n<p><strong>15. Укуктан баш тартуу</strong></p>\r\n<p>Тараптардын бирөө ушул Макулдашуу боюнча коргоонун укуктарын, ыйгарым укуктарын&nbsp;же каражаттарын пайдаланбагандыгы&nbsp;же мөөнөтүнөн өткөрүүсү мындай укуктардан баш тартуу болуп саналбайт жана мындай укуктарды бир жолу&nbsp;же жарым жартылай пайдалануу аларды башкача&nbsp;же андан аркы пайдаланууга тоскоол жаратпайт. Укуктан баш тартуу жазуу жүзүндө таризделүүгө тийиш. Ушул Макулдашуу боюнча берилүүчү коргоо каражаттары кумулятивдик мүнөзгө ээ&nbsp;болуп, мыйзам боюнча берилүүчү коргоо каражаттарын колдонууну жокко чыгарбайт.</p>\r\n<p><strong>16. Аталыштары</strong></p>\r\n<p>Ушул Макулдашууда аталыштар Макулдашуунун жоболорун чечмелөөдө ыңгайлуулук үчүн гана пайдаланылат жана эске алынбайт.</p>\r\n<p><strong>17. Укуктар жөнүндө кабарлоо</strong></p>\r\n<p>17.1. Бул бөлүм жумушчу стол үчүн 2ГИС 4.0 версиясынын Программалык продуктусуна (мындан ары&nbsp;&mdash; &laquo;2ГИС Desktop&nbsp;4.0&raquo;) киргизилген ачык баштапкы коду бар программалык камсыздоо үчүн лицензияларды жана кабарлоолорду камтыйт. 2ГИС Desktop&nbsp;4.0 өзүнө ачык баштапкы коду бар (&laquo;Программалык камсыздоо компоненттери&raquo;) ар&nbsp;башка программалык камсыздоону камтыйт, ачык баштапкы коду бар программалык камсыздоого карата лицензияларга ылайык лицензияланат. Ар&nbsp;бир Программалык камсыздоонун компоненти үчүн лицензиялык макулдашуулар программалык камсыздоо компонентинин файлын коштойт жана төмөндөгү тиешелүү лицензия менен аныкталгандардан башка баштапкы код жана да&nbsp;кош код формасында Программалык камсыздоо компонентерин пайдаланууга, көчүрүүгө, модификациялоого жана таратууга укуктарды берет.</p>\r\n<p>17.2. Автордук укуктар жөнүндө</p>\r\n<p>2ГИС Desktop&nbsp;4.0 камтылган материалдар автордук укук тарабынан корголуучу болуп саналат. Автордук укуктар жөнүндө мыйзамдар, автордук укуктун Укук ээсинин уруксатысыз берилмелерди толугу менен&nbsp;же жарым-жартылай көчүрүп алуу, калыбына келтирүү, пайдалануу жана логотиптерди, графикалык сүрөттөрдү, иллюстрацияларды, продуктунун дизайнын жана аны менен байланышкан документтерди (колдонмолор, расмий документтер, таблицалар&nbsp;ж.&nbsp;б.) таратууга тыюу салат.</p>\r\n<p>Boost, GNU Crypto, Tukaani, JSON, SQLite, Tinyxml, Zlib, Snappy, Qt&nbsp;логотиптери товардык белгилер менен катталган жана алардын укук ээлеринин менчиктеринин автордук укуктары менен корголуучу болуп саналат.</p>\r\n<p>2ГИС Desktop&nbsp;4.0&nbsp;ке киргизилген тексттер, продуктылардын графикасы, сүрөттөрү жана белгилөөлөрү ушул элементтерге тиешелүү авторлордун менчиктери болуп саналат.</p>\r\n<p>17.3. Программалык камсыздоо жөнүндө</p>\r\n<p>Автордук укуктар жөнүндө мыйзамдар автордук укуктардын укук ээсинин уруксатысыз программалык камсыздоону толугу менен&nbsp;же жарым-жартылай пайдаланууга, көчүрүүгө, ижарага берүүгө, өзгөртүүгө жана жайылтууга тыюу салат.</p>\r\n<p>2ГИС Desktop&nbsp;4.0 тиешелүү лицензиялык макулдашуулардын шарттарында пайдалануу, Колдонуучуга программалык камсыздоонун Компоненттерин пайдаланууга эч&nbsp;кандай мүлктүк&nbsp;же мүлктүк эмес укуктарды бергендигин билдирбейт. Бул укуктар Колдонуучуларга Программалык камсыздоонун компоненттерине тиешелүү лицензиялар менен берилет.</p>\r\n<p>Программалык камсыздоо Компоненттеринин тизмеси:</p>\r\n<p>a) Boost</p>\r\n<p>Boost Software License, Version&nbsp;1.0 шарттарында 2003-жылдын 17-августунан баштап берилет.</p>\r\n<p>b) Cryptopp</p>\r\n<p>Crypto++ Library жыйнагы Boost Software License&nbsp;1.0 шарттарында берилет</p>\r\n<p>c) Lzma</p>\r\n<p>LZMA SDK</p>\r\n<p>LZMA SDK Игорь Павлов тарабынан жазылган жана коомдук менчикке берилген.</p>\r\n<p>d) Jsoncpp</p>\r\n<p>2007-2010 Baptiste Lepilleur копирайты </p>\r\n<p>e) sqlite</p>\r\n<p>2001-жылдын 15-сентябрда</p>\r\n<p>f) Zlib</p>\r\n<p>1995-2004 Jean-loup Gailly and Mark Adler копирайты</p>\r\n<p>g) TinyXML-2</p>\r\n<p>2000-2006 Lee Thomson копирайты</p>\r\n<p>h) snappy</p>\r\n<p>2011, Google Inc копирайты. Бардык укуктар мыйзам менен корголот.</p>\r\n<p>i) Qt</p>\r\n<p>2013 Digia Plc копирайты жана\\же анын туунду компаниялары.</p>\r\n<p>17.4. Колдонуучу программалык камсыздоо Компоненттеринин баштапкы коддорун, алардын тиешелүү лицензияларынын шарттарына ылайык алып, модификациялап жана тарата алат. Бул баштапкы коддор Укук ээсинин сайтынан жүктөө үчүн жеткиликтүү болушу мүмкүн&nbsp;же Колдонуучунун суроо-талабы менен Укук ээси тарабынан, ал&nbsp;баштапкы коддордун мазмунуна тийиштүү суроо-талаптарды Укук ээси кабыл албаган шартта берилиши мүмкүн.</p>\r\n<p>17.5. 2ГИС Desktop&nbsp;4.0 менен Программалык камсыздоо компоненттеринин өз&nbsp;ара аракеттенүүсү ушул макулдашуу менен каралганга караганда башкача, кепилдиктин таасирине туура келбейт. Укук ээси бардык финансылык зыян&nbsp;же кетирилген пайда, 2ГИС Desktop&nbsp;4.0 менен берилүүчү программалык камсыздоо Компоненттерин пайдалануунун натыйжасында пайда боло турган үчүнчү жактардын бардык дооматтары үчүн жооп бербейт.</p>\r\n<p>17.6. 2ГИС Desktop&nbsp;4.0 киргизилген ачык коду менен программалык камсыздоого тиешелүү бардык суроолор support@2gis.ruга жөнөтүлүүгө тийиш.</p>\r\n<p><strong>18. Укук ээлери жөнүндө маалымат</strong></p>\r\n<p>18.1. Башка укук ээлеринин тизмеси менен төмөнкү даректен тааныша аласыздар:</p>\r\n<p><a href=\"https://law.2gis.kg/copyright/\">https://law.2gis.kg/copyright/</a></p>\r\n<p>05.08.2024-ж. редакциясы</p>\r\n<p>&nbsp;</p>\r\n<hr />\r\n<h2>\r\nСмотрите также:\r\n</h2>\r\n<ul>\r\n<li><a href=\"/licensing-agreement/red211222/\">Редакция Лицензионного соглашения от&nbsp;21.12.2022г.</a> (утратила силу 05.08.2024г.)</li>\r\n<li><a href=\"/licensing-agreement/red040820/\">Редакция Лицензионного соглашения от&nbsp;04.08.2020г.</a> (утратила силу 21.12.2022г.)</li>\r\n<li><a href=\"/licensing-agreement/red301015/\">Редакция Лицензионного соглашения от&nbsp;30.10.2015г.</a> (утратила силу 04.08.2020г.)</li>\r\n</ul>","module":{"id":"1-8","type":"usercontent"}}}],"initedModules":[{"slot":{"templates":{},"modules":{},"utils":{},"config":{"mainModule":"page","projectName":"infoportal","city.cookieName":"project","mapsApi.libURL":"https://maps.api.2gis.ru/2.0/loader.js?pkg=full","static.prefix":"https://hstatic.2gis.com/","schema":"https","crmEndpoint":"https://info.2gis.ru/moscow/advtilda","infoApi.host":"ayahuasca.2gis.com","monitor.url":"/novosibirsk/monitor","server.listenArgs":[3000],"server.instanceCount":1,"server.useCluster":true,"WebApi.catalogUrl":"https://catalog.api.2gis.ru/2.0/","WebApi.key":"rudxfw6016","suggestUrl":"https://catalog.api.2gis.ru/suggest","logger.app":{"filename":"./logs/app.log","json":false,"timestamp":true},"logger.leaks":{"file":{"filename":"./logs/leaks.log","json":false,"timestamp":true}},"logger.graylog":{"graylogHost":"logserver.test","graylogPort":12201,"level":"warn"},"logger.crash":{"emails":[{"email":"al.kolpakov@2gis.ru"},{"email":"d.donov@2gis.ru"}]},"addFirmHref":"https://reklama.2gis.ru/%1/add-info/?utm_source=partner_network&utm_medium=add_info&utm_campaign=%2","feedbackApi.url":"https://feedback.api.2gis.ru/","feedback.rulesUrl":"https://law.2gis.ru/rules/","feedback.editPhotoUrl":"https://2gis.ru/$photoId","feedback.advertismentHref":"https://reklama.2gis.ru/%2/partner_network/feedback?calculate_for=%1&utm_source=partner_network&utm_medium=ad_link&utm_campaign=feedback","log_channels":["debug","warn"],"projectListTTL":600000,"storeLink.android":"https://play.google.com/store/apps/details?id=ru.dublgis.dgismobile&utm_source=2gisru&utm_medium=link&utm_campaign=android","storeLink.ios":"http://itunes.apple.com/ru/app/2gis/id481627348?mt=8","storeLink.windowsphone":"http://www.windowsphone.com/ru-ru/store/app/2gis/