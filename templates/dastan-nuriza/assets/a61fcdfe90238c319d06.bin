        Запретить обработку cookies можно в&nbsp;настройках Вашего браузера. 
        Пожалуйста, ознакомьтесь с&nbsp;Политиками 
        <a href="https://law.2gis.ru/privacy" target="_blank">конфиденциальности</a>
        и&nbsp;
        <a href="https://law.2gis.ru/privacy/cookie" target="_blank">использования файлов cookies</a></p> <div class="accept-btn"><p>Принять</p></div> </div> <div class="cookies-footer-mobile"> <p class="notice-head">Конфиденциальность</p> <p class="notice-text">2ГИС защищает персональные данные и&nbsp;обрабатывает cookies только для&nbsp;персонализации сервисов. 
        Запретить обработку cookies можно в&nbsp;настройках Вашего браузера. 
        Пожалуйста, ознакомьтесь с&nbsp;Политиками 
        <a href="https://law.2gis.ru/privacy" target="_blank">конфиденциальности</a> <br/>и
        <!--<p>и</p>--> <a href="https://law.2gis.ru/privacy/cookie" target="_blank" style="display:inline">использования файлов cookies</a></p> <div class="swipe-container"> <div class="swipe-track"> <div class="swipe-thumb" id="swipeThumb"></div> <span class="swipe-text">Смахни, чтобы принять</span> </div> </div> </div> </div> <script>
    function acceptCookies() {
        if (!localStorage.getItem('cookies-notified')) {
            localStorage.setItem('cookies-notified', true);
            if (document.querySelector(".cookies-footer-desktop").classList.contains("visible")) {
                document.querySelector(".cookies-footer-desktop").classList.remove("visible")
            }
            if (document.querySelector(".cookies-footer-mobile").classList.contains("visible")) {
                document.querySelector(".cookies-footer-mobile").classList.remove("visible")
            }
        }
    }
    document.querySelector(".cookies-footer-desktop .accept-btn").addEventListener("click", acceptCookies)
    document.addEventListener("DOMContentLoaded", () => {
        console.log(localStorage.getItem('cookies-notified'))
        if (!localStorage.getItem('cookies-notified')) {
            document.querySelector(".cookies-footer-desktop").classList.add("visible")
            document.querySelector(".cookies-footer-mobile").classList.add("visible")
        }
    })
    
    
</script> <style>
    .cookies-footer-desktop {
        font-family: 'SBSans',Arial,sans-serif;
        background: white;
        border-radius: 20px;
        width: fit-content;
        height: 56px;
        padding: 24px;
        gap: 40px;
        position: fixed;
        bottom: 36px;
        left: 50%;
        transform: translateX(-50%);
        align-items: center;
        display: none;
        z-index: 9999;
    }
    .cookies-footer-desktop.visible {
        display: flex;
    }
    
    
    .cookies-footer-desktop .notice-text {
        color: #1A1A1A;
        font-size: 14px;
        line-height: 18px;
        letter-spacing: -0.196px;
        width: 640px;
    }
    .cookies-footer-desktop a {
        color: #0073FA !important;
        font-weight: 600;
        line-height: 16px;
    }
    .cookies-footer-desktop .accept-btn {
        width: 220px;
        height: 56px;
        background: #0073FA;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .cookies-footer-desktop .accept-btn:hover {
        cursor: pointer;
        background: #0D5ABC;
    }
    
    .cookies-footer-desktop .accept-btn p {
        width: unset;
        color: white;
        font-size: 16px;
        font-weight: 600;
        letter-spacing: -0.16px;
    }
    
    .cookies-footer-mobile {
        display: none;
    }
    
    @media(max-width: 1200px) {
        .cookies-footer-desktop.visible {
            display: none;
        }
        .cookies-footer-mobile.visible {
            display: block;
            z-index: 9999;
        }
        .cookies-footer-mobile {
            font-family: 'SBSans',Arial,sans-serif;
            box-sizing: border-box;
            width: 375px;
            /*height: 278px;*/
            height: 220px;
            padding: 20px;
            position: fixed;
            bottom: 0px;
            left: 50%;
            transform: translateX(-50%);
            align-items: center;
            background: white;
            border-radius: 20px;
        }
        
        .cookies-footer-mobile .notice-head {
            color: #1A1A1A;
            font-size: 20px;
            font-weight: 800;
            line-height: 28px;
            letter-spacing: -0.24px;
            width: 100%;
            margin-bottom: 12px;
        }
        
        .cookies-footer-mobile .notice-text {
            color: #1A1A1A;
            font-size: 12px;
            line-height: 16px;
            width: 100%;
            margin-top: 8px;
            letter-spacing: -0.12px;
        }
        .cookies-footer-mobile a {
            color: #0073FA !important;
            font-weight: 600;
            line-height: 16px;
        }
        .swipe-container {
            width: 100%;
            /*margin: 50px auto;*/
            user-select: none;
            margin-top: 16px;
          }
    
          .swipe-track {
            position: relative;
            width: 100%;
            height: 44px;
            background-color: rgba(0, 115, 250, 0.12);
            border-radius: 10px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
          }
    
          .swipe-thumb {
            position: absolute;
            width: 56px;
            height: 44px;
            background-color: #0073fa;
            background-image: url("https://static.tildacdn.com/tild6261-6533-4835-a165-343761663162/keyboard-arrow-down_.png");
            background-position: center;
            background-size: 24px;
            background-repeat: no-repeat;
            border-radius: 10px;
            cursor: grab;
            z-index: 2;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
          }
          
          .swipe-thumb:active {
            background-color: #0D5ABC;
          }
    
          .swipe-text {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            color: #0073fa;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: -0.14px;
            pointer-events: none;
            z-index: 1;
          }

    }
</style> <script>
    document.addEventListener("DOMContentLoaded", () => {
        const thumb = document.getElementById("swipeThumb");
      const track = thumb.closest(".swipe-track");
      const container = thumb.closest(".swipe-container");

      let isDragging = false;
      let startX = 0;
      let currentX = 0;
      let offsetX = 0;

      const trackWidth = track.offsetWidth;
      console.log(trackWidth);
      const thumbWidth = thumb.offsetWidth;
      console.log(thumbWidth);
      const maxTranslate = trackWidth - thumbWidth;

      // Обработчики мыши
      thumb.addEventListener("mousedown", startDrag);
      document.addEventListener("mousemove", onDrag);
      document.addEventListener("mouseup", endDrag);

      // Обработчики тач-событий для мобильных
      thumb.addEventListener("touchstart", (e) => {
        e.preventDefault();
        startDrag(e.touches[0]);
      });
      document.addEventListener("touchmove", (e) => {
        e.preventDefault();
        onDrag(e.touches[0]);
        console.log(e.touches[0]);
      });
      document.addEventListener("touchend", endDrag);

      function startDrag(e) {
        isDragging = true;
        startX = e.clientX || e.touches?.[0]?.clientX;
        offsetX = parseFloat(
          getComputedStyle(thumb).transform.split(",")[4] || 0
        );
        thumb.style.cursor = "grabbing";
      }

      function onDrag(e) {
        if (!isDragging) return;

        const x = e.clientX || e.touches?.[0]?.clientX;
        currentX = offsetX + (x - startX);
        const clampedX = Math.max(0, Math.min(currentX, maxTranslate));

        thumb.style.transform = `translateX(${clampedX}px)`;
      }

      function endDrag() {
        if (!isDragging) return;

        isDragging = false;
        thumb.style.cursor = "grab";

        const finalX = parseFloat(
          getComputedStyle(thumb).transform.split(",")[4] || 0
        );

        if (finalX >= maxTranslate * 0.5) {
          // Успешный свайп → подтверждение
          confirmAction();
        } else {
          // Откат
          thumb.style.transition = "transform 0.1s ease";
          thumb.style.transform = "translateX(0px)";
          setTimeout(() => {
            thumb.style.transition = "";
          }, 100);
        }
      }

      function confirmAction() {
        // Отключаем взаимодействие
        thumb.style.pointerEvents = "none";

        const textEl = track.querySelector(".swipe-text");
        textEl.textContent = "Подтверждено";
        textEl.style.opacity = "1";

        thumb.style.transition = "transform 0.1s ease";
        thumb.style.transform = `translateX(${maxTranslate}px)`;
        setTimeout(() => {
          acceptCookies();
        }, 600);
      }
    })
      
</script> <!-- nominify end --> </div> </div> </div> </div> <div id="rec2213206221" class="r t-rec" style=" " data-animationappear="off" data-record-type="131"> <!-- T123 --> <div class="t123"> <div class="t-container_100 "> <div class="t-width t-width_100 "> <!-- nominify begin --> <script>
$(document).ready(function() {
    $('.t-submenublocks__item').on('click', function (e) {
        
        e.preventDefault(); 
        if ($(this).text().trim() === "KG") {
            
            const currentUrl = window.location.href;
            let newUrl = ''; 
            if (currentUrl.includes("about")) {
                newUrl = 'https://reklama.2gis.kg/about';
            }
            else if (currentUrl.includes("price")) {
                newUrl = 'https://reklama.2gis.kg/price';
            }
            else if (currentUrl.includes("add-info")) {
                newUrl = 'https://reklama.2gis.kg/add-info';
            }
            else {
                newUrl = 'https://reklama.2gis.kg';
            }
            window.location.href = newUrl;
        }
    });
});
</script> <!-- nominify end --> </div> </div> </div> </div> <div id="rec1923499021" class="r t-rec" style=" " data-animationappear="off" data-record-type="121" data-alias-record-type="794"> <!-- T794 --> <div class="t794" data-tooltip-hook="#language" data-tooltip-margin="1px" data-add-arrow=""> <div class="t794__tooltip-menu"> <div class="t794__content"> <ul class="t794__list" role="menu" aria-label=""> <li class="t794__list_item t-submenublocks__item t-name t-name_xs"> <a class="t794__typo t794__typo_1923499021 t794__link t-name t-name_xs"
